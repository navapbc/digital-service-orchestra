#!/bin/sh
# dso — shim for dispatching DSO plugin commands in a host project.
#
# Usage:
#   dso <script-name> [args...]
#
# DSO_ROOT resolution order:
#   1. $CLAUDE_PLUGIN_ROOT environment variable
#   2. dso.plugin_root key in .claude/dso-config.conf at the git repo root
#   3. Self-detect: REPO_ROOT/plugins/dso when sentinel .claude-plugin/plugin.json exists
#   4. Exit non-zero with an error naming the config key and file
#
# Install this file as .claude/scripts/dso in your host project and
# make it executable (chmod +x).

# ── Resolve DSO_ROOT ──────────────────────────────────────────────────────────

DSO_ROOT=""

# (1) Prefer explicit env var
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    DSO_ROOT="$CLAUDE_PLUGIN_ROOT"
fi

# (2) Fall back to .claude/dso-config.conf in the git repo root
if [ -z "$DSO_ROOT" ]; then
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || REPO_ROOT=""
    if [ -n "$REPO_ROOT" ] && [ -f "$REPO_ROOT/.claude/dso-config.conf" ]; then
        DSO_ROOT="$(grep '^dso\.plugin_root=' "$REPO_ROOT/.claude/dso-config.conf" 2>/dev/null | cut -d= -f2-)"
        # Resolve relative paths against REPO_ROOT (d145-1b1e)
        if [ -n "$DSO_ROOT" ] && [ "${DSO_ROOT#/}" = "$DSO_ROOT" ]; then
            DSO_ROOT="$REPO_ROOT/$DSO_ROOT"
        fi
    fi
fi

# (3) Self-detect: REPO_ROOT/plugins/dso with sentinel validation
if [ -z "$DSO_ROOT" ] && [ -n "$REPO_ROOT" ] && [ -f "$REPO_ROOT/plugins/dso/.claude-plugin/plugin.json" ]; then
    DSO_ROOT="$REPO_ROOT/plugins/dso"
fi

# Export DSO_ROOT as CLAUDE_PLUGIN_ROOT so downstream scripts can rely on it
# (They may use CLAUDE_PLUGIN_ROOT directly, e.g. hooks/lib/config-paths.sh)
# Guard: only export when CLAUDE_PLUGIN_ROOT was NOT already set by the caller.
# If the caller pre-set CLAUDE_PLUGIN_ROOT (step 1 above), DSO_ROOT came from
# that value — re-exporting would be a no-op at best and would risk overwriting
# a caller-controlled value with a stale config fallback in re-source scenarios.
if [ -n "$DSO_ROOT" ] && [ -z "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    export CLAUDE_PLUGIN_ROOT="$DSO_ROOT"
fi

# (4) Neither source provided a value — tell the user how to fix it
if [ -z "$DSO_ROOT" ]; then
    printf 'dso: DSO plugin root not configured.\n' >&2
    printf 'dso: Set the CLAUDE_PLUGIN_ROOT environment variable, or add\n' >&2
    printf 'dso:   dso.plugin_root=<path-to-plugin>\n' >&2
    printf 'dso: to .claude/dso-config.conf in your git repository root.\n' >&2
    exit 1
fi

# ── Resolve PROJECT_ROOT ──────────────────────────────────────────────────────
# Export the host project's git root so dispatched scripts can locate project
# resources (.tickets-tracker, app/, tests/) without relying on CWD or
# git rev-parse (which returns the wrong root when CWD is the plugin cache).
# Resolution: reuse REPO_ROOT if already computed above; otherwise compute now.
if [ -z "${REPO_ROOT:-}" ]; then
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || REPO_ROOT=""
fi
if [ -n "$REPO_ROOT" ]; then
    export PROJECT_ROOT="$REPO_ROOT"
fi

# ── Library mode ──────────────────────────────────────────────────────────────

# Library mode: export DSO_ROOT and return without dispatching
if [ "${1:-}" = "--lib" ]; then
    export DSO_ROOT="$DSO_ROOT"
    return 0 2>/dev/null || exit 0
fi

# ── Dispatch ──────────────────────────────────────────────────────────────────
# Registered commands (auto-dispatched via $DSO_ROOT/scripts/<cmd>[.sh]):
#   harvest-worktree — merge worktree branch into session with gate validation

if [ $# -eq 0 ]; then
    printf 'dso: usage: dso <command> [args...]\n' >&2
    exit 1
fi

CMD="$1"
shift

SCRIPT_PATH="$DSO_ROOT/scripts/$CMD"

# Fallback: try with .sh extension if exact match not found (0c98-6085)
if [ ! -f "$SCRIPT_PATH" ] && [ -f "${SCRIPT_PATH}.sh" ]; then
    SCRIPT_PATH="${SCRIPT_PATH}.sh"
fi

# Fallback: hook scripts live in hooks/ not scripts/ (7f36-1317, d122-20d3)
if [ ! -f "$SCRIPT_PATH" ]; then
    HOOK_PATH="$DSO_ROOT/hooks/$CMD"
    if [ ! -f "$HOOK_PATH" ] && [ -f "${HOOK_PATH}.sh" ]; then
        HOOK_PATH="${HOOK_PATH}.sh"
    fi
    if [ -f "$HOOK_PATH" ]; then
        SCRIPT_PATH="$HOOK_PATH"
    fi
fi

if [ ! -f "$SCRIPT_PATH" ]; then
    printf 'dso: command not found: %s\n' "$CMD" >&2
    printf 'dso: (looked for %s)\n' "$SCRIPT_PATH" >&2
    exit 127
fi

if [ ! -x "$SCRIPT_PATH" ]; then
    printf 'dso: script not executable: %s\n' "$SCRIPT_PATH" >&2
    exit 127
fi

exec "$SCRIPT_PATH" "$@"
