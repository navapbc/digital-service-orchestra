{
  "name": "lockpick-workflow",
  "version": "0.2.0",
  "description": "Workflow infrastructure plugin for Claude Code projects \u2014 TDD-driven sprint management, review gates, hook parameterization, and multi-stack config",
  "repository": "https://github.com/lockpick/lockpick-workflow",
  "homepage": "https://github.com/lockpick/lockpick-workflow#readme",
  "license": "MIT",
  "install": {
    "command": "claude plugin install github:lockpick/lockpick-workflow",
    "requires_env": "CLAUDE_PLUGIN_ROOT"
  },
  "compatibility": {
    "claude_code": ">=1.0.0",
    "min_bash": "4.0"
  },
  "skills": "skills/",
  "hooks": "hooks.json",
  "config_schema": "docs/workflow-config-schema.json",
  "tags": [
    "workflow",
    "tdd",
    "sprint",
    "review",
    "hooks"
  ]
}
