{
  "name": "digital-service-orchestra",
  "version": "0.2.0",
  "description": "Workflow infrastructure plugin for Claude Code projects \u2014 TDD-driven sprint management, review gates, hook parameterization, and multi-stack config",
  "repository": "https://github.com/navapbc/digital-service-orchestra",
  "homepage": "https://github.com/navapbc/digital-service-orchestra#readme",
  "license": "MIT",
  "install": {
    "command": "claude plugin install github:navapbc/digital-service-orchestra",
    "requires_env": "CLAUDE_PLUGIN_ROOT"
  },
  "compatibility": {
    "claude_code": ">=1.0.0",
    "min_bash": "4.0"
  },
  "skills": "skills/",
  "hooks": "hooks.json",
  "config_schema": "docs/workflow-config-schema.json",
  "tags": [
    "workflow",
    "tdd",
    "sprint",
    "review",
    "hooks"
  ],
  "externalDependencies": {
    "tk": {
      "required": true,
      "description": "Ticket management CLI for issue tracking workflows",
      "check": "command -v tk",
      "installHint": "See https://github.com/lockpick/tk for installation"
    }
  }
}
