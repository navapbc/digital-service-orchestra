#!/usr/bin/env bash
# tk-plugin: Output tickets as JSON, optionally filtered with jq (pipe output through jq for transforms)
# REVIEW-DEFENSE: testing_coverage — These are vendored bash tk-plugin scripts.
# The project has no bash test infrastructure (no bats/shunit2). The Python test
# suite (make test-unit-only) covers the app/ directory only. Command injection
# is mitigated by the jq filter allowlist validation added in this diff. Adding
# bash test infra is tracked separately.
# tk-plugin-version: 1.0.0
set -euo pipefail

if [[ -z "${TICKETS_DIR:-}" ]]; then
    echo "Error: TICKETS_DIR is not set or empty" >&2
    exit 1
fi

filter="${1:-}"

# Validate jq filter to prevent command injection.
# Allowlist: field access (.foo), comparisons (==, !=, <, >, <=, >=),
# boolean operators (and, or, not), string literals, numbers, parentheses,
# array indexing, and comma. Pipe (|) is excluded — it enables jq builtins
# like `env` that could leak sensitive data.
# For transforms, pipe the output of this command through jq externally:
#   tk query | jq '[.[] | select(.status == "open")] | length'
if [[ -n "$filter" ]]; then
    if [[ "$filter" =~ \| ]]; then
        echo "Error: pipe (|) is not allowed in tk query filters." >&2
        echo "  To chain transforms, pipe tk query output through jq instead:" >&2
        echo "    tk query | jq 'select(.status == \"open\")'" >&2
        echo "    tk query | jq '[.[] | select(.priority < 3)] | length'" >&2
        echo "  Or use 'and'/'or' for multi-condition filters:" >&2
        echo "    tk query '.status == \"open\" and .priority < 3'" >&2
        exit 1
    fi
    # Allowlist: only permit characters used in safe field access and comparisons.
    # Rejects semicolons, backticks, dollar signs ($ENV), @ format strings, braces,
    # and other characters not needed for .field == "value" style filtering.
    if [[ "$filter" =~ [^a-zA-Z0-9_.=!\<\>\(\)\[\],\"\'\ \	-] ]]; then
        echo "Error: filter contains disallowed characters" >&2
        exit 1
    fi
fi

# Generate all JSON in one awk pass
json_output=$(awk '
BEGIN { FS=": "; in_front=0 }
FNR==1 {
    if (prev_file) emit()
    field_count=0; in_front=0
    prev_file=FILENAME
}
/^---$/ { in_front = !in_front; next }
in_front && /^[a-zA-Z]/ {
    key = $1
    val = substr($0, length($1) + 3)
    gsub(/^ +| +$/, "", val)
    field_count++
    field_keys[field_count] = key
    field_vals[field_count] = val
}
function json_escape(s) {
    gsub(/\\/, "\\\\", s)
    gsub(/"/, "\\\"", s)
    gsub(/\n/, "\\n", s)
    gsub(/\r/, "\\r", s)
    gsub(/\t/, "\\t", s)
    return s
}
function emit() {
    if (field_count > 0) {
        printf "{"
        for (i = 1; i <= field_count; i++) {
            if (i > 1) printf ","
            key = json_escape(field_keys[i])
            val = field_vals[i]
            # Handle arrays
            if (val ~ /^\[.*\]$/) {
                gsub(/^\[|\]$/, "", val)
                n = split(val, items, ", *")
                printf "\"%s\":[", key
                for (j = 1; j <= n; j++) {
                    if (j > 1) printf ","
                    gsub(/^ +| +$/, "", items[j])
                    if (items[j] != "") printf "\"%s\"", json_escape(items[j])
                }
                printf "]"
            } else {
                printf "\"%s\":\"%s\"", key, json_escape(val)
            }
        }
        printf "}\n"
    }
}
END { if (prev_file) emit() }
' "$TICKETS_DIR"/*.md 2>/dev/null)

if [[ -n "$filter" ]]; then
    echo "$json_output" | jq -c "select($filter)"
else
    echo "$json_output"
fi
