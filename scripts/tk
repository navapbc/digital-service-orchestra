#!/usr/bin/env bash
set -euo pipefail

# ticket - minimal ticket system with dependency tracking
# Stores markdown files with YAML frontmatter in .tickets/

# Read a value from workflow-config.yaml using read-config.sh
# Returns empty string and exit 0 if key or config not found.
_tk_read_config() {
    local key="$1"
    local _read_config=""

    # Find read-config.sh relative to this script's location (lockpick-workflow/scripts/tk)
    local _script_dir
    _script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local _tk_repo_root
    _tk_repo_root="$(cd "$_script_dir/../.." && pwd)"

    # read-config.sh is a sibling in the same directory
    if [[ -x "$_script_dir/read-config.sh" ]]; then
        _read_config="$_script_dir/read-config.sh"
    fi

    # Also check relative to the current git repo root (for installed plugins)
    if [[ -z "$_read_config" ]]; then
        local _repo_root
        _repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
        if [[ -n "$_repo_root" ]] && [[ -x "$_repo_root/lockpick-workflow/scripts/read-config.sh" ]]; then
            _read_config="$_repo_root/lockpick-workflow/scripts/read-config.sh"
        fi
    fi

    if [[ -n "$_read_config" ]]; then
        # Pass the config file from the current repo, not from tk's repo
        local _repo_root
        _repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")
        local _config_file="$_repo_root/workflow-config.yaml"
        if [[ -f "$_config_file" ]]; then
            # Ensure read-config.sh can find Python with pyyaml by hinting
            # the venv from tk's own repo if not already set
            if [[ -z "${CLAUDE_PLUGIN_PYTHON:-}" ]]; then
                local _py_candidate="$_tk_repo_root/app/.venv/bin/python3"
                if [[ -f "$_py_candidate" ]] && "$_py_candidate" -c "import yaml" 2>/dev/null; then
                    CLAUDE_PLUGIN_PYTHON="$_py_candidate" "$_read_config" "$_config_file" "$key" 2>/dev/null || true
                    return
                fi
            fi
            "$_read_config" "$_config_file" "$key" 2>/dev/null || true
        fi
    fi
}

# Find .tickets directory by walking parent directories
find_tickets_dir() {
    # Explicit env var takes priority
    [[ -n "${TICKETS_DIR:-}" ]] && { echo "$TICKETS_DIR"; return 0; }

    # Check workflow-config.yaml for tickets.directory
    local _config_dir
    _config_dir=$(_tk_read_config "tickets.directory")
    if [[ -n "$_config_dir" ]]; then
        # Resolve relative to repo root
        local _repo_root
        _repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")
        if [[ -d "$_repo_root/$_config_dir" ]]; then
            echo "$_repo_root/$_config_dir"
            return 0
        fi
    fi

    # Walk parents looking for .tickets
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -d "$dir/.tickets" ]]; then
            echo "$dir/.tickets"
            return 0
        fi
        dir=$(dirname "$dir")
    done

    # Check root too
    [[ -d "/.tickets" ]] && { echo "/.tickets"; return 0; }

    # Not found
    return 1
}

# Commands that can create .tickets if not found
WRITE_COMMANDS="create"

# Initialize TICKETS_DIR based on command type
init_tickets_dir() {
    local cmd="$1"
    local is_write_cmd=0
    [[ " $WRITE_COMMANDS " == *" $cmd "* ]] && is_write_cmd=1

    if TICKETS_DIR=$(find_tickets_dir); then
        # For read commands, verify the directory exists
        if [[ $is_write_cmd -eq 0 ]] && [[ ! -d "$TICKETS_DIR" ]]; then
            echo "Error: tickets directory '$TICKETS_DIR' does not exist" >&2
            return 1
        fi
        return 0
    fi

    # Not found - write commands can initialize in current directory
    if [[ $is_write_cmd -eq 1 ]]; then
        TICKETS_DIR=".tickets"
        return 0
    fi

    echo "Error: no .tickets directory found (searched parent directories)" >&2
    echo "Run 'tk create' to initialize, or set TICKETS_DIR env var" >&2
    return 1
}

TICKET_PAGER="${TICKET_PAGER:-${PAGER:-}}"

# Prefer ripgrep if available, fall back to grep
if command -v rg &>/dev/null; then
    _grep() { rg "$@"; }
else
    _grep() { grep "$@"; }
fi

# Portable ISO date (GNU date supports -Iseconds, BSD date does not)
_iso_date() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

# Portable sed -i (BSD requires -i '', GNU uses -i)
_sed_i() {
    local file="$1"
    shift
    local tmp="${file}.tmp.$$"
    sed "$@" "$file" > "$tmp" && mv "$tmp" "$file"
}

# Generate ticket ID from config prefix or directory name + random string
generate_id() {
    local prefix

    # Check workflow-config.yaml for tickets.prefix
    prefix=$(_tk_read_config "tickets.prefix")

    if [[ -z "$prefix" ]]; then
        # Fall back to deriving prefix from directory name
        local dir_name
        dir_name=$(basename "$(pwd)")

        # Extract first letter of each hyphenated/underscored segment
        prefix=$(echo "$dir_name" | sed 's/[-_]/ /g' | awk '{for(i=1;i<=NF;i++) printf substr($i,1,1)}')

        # Fallback to first 3 chars if single segment (prefix too short)
        [[ ${#prefix} -lt 2 ]] && prefix="${dir_name:0:3}"
    fi

    # 4-char random lower case alphanumeric string
    # Use dd to read a fixed buffer instead of tr|head to avoid SIGPIPE under pipefail
    local hash
    hash=$(dd if=/dev/urandom bs=256 count=1 2>/dev/null | LC_ALL=C tr -dc 'a-z0-9' | head -c 4)

    echo "${prefix}-${hash}"
}

# Ensure tickets directory exists
ensure_dir() {
    mkdir -p "$TICKETS_DIR"
}

# Get ticket file path (supports partial ID matching)
ticket_path() {
    local id="$1"
    # Trim leading/trailing whitespace (handles Claude/agent quirks)
    read -r id <<< "$id"

    # Guard: reject empty IDs and IDs containing path traversal components.
    # An ID must not be empty, must not contain '/', and must not be '..'.
    # This prevents path traversal attacks like "../../../etc/passwd".
    if [[ -z "$id" || "$id" == *"/"* || "$id" == ".." ]]; then
        echo "Error: invalid ticket ID '$id'" >&2
        return 1
    fi

    local exact="$TICKETS_DIR/${id}.md"

    if [[ -f "$exact" ]]; then
        echo "$exact"
        return 0
    fi

    # Try partial match (anywhere in filename)
    local matches
    matches=$(find "$TICKETS_DIR" -maxdepth 1 -name "*${id}*.md" 2>/dev/null | head -2)
    local count
    count=$(echo "$matches" | _grep -c . || true)

    if [[ "$count" -eq 1 ]]; then
        echo "$matches"
        return 0
    elif [[ "$count" -gt 1 ]]; then
        echo "Error: ambiguous ID '$id' matches multiple tickets" >&2
        return 1
    else
        echo "Error: ticket '$id' not found" >&2
        return 1
    fi
}

# Extract YAML field value
yaml_field() {
    local file="$1"
    local field="$2"
    sed -n '/^---$/,/^---$/p' "$file" | _grep "^${field}:" | sed "s/^${field}: *//"
}

# Update YAML field
update_yaml_field() {
    local file="$1"
    local field="$2"
    local value="$3"

    if _grep -q "^${field}:" "$file"; then
        _sed_i "$file" "s/^${field}:.*/${field}: ${value}/"
    else
        # Insert new field before closing --- of frontmatter.
        # Uses python3 for cross-platform reliability (BSD sed on macOS
        # does not support the 0,/range/ address syntax).
        FIELD="$field" VALUE="$value" python3 -c "
import os
field = os.environ['FIELD']
value = os.environ['VALUE']
lines = open('$file').readlines()
result = []
fm_count = 0
inserted = False
for line in lines:
    stripped = line.rstrip('\n').rstrip('\r')
    if stripped == '---':
        fm_count += 1
        if fm_count == 2 and not inserted:
            result.append(field + ': ' + value + '\n')
            inserted = True
    result.append(line)
open('$file', 'w').writelines(result)
" 2>/dev/null
    fi
}

# ---------------------------------------------------------------------------
# Source the ticket-sync push library.
# Provides _sync_ticket_file <absolute_path> — fire-and-forget push to main.
# Guard: silently skip if the lib is absent (e.g., during bootstrap).
# ---------------------------------------------------------------------------
_TK_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/tk-sync-lib.sh
if [[ -f "${_TK_SCRIPT_DIR}/tk-sync-lib.sh" ]]; then
    source "${_TK_SCRIPT_DIR}/tk-sync-lib.sh"
else
    # Stub: no-op so _sync_ticket_file calls below are always safe
    _sync_ticket_file() { return 0; }
fi

cmd_create() {
    ensure_dir

    local title="" description="" design="" acceptance=""
    local priority=2 issue_type="task" assignee="" external_ref="" parent="" tags=""

    # Default assignee to git user.name if available
    assignee=$(git config user.name 2>/dev/null || true)

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--description) description="$2"; shift 2 ;;
            --design) design="$2"; shift 2 ;;
            --acceptance) acceptance="$2"; shift 2 ;;
            -p|--priority) priority="$2"; shift 2 ;;
            -t|--type) issue_type="$2"; shift 2 ;;
            -a|--assignee) assignee="$2"; shift 2 ;;
            --external-ref) external_ref="$2"; shift 2 ;;
            --parent=*) parent="${1#--parent=}"; shift ;;
            --parent) parent="$2"; shift 2 ;;
            --tags) tags="$2"; shift 2 ;;
            -*) echo "Unknown option: $1" >&2; return 1 ;;
            *) title="$1"; shift ;;
        esac
    done

    # Validate and resolve parent if specified
    if [[ -n "$parent" ]]; then
        local parent_file
        parent_file=$(ticket_path "$parent") || return 1
        parent=$(basename "$parent_file" .md)
    fi

    title="${title:-Untitled}"

    # Hard gate: Jira summary field has a 255-character limit.
    local title_max=255
    local title_len=${#title}
    if (( title_len > title_max )); then
        echo "Error: ticket title is ${title_len} characters (max ${title_max})." >&2
        echo "Jira's summary field has a ${title_max}-character limit. Please shorten the title." >&2
        return 1
    fi

    local id
    id=$(generate_id)
    local file="$TICKETS_DIR/${id}.md"
    local now
    now=$(_iso_date)

    {
        echo "---"
        echo "id: $id"
        echo "status: open"
        echo "deps: []"
        echo "links: []"
        echo "created: $now"
        echo "type: $issue_type"
        echo "priority: $priority"
        [[ -n "$assignee" ]] && echo "assignee: $assignee"
        [[ -n "$external_ref" ]] && echo "external-ref: $external_ref"
        [[ -n "$parent" ]] && echo "parent: $parent"
        if [[ -n "$tags" ]]; then
            echo "tags: [${tags//,/, }]"
        fi
        echo "---"
        echo "# $title"
        echo ""
        if [[ -n "$description" ]]; then
            echo "$description"
            echo ""
        fi
        if [[ -n "$design" ]]; then
            echo "## Design"
            echo ""
            echo "$design"
            echo ""
        fi
        if [[ -n "$acceptance" ]]; then
            echo "## Acceptance Criteria"
            echo ""
            echo "$acceptance"
            echo ""
        fi
    } > "$file"

    ( _sync_ticket_file "$file" || true )
    echo "$id"
}

# Valid statuses
VALID_STATUSES="open in_progress closed"

validate_status() {
    local status="$1"
    for valid in $VALID_STATUSES; do
        [[ "$status" == "$valid" ]] && return 0
    done
    echo "Error: invalid status '$status'. Must be one of: $VALID_STATUSES" >&2
    return 1
}

cmd_status() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: $(basename "$0") status <id> <status>" >&2
        echo "Valid statuses: $VALID_STATUSES" >&2
        return 1
    fi

    local id="$1"
    local status="$2"

    validate_status "$status" || return 1

    local file
    file=$(ticket_path "$id") || return 1

    update_yaml_field "$file" "status" "$status"
    ( _sync_ticket_file "$file" || true )
    echo "Updated $(basename "$file" .md) -> $status"
}

cmd_start() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") start <id>" >&2
        return 1
    fi
    cmd_status "$1" "in_progress"
}

cmd_close() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") close <id> [--reason=\"...\"]" >&2
        return 1
    fi
    local id=""
    local reason=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reason=*) reason="${1#--reason=}"; shift ;;
            --reason)   reason="${2:-}"; shift 2 ;;
            *)          id="$1"; shift ;;
        esac
    done
    if [[ -z "$id" ]]; then
        echo "Usage: $(basename "$0") close <id> [--reason=\"...\"]" >&2
        return 1
    fi
    if [[ -n "$reason" ]]; then
        cmd_add_note "$id" "CLOSE REASON: $reason"
    fi
    cmd_status "$id" "closed"
    local _close_file
    ( _close_file=$(ticket_path "$id" 2>/dev/null) && _sync_ticket_file "$_close_file" || true )
}

cmd_reopen() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") reopen <id>" >&2
        return 1
    fi
    cmd_status "$1" "open"
    local _reopen_file
    ( _reopen_file=$(ticket_path "$1" 2>/dev/null) && _sync_ticket_file "$_reopen_file" || true )
}

cmd_dep_tree() {
    local full_mode=0
    local root_id=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --full) full_mode=1; shift ;;
            *) root_id="$1"; shift ;;
        esac
    done

    if [[ -z "$root_id" ]]; then
        echo "Usage: ticket dep tree [--full] <id>" >&2
        return 1
    fi

    awk -v root_pattern="$root_id" -v full_mode="$full_mode" '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; deps=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { status = $2 }
    in_front && /^deps:/ {
        deps = $2
        gsub(/[\[\] ]/, "", deps)
    }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function store() {
        if (id != "") {
            statuses[id] = status
            titles[id] = title
            deps_str[id] = deps
            n = split(deps, arr, ",")
            for (i = 1; i <= n; i++) if (arr[i] != "") {
                dep_count[id]++
                dep_list[id, dep_count[id]] = arr[i]
            }
        }
    }

    END {
        if (prev_file) store()
        # Resolve partial ID
        root = ""
        for (id in statuses) {
            if (index(id, root_pattern) > 0) {
                if (root != "") {
                    print "Error: ambiguous ID " root_pattern > "/dev/stderr"
                    exit 1
                }
                root = id
            }
        }
        if (root == "") {
            print "Error: ticket " root_pattern " not found" > "/dev/stderr"
            exit 1
        }

        # Find max depths using iterative approach with stack
        stack[1] = root; stack_depth[1] = 0; stack_path[1] = ":"
        sp = 1
        while (sp > 0) {
            id = stack[sp]; depth = stack_depth[sp]; path = stack_path[sp]
            sp--

            if (!(id in statuses)) continue
            if (index(path, ":" id ":") > 0) continue

            if (!(id in max_depth) || depth > max_depth[id]) {
                max_depth[id] = depth
            }

            new_path = path id ":"
            for (i = dep_count[id]; i >= 1; i--) {
                child = dep_list[id, i]
                if (child != "") {
                    sp++
                    stack[sp] = child
                    stack_depth[sp] = depth + 1
                    stack_path[sp] = new_path
                }
            }
        }

        # Compute subtree depths (iterative post-order)
        delete stack; delete stack_depth; delete stack_path
        delete visited
        stack[1] = root; stack_path[1] = ":"; stack_phase[1] = 0
        sp = 1
        while (sp > 0) {
            id = stack[sp]; path = stack_path[sp]; phase = stack_phase[sp]

            if (!(id in statuses) || index(path, ":" id ":") > 0) { sp--; continue }

            if (phase == 0) {
                # First visit: push children
                stack_phase[sp] = 1
                new_path = path id ":"
                for (i = dep_count[id]; i >= 1; i--) {
                    child = dep_list[id, i]
                    if (child != "" && !(child in subtree_depth)) {
                        sp++
                        stack[sp] = child
                        stack_path[sp] = new_path
                        stack_phase[sp] = 0
                    }
                }
            } else {
                # Second visit: compute subtree depth
                max_sub = max_depth[id]
                for (i = 1; i <= dep_count[id]; i++) {
                    child = dep_list[id, i]
                    if (child in subtree_depth && subtree_depth[child] > max_sub) {
                        max_sub = subtree_depth[child]
                    }
                }
                subtree_depth[id] = max_sub
                sp--
            }
        }

        # Print tree (iterative with stack)
        print root " [" statuses[root] "] " titles[root]
        printed[root] = 1

        delete stack
        # Stack entries: id|depth|prefix|connector|path
        # Start with root children
        build_children(root, 0, "", "", ":" root ":")

        while (print_sp > 0) {
            id = print_stack_id[print_sp]
            depth = print_stack_depth[print_sp]
            prefix = print_stack_prefix[print_sp]
            connector = print_stack_conn[print_sp]
            path = print_stack_path[print_sp]
            print_sp--

            if (!(id in statuses)) continue
            if (!full_mode && (id in printed)) continue
            if (index(path, ":" id ":") > 0) continue
            if (!full_mode && depth != max_depth[id]) continue

            print prefix connector id " [" statuses[id] "] " titles[id]
            if (!full_mode) printed[id] = 1

            if (connector == "└── ") new_prefix = prefix "    "
            else new_prefix = prefix "│   "

            build_children(id, depth, new_prefix, connector, path id ":")
        }
    }

    function build_children(id, depth, prefix, connector, path,    i, child, n, arr, sorted, j, tmp, min_idx) {
        # Collect printable children
        n = 0
        for (i = 1; i <= dep_count[id]; i++) {
            child = dep_list[id, i]
            if (child == "") continue
            if (!full_mode && (child in printed)) continue
            if (!(child in max_depth)) continue
            if (!full_mode && depth + 1 != max_depth[child]) continue
            if (index(path, ":" child ":") > 0) continue
            n++
            arr[n] = child
        }
        if (n == 0) return

        # Sort by subtree_depth, then by ticket ID (insertion sort)
        for (i = 2; i <= n; i++) {
            tmp = arr[i]
            j = i - 1
            while (j >= 1 && (subtree_depth[arr[j]] > subtree_depth[tmp] || \
                   (subtree_depth[arr[j]] == subtree_depth[tmp] && arr[j] > tmp))) {
                arr[j + 1] = arr[j]
                j--
            }
            arr[j + 1] = tmp
        }

        # Push to stack in reverse order (so first prints first)
        for (i = n; i >= 1; i--) {
            child = arr[i]
            print_sp++
            print_stack_id[print_sp] = child
            print_stack_depth[print_sp] = depth + 1
            print_stack_prefix[print_sp] = prefix
            if (i == n) print_stack_conn[print_sp] = "└── "
            else print_stack_conn[print_sp] = "├── "
            print_stack_path[print_sp] = path
        }
    }
    ' "$TICKETS_DIR"/*.md 2>/dev/null
}

cmd_dep_cycle() {
    awk '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; deps=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { status = $2 }
    in_front && /^deps:/ {
        deps = $2
        gsub(/[\[\] ]/, "", deps)
    }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function store() {
        if (id != "" && status != "closed") {
            statuses[id] = status
            titles[id] = title
            deps_str[id] = deps
            n = split(deps, arr, ",")
            for (i = 1; i <= n; i++) if (arr[i] != "") {
                dep_count[id]++
                dep_list[id, dep_count[id]] = arr[i]
            }
        }
    }

    # DFS cycle detection
    function dfs(node, path, path_len,    i, child, result) {
        if (!(node in statuses)) return ""
        if (state[node] == 2) return ""  # black - fully visited
        if (state[node] == 1) {
            # gray - found cycle, extract it
            cycle = node
            for (i = path_len; i >= 1; i--) {
                cycle = path[i] " -> " cycle
                if (path[i] == node) break
            }
            return cycle
        }

        state[node] = 1  # gray - visiting
        path[path_len + 1] = node

        for (i = 1; i <= dep_count[node]; i++) {
            child = dep_list[node, i]
            result = dfs(child, path, path_len + 1)
            if (result != "") return result
        }

        state[node] = 2  # black - done
        return ""
    }

    END {
        if (prev_file) store()

        cycle_count = 0
        for (id in statuses) {
            if (state[id] == 0) {
                delete path
                result = dfs(id, path, 0)
                if (result != "") {
                    # Check if this cycle is already found (normalized)
                    # Extract cycle members
                    n = split(result, parts, " -> ")
                    # Normalize: find smallest ID as starting point
                    min_id = parts[1]
                    min_idx = 1
                    for (i = 2; i < n; i++) {  # skip last (duplicate of first)
                        if (parts[i] < min_id) {
                            min_id = parts[i]
                            min_idx = i
                        }
                    }
                    # Build normalized cycle string
                    norm = ""
                    for (i = 0; i < n - 1; i++) {
                        idx = ((min_idx - 1 + i) % (n - 1)) + 1
                        norm = (norm == "") ? parts[idx] : norm "," parts[idx]
                    }
                    # Check if already seen
                    if (!(norm in seen_cycles)) {
                        seen_cycles[norm] = 1
                        cycle_count++
                        cycles[cycle_count] = result
                        cycle_members[cycle_count] = norm
                    }
                }
            }
        }

        if (cycle_count == 0) {
            print "No dependency cycles found"
        } else {
            for (c = 1; c <= cycle_count; c++) {
                if (c > 1) print ""
                print "Cycle " c ": " cycles[c]
                n = split(cycle_members[c], members, ",")
                for (i = 1; i <= n; i++) {
                    id = members[i]
                    printf "  %-8s [%s] %s\n", id, statuses[id], titles[id]
                }
            }
        }
    }
    ' "$TICKETS_DIR"/*.md 2>/dev/null
}

cmd_dep() {
    # Handle subcommands
    if [[ "${1:-}" == "tree" ]]; then
        shift
        cmd_dep_tree "$@"
        return
    fi
    if [[ "${1:-}" == "cycle" ]]; then
        shift
        cmd_dep_cycle "$@"
        return
    fi
    if [[ "${1:-}" == "rm" || "${1:-}" == "remove" ]]; then
        shift
        cmd_undep "$@"
        return
    fi
    if [[ "${1:-}" == "add" ]]; then
        shift
    fi

    if [[ $# -lt 2 ]]; then
        echo "Usage: ticket dep <id> <dependency-id>" >&2
        echo "       ticket dep add <id> <dependency-id>  - add dependency (default)" >&2
        echo "       ticket dep rm <id> <dependency-id>   - remove dependency" >&2
        echo "       ticket dep tree <id>  - show dependency tree" >&2
        echo "       ticket dep cycle      - find dependency cycles" >&2
        return 1
    fi

    local id="$1"
    local dep_id="$2"
    local file
    file=$(ticket_path "$id") || return 1

    # Verify dependency exists and resolve to full ID
    local dep_file
    dep_file=$(ticket_path "$dep_id") || return 1
    dep_id=$(basename "$dep_file" .md)

    # Get current deps
    local current_deps
    current_deps=$(yaml_field "$file" "deps")

    # Add dep if not already present
    if echo "$current_deps" | _grep -q "$dep_id"; then
        echo "Dependency already exists"
        return 0
    fi

    # Update deps array
    if [[ "$current_deps" == "[]" ]]; then
        update_yaml_field "$file" "deps" "[$dep_id]"
    else
        local new_deps
        new_deps=$(echo "$current_deps" | sed "s/\]/, $dep_id]/")
        update_yaml_field "$file" "deps" "$new_deps"
    fi

    ( _sync_ticket_file "$file" || true )
    echo "Added dependency: $(basename "$file" .md) -> $dep_id"
}

cmd_ready() {
    local assignee_filter="" tag_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -a) assignee_filter="$2"; shift 2 ;;
            --assignee=*) assignee_filter="${1#--assignee=}"; shift ;;
            -T) tag_filter="$2"; shift 2 ;;
            --tag=*) tag_filter="${1#--tag=}"; shift ;;
            *) shift ;;
        esac
    done

    awk -v assignee_filter="$assignee_filter" -v tag_filter="$tag_filter" '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; deps=""; priority=""; assignee=""; tags=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { status = $2 }
    in_front && /^priority:/ { priority = $2 }
    in_front && /^assignee:/ { assignee = $2 }
    in_front && /^tags:/ { tags = $2; gsub(/[\[\] ]/, "", tags) }
    in_front && /^deps:/ {
        deps = $2
        gsub(/[\[\] ]/, "", deps)
    }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function has_tag(tags_str, tag,    i, n, arr) {
        n = split(tags_str, arr, ",")
        for (i = 1; i <= n; i++) if (arr[i] == tag) return 1
        return 0
    }
    function store() {
        if (id != "") {
            statuses[id] = status
            titles[id] = title
            deps_raw[id] = deps
            priorities[id] = (priority != "") ? priority : 2
            assignees[id] = assignee
            all_tags[id] = tags
        }
    }
    END {
        if (prev_file) store()
        # Find ready tickets: active with all deps closed
        for (id in statuses) {
            status = statuses[id]
            if (status != "open" && status != "in_progress") continue
            if (assignee_filter != "" && assignees[id] != assignee_filter) continue
            if (tag_filter != "" && !has_tag(all_tags[id], tag_filter)) continue

            deps = deps_raw[id]
            ready = 1
            if (deps != "") {
                n = split(deps, arr, ",")
                for (i = 1; i <= n; i++) {
                    dep = arr[i]
                    if (dep != "" && statuses[dep] != "closed") {
                        ready = 0
                        break
                    }
                }
            }
            if (ready) {
                output[++count] = sprintf("%s|%s|%s|%s", priorities[id], id, status, titles[id])
            }
        }

        # Sort by priority, then by id
        for (i = 1; i <= count; i++) {
            for (j = i + 1; j <= count; j++) {
                split(output[i], a, "|")
                split(output[j], b, "|")
                if (a[1] > b[1] || (a[1] == b[1] && a[2] > b[2])) {
                    tmp = output[i]; output[i] = output[j]; output[j] = tmp
                }
            }
        }

        for (i = 1; i <= count; i++) {
            split(output[i], f, "|")
            printf "%-8s [P%s][%s] - %s\n", f[2], f[1], f[3], f[4]
        }
    }
    ' "$TICKETS_DIR"/*.md 2>/dev/null
}

cmd_closed() {
    local limit=20 assignee_filter="" tag_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --limit=*) limit="${1#--limit=}"; shift ;;
            -a) assignee_filter="$2"; shift 2 ;;
            --assignee=*) assignee_filter="${1#--assignee=}"; shift ;;
            -T) tag_filter="$2"; shift 2 ;;
            --tag=*) tag_filter="${1#--tag=}"; shift ;;
            *) shift ;;
        esac
    done

    # List files by mtime (most recent first), filter closed, limit output
    local files
    files=$(ls -t "$TICKETS_DIR"/*.md 2>/dev/null | head -n 100)
    [[ -z "$files" ]] && return 0
    echo "$files" | xargs awk -v assignee_filter="$assignee_filter" -v tag_filter="$tag_filter" '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) emit()
        id=""; status=""; title=""; assignee=""; tags=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { status = $2 }
    in_front && /^assignee:/ { assignee = $2 }
    in_front && /^tags:/ { tags = $2; gsub(/[\[\] ]/, "", tags) }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function has_tag(tags_str, tag,    i, n, arr) {
        n = split(tags_str, arr, ",")
        for (i = 1; i <= n; i++) if (arr[i] == tag) return 1
        return 0
    }
    function emit() {
        if (id != "" && (status == "closed" || status == "done") && (assignee_filter == "" || assignee == assignee_filter) && (tag_filter == "" || has_tag(tags, tag_filter))) {
            output[++count] = sprintf("%-8s [%s] - %s", id, status, title)
        }
    }
    END {
        if (prev_file) emit()
        for (i = 1; i <= count; i++) print output[i]
    }
    ' | head -n "$limit"
}

cmd_blocked() {
    local assignee_filter="" tag_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -a) assignee_filter="$2"; shift 2 ;;
            --assignee=*) assignee_filter="${1#--assignee=}"; shift ;;
            -T) tag_filter="$2"; shift 2 ;;
            --tag=*) tag_filter="${1#--tag=}"; shift ;;
            *) shift ;;
        esac
    done

    awk -v assignee_filter="$assignee_filter" -v tag_filter="$tag_filter" '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; deps=""; priority=""; assignee=""; tags=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { status = $2 }
    in_front && /^priority:/ { priority = $2 }
    in_front && /^assignee:/ { assignee = $2 }
    in_front && /^tags:/ { tags = $2; gsub(/[\[\] ]/, "", tags) }
    in_front && /^deps:/ {
        deps = $2
        gsub(/[\[\] ]/, "", deps)
    }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function has_tag(tags_str, tag,    i, n, arr) {
        n = split(tags_str, arr, ",")
        for (i = 1; i <= n; i++) if (arr[i] == tag) return 1
        return 0
    }
    function store() {
        if (id != "") {
            statuses[id] = status
            titles[id] = title
            deps_raw[id] = deps
            priorities[id] = (priority != "") ? priority : 2
            assignees[id] = assignee
            all_tags[id] = tags
        }
    }
    END {
        if (prev_file) store()
        # Find blocked tickets: active with at least one dep not closed
        for (id in statuses) {
            status = statuses[id]
            if (status != "open" && status != "in_progress") continue
            if (assignee_filter != "" && assignees[id] != assignee_filter) continue
            if (tag_filter != "" && !has_tag(all_tags[id], tag_filter)) continue

            deps = deps_raw[id]
            if (deps == "") continue

            blocked = 0
            n = split(deps, arr, ",")
            for (i = 1; i <= n; i++) {
                dep = arr[i]
                if (dep != "" && statuses[dep] != "closed") {
                    blocked = 1
                    break
                }
            }
            if (blocked) {
                # Build list of only open blockers
                blockers = ""
                n = split(deps, arr, ",")
                for (i = 1; i <= n; i++) {
                    dep = arr[i]
                    if (dep != "" && statuses[dep] != "closed") {
                        blockers = (blockers == "") ? dep : blockers ", " dep
                    }
                }
                output[++count] = sprintf("%s|%s|%s|%s|[%s]", priorities[id], id, status, titles[id], blockers)
            }
        }

        # Sort by priority, then by id
        for (i = 1; i <= count; i++) {
            for (j = i + 1; j <= count; j++) {
                split(output[i], a, "|")
                split(output[j], b, "|")
                if (a[1] > b[1] || (a[1] == b[1] && a[2] > b[2])) {
                    tmp = output[i]; output[i] = output[j]; output[j] = tmp
                }
            }
        }

        for (i = 1; i <= count; i++) {
            split(output[i], f, "|")
            printf "%-8s [P%s][%s] - %s <- %s\n", f[2], f[1], f[3], f[4], f[5]
        }
    }
    ' "$TICKETS_DIR"/*.md 2>/dev/null
}

cmd_list() {
    local type_filter="" status_filter="" priority_filter="" assignee_filter="" show_all=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) type_filter="$2"; shift 2 ;;
            --type=*) type_filter="${1#--type=}"; shift ;;
            --status) status_filter="$2"; shift 2 ;;
            --status=*) status_filter="${1#--status=}"; shift ;;
            --priority) priority_filter="$2"; shift 2 ;;
            --priority=*) priority_filter="${1#--priority=}"; shift ;;
            -a) assignee_filter="$2"; shift 2 ;;
            --assignee=*) assignee_filter="${1#--assignee=}"; shift ;;
            --all) show_all=1; shift ;;
            *) shift ;;
        esac
    done

    awk -v type_filter="$type_filter" -v status_filter="$status_filter" \
        -v priority_filter="$priority_filter" -v assignee_filter="$assignee_filter" \
        -v show_all="$show_all" '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; st=""; title=""; priority=""; assignee=""; typ=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { st = $2 }
    in_front && /^priority:/ { priority = $2 }
    in_front && /^assignee:/ { assignee = $2 }
    in_front && /^type:/ { typ = $2 }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function store() {
        if (id == "") return
        # Apply filters
        if (status_filter != "") {
            if (st != status_filter) return
        } else if (show_all == 0) {
            if (st == "closed" || st == "done") return
        }
        if (type_filter != "" && typ != type_filter) return
        if (priority_filter != "" && priority != priority_filter) return
        if (assignee_filter != "" && assignee != assignee_filter) return

        p = (priority != "") ? priority : 2
        output[++count] = sprintf("%s|%s|%s|%s|%s", p, id, st, typ, title)
    }
    END {
        if (prev_file) store()

        # Sort by priority, then by id
        for (i = 1; i <= count; i++) {
            for (j = i + 1; j <= count; j++) {
                split(output[i], a, "|")
                split(output[j], b, "|")
                if (a[1] > b[1] || (a[1] == b[1] && a[2] > b[2])) {
                    tmp = output[i]; output[i] = output[j]; output[j] = tmp
                }
            }
        }

        for (i = 1; i <= count; i++) {
            split(output[i], f, "|")
            printf "%-8s [P%s][%s][%s] - %s\n", f[2], f[1], f[3], f[4], f[5]
        }
    }
    ' "$TICKETS_DIR"/*.md 2>/dev/null
}

cmd_children() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: ticket children <id>" >&2
        return 1
    fi

    local file
    file=$(ticket_path "$1") || return 1
    local target_id
    target_id=$(basename "$file" .md)

    awk -v target="$target_id" '
    BEGIN { FS=": "; in_front=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; st=""; title=""; priority=""; typ=""; par=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { st = $2 }
    in_front && /^priority:/ { priority = $2 }
    in_front && /^type:/ { typ = $2 }
    in_front && /^parent:/ { par = $2 }
    !in_front && /^# / && title == "" { title = substr($0, 3) }
    function store() {
        if (id == "" || par != target) return
        p = (priority != "") ? priority : 2
        output[++count] = sprintf("%s|%s|%s|%s|%s", p, id, st, typ, title)
    }
    END {
        if (prev_file) store()

        for (i = 1; i <= count; i++) {
            for (j = i + 1; j <= count; j++) {
                split(output[i], a, "|")
                split(output[j], b, "|")
                if (a[1] > b[1] || (a[1] == b[1] && a[2] > b[2])) {
                    tmp = output[i]; output[i] = output[j]; output[j] = tmp
                }
            }
        }

        for (i = 1; i <= count; i++) {
            split(output[i], f, "|")
            printf "%-8s [P%s][%s][%s] - %s\n", f[2], f[1], f[3], f[4], f[5]
        }
    }
    ' "$TICKETS_DIR"/*.md 2>/dev/null
}

cmd_assign() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: $(basename "$0") assign <id> <name>" >&2
        return 1
    fi
    local file
    file=$(ticket_path "$1") || return 1
    update_yaml_field "$file" "assignee" "$2"
    ( _sync_ticket_file "$file" || true )
    echo "Assigned $(basename "$file" .md) -> $2"
}

cmd_priority() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: $(basename "$0") priority <id> <0-4>" >&2
        return 1
    fi
    local file
    file=$(ticket_path "$1") || return 1
    local p="$2"
    if ! [[ "$p" =~ ^[0-4]$ ]]; then
        echo "Invalid priority: $p (must be 0-4)" >&2
        return 1
    fi
    update_yaml_field "$file" "priority" "$p"
    ( _sync_ticket_file "$file" || true )
    echo "Priority $(basename "$file" .md) -> P$p"
}

cmd_set_parent() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: $(basename "$0") parent <id> <parent-id>" >&2
        return 1
    fi
    local file
    file=$(ticket_path "$1") || return 1
    local parent_file
    parent_file=$(ticket_path "$2") || return 1
    local parent_id
    parent_id=$(basename "$parent_file" .md)
    update_yaml_field "$file" "parent" "$parent_id"
    ( _sync_ticket_file "$file" || true )
    echo "Parent $(basename "$file" .md) -> $parent_id"
}

cmd_tag() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: $(basename "$0") tag <id> <tag>" >&2
        return 1
    fi
    local file
    file=$(ticket_path "$1") || return 1
    local new_tag="$2"

    local current_tags
    current_tags=$(yaml_field "$file" "tags" || true)
    [[ -z "$current_tags" ]] && current_tags="[]"

    # Skip if already present (split array into individual tags for exact match)
    if echo "$current_tags" | sed 's/[][]//g; s/, */\n/g' | _grep -qxF "$new_tag"; then
        echo "Tag already present: $new_tag"
        return 0
    fi

    if [[ "$current_tags" == "[]" ]]; then
        update_yaml_field "$file" "tags" "[$new_tag]"
    else
        local new_tags
        new_tags=$(echo "$current_tags" | sed "s/\]/, $new_tag]/")
        update_yaml_field "$file" "tags" "$new_tags"
    fi
    ( _sync_ticket_file "$file" || true )
    echo "Tagged $(basename "$file" .md) with $new_tag"
}

cmd_delete() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") delete <id>" >&2
        return 1
    fi
    local file
    file=$(ticket_path "$1") || return 1
    local id
    id=$(basename "$file" .md)
    rm "$file"
    # Use _sync_ticket_delete (not _sync_ticket_file) because the file no longer exists on disk
    ( _sync_ticket_delete "$file" || true )
    echo "Deleted $id"
}

cmd_count() {
    local type_filter="" status_filter="" show_all=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) type_filter="$2"; shift 2 ;;
            --type=*) type_filter="${1#--type=}"; shift ;;
            --status) status_filter="$2"; shift 2 ;;
            --status=*) status_filter="${1#--status=}"; shift ;;
            --all) show_all=1; shift ;;
            *) shift ;;
        esac
    done

    awk -v type_filter="$type_filter" -v status_filter="$status_filter" \
        -v show_all="$show_all" '
    BEGIN { FS=": "; in_front=0; count=0 }
    FNR==1 {
        if (prev_file) store()
        id=""; st=""; typ=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { st = $2 }
    in_front && /^type:/ { typ = $2 }
    function store() {
        if (id == "") return
        if (status_filter != "") {
            if (st != status_filter) return
        } else if (show_all == 0) {
            if (st == "closed" || st == "done") return
        }
        if (type_filter != "" && typ != type_filter) return
        count++
    }
    END {
        if (prev_file) store()
        print count
    }
    ' "$TICKETS_DIR"/*.md 2>/dev/null
}

cmd_search() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $(basename "$0") search <pattern>" >&2
        return 1
    fi
    local pattern="$1"

    _grep -liF "$pattern" "$TICKETS_DIR"/*.md 2>/dev/null | while IFS= read -r file; do
        local id status title
        id=$(yaml_field "$file" "id")
        status=$(yaml_field "$file" "status")
        title=$(sed -n '/^# /{s/^# //p;q;}' "$file")
        printf "%-8s [%s] - %s\n" "$id" "$status" "$title"
    done
}

cmd_undep() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: ticket undep <id> <dependency-id>" >&2
        return 1
    fi

    local id="$1"
    local dep_id="$2"
    local file
    file=$(ticket_path "$id") || return 1

    # Resolve dep_id to full ID
    local dep_file
    dep_file=$(ticket_path "$dep_id") || return 1
    dep_id=$(basename "$dep_file" .md)

    local current_deps
    current_deps=$(yaml_field "$file" "deps")

    if ! echo "$current_deps" | _grep -q "$dep_id"; then
        echo "Dependency not found"
        return 1
    fi

    # Remove dep from array
    local new_deps
    new_deps=$(echo "$current_deps" | sed "s/, *$dep_id//g; s/$dep_id, *//g; s/$dep_id//g")
    # Clean up empty array case
    [[ "$new_deps" == "[]" || "$new_deps" == "[, ]" || "$new_deps" == "[ ]" ]] && new_deps="[]"

    update_yaml_field "$file" "deps" "$new_deps"
    ( _sync_ticket_file "$file" || true )
    echo "Removed dependency: $(basename "$file" .md) -/-> $dep_id"
}

add_link_to_file() {
    local file="$1"
    local target_id="$2"

    local current_links
    current_links=$(yaml_field "$file" "links" || true)
    [[ -z "$current_links" ]] && current_links="[]"

    # Skip if already present
    if echo "$current_links" | _grep -q "$target_id"; then
        return 0
    fi

    if [[ "$current_links" == "[]" ]]; then
        update_yaml_field "$file" "links" "[$target_id]"
    else
        local new_links
        new_links=$(echo "$current_links" | sed "s/\]/, $target_id]/")
        update_yaml_field "$file" "links" "$new_links"
    fi
}

cmd_link() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: ticket link <id> <id> [id...]" >&2
        return 1
    fi

    # Resolve all ticket paths first
    local -a ids=() files=()
    for arg in "$@"; do
        local file
        file=$(ticket_path "$arg") || return 1
        ids+=("$(basename "$file" .md)")
        files+=("$file")
    done

    # Use awk to update all files in one pass per file
    local id_list
    id_list=$(printf '%s\n' "${ids[@]}")

    local count=0
    for ((i=0; i<${#ids[@]}; i++)); do
        local file="${files[$i]}"
        local self="${ids[$i]}"

        # Build list of other IDs to link
        local others=""
        for ((j=0; j<${#ids[@]}; j++)); do
            [[ $i -ne $j ]] && others="$others ${ids[$j]}"
        done

        # Update file with awk - add missing links
        local result
        result=$(awk -v self="$self" -v others="$others" '
        BEGIN {
            n = split(others, other_arr, " ")
            for (i = 1; i <= n; i++) need[other_arr[i]] = 1
        }
        /^links:/ {
            # Parse existing links
            gsub(/[\[\]]/, "", $0)
            sub(/^links: */, "", $0)
            m = split($0, existing, ", *")
            for (i = 1; i <= m; i++) {
                if (existing[i] != "") {
                    have[existing[i]] = 1
                    delete need[existing[i]]
                }
            }

            # Build new links array
            out = ""
            for (i = 1; i <= m; i++) {
                if (existing[i] != "") {
                    out = (out == "") ? existing[i] : out ", " existing[i]
                }
            }
            for (id in need) {
                out = (out == "") ? id : out ", " id
                added++
            }
            print "links: [" out "]"
            found = 1
            next
        }
        { print }
        END { printf "%d", added > "/dev/stderr" }
        ' "$file" 2>&1 >"${file}.tmp")

        mv "${file}.tmp" "$file"
        ((count += result)) || true
    done

    if [[ $count -eq 0 ]]; then
        echo "All links already exist"
    else
        echo "Added $count link(s) between ${#ids[@]} tickets"
        # Sync all modified ticket files
        for ((i=0; i<${#files[@]}; i++)); do
            ( _sync_ticket_file "${files[$i]}" || true )
        done
    fi
}

remove_link_from_file() {
    local file="$1"
    local target_id="$2"

    local current_links
    current_links=$(yaml_field "$file" "links" || true)

    # Skip if not present
    if [[ -z "$current_links" ]] || ! echo "$current_links" | _grep -q "$target_id"; then
        return 0
    fi

    local new_links
    new_links=$(echo "$current_links" | sed "s/, *$target_id//g; s/$target_id, *//g; s/$target_id//g")
    [[ "$new_links" == "[]" || "$new_links" == "[, ]" || "$new_links" == "[ ]" ]] && new_links="[]"

    update_yaml_field "$file" "links" "$new_links"
}

cmd_unlink() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: ticket unlink <id> <target-id>" >&2
        return 1
    fi

    # Resolve both IDs to full IDs
    local file target_file
    file=$(ticket_path "$1") || return 1
    target_file=$(ticket_path "$2") || return 1
    local id target_id
    id=$(basename "$file" .md)
    target_id=$(basename "$target_file" .md)

    local current_links
    current_links=$(yaml_field "$file" "links" || true)

    if [[ -z "$current_links" ]] || ! echo "$current_links" | _grep -q "$target_id"; then
        echo "Link not found"
        return 1
    fi

    # Remove from both files
    remove_link_from_file "$file" "$target_id"
    remove_link_from_file "$target_file" "$id"
    ( _sync_ticket_file "$file" || true )
    ( _sync_ticket_file "$target_file" || true )

    echo "Removed link: $(basename "$file" .md) <-> $target_id"
}

cmd_show() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: ticket show <id>" >&2
        return 1
    fi

    local file
    file=$(ticket_path "$1") || return 1
    local target_id
    target_id=$(basename "$file" .md)

    _show_output() {
        awk -v target="$target_id" -v target_file="$file" '
    BEGIN { FS=": "; in_front=0 }

    # First pass: collect all ticket metadata
    FNR==1 {
        if (prev_file) store()
        id=""; status=""; title=""; deps=""; links=""; parent=""; in_front=0
        prev_file=FILENAME
    }
    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/ { id = $2 }
    in_front && /^status:/ { status = $2 }
    in_front && /^deps:/ { deps = $2; gsub(/[\[\] ]/, "", deps) }
    in_front && /^links:/ { links = $2; gsub(/[\[\] ]/, "", links) }
    in_front && /^parent:/ { parent = $2 }
    !in_front && /^# / && title == "" { title = substr($0, 3) }

    function store() {
        if (id != "") {
            statuses[id] = status
            titles[id] = title
            all_deps[id] = deps
            all_links[id] = links
            parents[id] = parent
        }
    }

    END {
        if (prev_file) store()

        # Build inverse relationships
        for (id in statuses) {
            # Children: tickets where parent == target
            if (parents[id] == target) {
                children_count++
                children[children_count] = id
            }
            # Blocking: tickets where target is in their deps
            deps = all_deps[id]
            if (deps != "") {
                n = split(deps, arr, ",")
                for (i = 1; i <= n; i++) {
                    if (arr[i] == target && statuses[id] != "closed") {
                        blocking_count++
                        blocking[blocking_count] = id
                    }
                }
            }
        }

        # Now output the target file with enhancements
        in_front = 0
        while ((getline line < target_file) > 0) {
            if (line == "---") {
                in_front = !in_front
                print line
            } else if (in_front && line ~ /^parent:/) {
                # Add parent title as comment
                p = line
                sub(/^parent: */, "", p)
                if (p in titles) {
                    print line "  # " titles[p]
                } else {
                    print line
                }
            } else {
                print line
            }
        }
        close(target_file)

        # Collect blockers (unclosed deps)
        deps = all_deps[target]
        if (deps != "") {
            n = split(deps, arr, ",")
            blocker_count = 0
            for (i = 1; i <= n; i++) {
                d = arr[i]
                if (d != "" && statuses[d] != "closed") {
                    blocker_count++
                    blockers[blocker_count] = d
                }
            }
            if (blocker_count > 0) {
                print ""
                print "## Blockers"
                print ""
                for (i = 1; i <= blocker_count; i++) {
                    d = blockers[i]
                    printf "- %s [%s] %s\n", d, statuses[d], titles[d]
                }
            }
        }

        # Show tickets this is blocking
        if (blocking_count > 0) {
            print ""
            print "## Blocking"
            print ""
            for (i = 1; i <= blocking_count; i++) {
                b = blocking[i]
                printf "- %s [%s] %s\n", b, statuses[b], titles[b]
            }
        }

        # Show children
        if (children_count > 0) {
            print ""
            print "## Children"
            print ""
            for (i = 1; i <= children_count; i++) {
                c = children[i]
                printf "- %s [%s] %s\n", c, statuses[c], titles[c]
            }
        }

        # Collect linked tickets
        links = all_links[target]
        if (links != "") {
            n = split(links, arr, ",")
            print ""
            print "## Linked"
            print ""
            for (i = 1; i <= n; i++) {
                l = arr[i]
                if (l != "") {
                    printf "- %s [%s] %s\n", l, statuses[l], titles[l]
                }
            }
        }
    }
    ' "$TICKETS_DIR"/*.md 2>/dev/null
    }

    if [[ -t 1 && -n "$TICKET_PAGER" ]]; then
        read -r -a pager_cmd <<<"$TICKET_PAGER"
        _show_output | "${pager_cmd[@]}"
    else
        _show_output
    fi
}

cmd_add_note() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: ticket add-note <id> [--origin agent|jira] [note text]" >&2
        return 1
    fi

    local file
    file=$(ticket_path "$1") || return 1
    shift

    # Parse optional --origin flag
    local origin="agent"
    if [[ $# -ge 2 ]] && [[ "$1" == "--origin" ]]; then
        origin="$2"
        shift 2
    fi

    local note
    if [[ $# -gt 0 ]]; then
        note="$*"
    elif [[ ! -t 0 ]]; then
        note=$(cat)
    else
        echo "Error: no note provided" >&2
        return 1
    fi

    local timestamp
    timestamp=$(_iso_date)

    # Generate unique note ID (8-char random alphanumeric)
    local note_id
    note_id=$(head -c 32 /dev/urandom | LC_ALL=C tr -dc 'a-z0-9' | head -c 8)
    # Pad if randomness was insufficient (unlikely but safe)
    while [[ ${#note_id} -lt 8 ]]; do
        note_id="${note_id}$(head -c 32 /dev/urandom | LC_ALL=C tr -dc 'a-z0-9' | head -c 1)"
    done

    # Add Notes section if missing, then append structured note block
    if ! grep -q '^## Notes' "$file"; then
        printf '\n## Notes\n' >> "$file"
    fi
    printf '\n<!-- note-id: %s -->\n' "$note_id" >> "$file"
    printf '<!-- timestamp: %s -->\n' "$timestamp" >> "$file"
    printf '<!-- origin: %s -->\n' "$origin" >> "$file"
    printf '<!-- sync: unsynced -->\n\n' >> "$file"
    printf '%s\n' "$note" >> "$file"

    ( _sync_ticket_file "$file" || true )
    echo "Note added to $(basename "$file" .md)"
}

# ---------------------------------------------------------------------------
# _enumerate_notes
#
# Parses all notes (structured and legacy) from a ticket file.
# Outputs one block per note in a canonical format:
#   note-id: <id>
#   timestamp: <ts>
#   origin: <origin>
#   sync: <state>
#   text: <note text>
#   ---
#
# Legacy freeform notes (bold timestamp, no metadata comments) are assigned
# a synthetic note-id of "legacy-<N>" and origin "unknown", sync "legacy".
#
# Args:
#   $1  ticket file path
# ---------------------------------------------------------------------------
_enumerate_notes() {
    local file="$1"
    [[ -f "$file" ]] || { echo "Error: file not found: $file" >&2; return 1; }

    # Check if file has a Notes section at all
    grep -q '^## Notes' "$file" || return 0

    # Extract everything after ## Notes
    local notes_section
    notes_section=$(awk '/^## Notes/{found=1; next} found{print}' "$file")

    [[ -z "$notes_section" ]] && return 0

    local in_structured=0 note_id="" timestamp="" origin="" sync_state="" text="" legacy_counter=0

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Structured note start: <!-- note-id: xxx -->
        if [[ "$line" =~ ^\<\!--\ note-id:\ ([a-z0-9-]+)\ --\> ]]; then
            # Flush any pending note
            if [[ -n "$note_id" ]]; then
                _emit_note "$note_id" "$timestamp" "$origin" "$sync_state" "$text"
                text=""
            fi
            in_structured=1
            note_id="${BASH_REMATCH[1]}"
            timestamp="" origin="" sync_state=""
            continue
        fi

        if [[ $in_structured -eq 1 ]]; then
            if [[ "$line" =~ ^\<\!--\ timestamp:\ (.+)\ --\> ]]; then
                timestamp="${BASH_REMATCH[1]}"
                continue
            elif [[ "$line" =~ ^\<\!--\ origin:\ (.+)\ --\> ]]; then
                origin="${BASH_REMATCH[1]}"
                continue
            elif [[ "$line" =~ ^\<\!--\ sync:\ (.+)\ --\> ]]; then
                sync_state="${BASH_REMATCH[1]}"
                continue
            fi
        fi

        # Legacy note start: **2026-03-05T10:00:00Z**
        if [[ "$line" =~ ^\*\*([0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.TZ]+)\*\* ]] && [[ $in_structured -eq 0 ]]; then
            # Flush any pending legacy note
            if [[ -n "$note_id" ]]; then
                _emit_note "$note_id" "$timestamp" "$origin" "$sync_state" "$text"
                text=""
            fi
            ((legacy_counter++))
            note_id="legacy-${legacy_counter}"
            timestamp="${BASH_REMATCH[1]}"
            origin="unknown"
            sync_state="legacy"
            continue
        fi

        # Accumulate text (skip leading/trailing blanks per note)
        if [[ -n "$note_id" ]]; then
            if [[ -n "$text" ]] || [[ -n "${line// /}" ]]; then
                text="${text:+${text}
}${line}"
            fi
        fi
    done <<< "$notes_section"

    # Flush last note
    if [[ -n "$note_id" ]]; then
        _emit_note "$note_id" "$timestamp" "$origin" "$sync_state" "$text"
    fi
}

# Helper: emit a single note block in canonical format
_emit_note() {
    local note_id="$1" timestamp="$2" origin="$3" sync_state="$4" text="$5"
    # Trim trailing blank lines from text (portable, no GNU sed)
    while [[ "$text" == *$'\n' ]]; do
        text="${text%$'\n'}"
    done
    printf 'note-id: %s\n' "$note_id"
    printf 'timestamp: %s\n' "$timestamp"
    printf 'origin: %s\n' "$origin"
    printf 'sync: %s\n' "$sync_state"
    printf 'text: %s\n' "$text"
    printf '%s\n' "---"
}

# Command wrapper for _enumerate_notes
cmd_enumerate_notes() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: ticket enumerate-notes <id>" >&2
        return 1
    fi
    local file
    file=$(ticket_path "$1") || return 1
    _enumerate_notes "$file"
}

# ---------------------------------------------------------------------------
# _sync_push_comments
#
# Pushes unsynced agent-origin notes from a ticket file to Jira as comments.
# Anti-echo: notes with origin=jira are always skipped (never echoed back).
# On per-note failure, logs a warning to stderr and continues (non-fatal).
# On success, updates the note's sync marker from unsynced to synced in-place.
#
# Args:
#   $1  ticket_file  (path to the ticket .md file)
#   $2  jira_key     (Jira issue key, e.g., LLD2L-42)
#
# Returns 0 always (non-fatal). Prints the count of successfully pushed
# comments to stdout for observability.
# ---------------------------------------------------------------------------
_sync_push_comments() {
    local ticket_file="$1" jira_key="$2"
    local pushed_count=0

    [[ -f "$ticket_file" ]] || { echo "0"; return 0; }

    # Enumerate all notes from the ticket
    local notes_output
    notes_output=$(_enumerate_notes "$ticket_file") || { echo "0"; return 0; }
    [[ -z "$notes_output" ]] && { echo "0"; return 0; }

    # Parse notes block by block (delimited by ---)
    local note_id="" origin="" sync_state="" text=""
    local in_text=0

    while IFS= read -r line; do
        if [[ "$line" == "---" ]]; then
            # Process the accumulated note
            if [[ -n "$note_id" ]]; then
                _sync_push_single_comment \
                    "$ticket_file" "$jira_key" \
                    "$note_id" "$origin" "$sync_state" "$text" \
                    && ((pushed_count++)) || true
            fi
            # Reset for next note
            note_id="" origin="" sync_state="" text="" in_text=0
            continue
        fi
        case "$line" in
            note-id:\ *)   note_id="${line#note-id: }" ;;
            origin:\ *)    origin="${line#origin: }" ;;
            sync:\ *)      sync_state="${line#sync: }" ;;
            text:\ *)      text="${line#text: }"; in_text=1 ;;
            *)
                if [[ $in_text -eq 1 ]]; then
                    text="${text}
${line}"
                fi
                ;;
        esac
    done <<< "$notes_output"

    # Flush last note if no trailing ---
    if [[ -n "$note_id" ]]; then
        _sync_push_single_comment \
            "$ticket_file" "$jira_key" \
            "$note_id" "$origin" "$sync_state" "$text" \
            && ((pushed_count++)) || true
    fi

    echo "$pushed_count"
    return 0
}

# ---------------------------------------------------------------------------
# _sync_push_single_comment
#
# Pushes a single note as a Jira comment if it qualifies (agent origin,
# unsynced). On success, updates the note's sync marker in the ticket file.
#
# Args:
#   $1  ticket_file
#   $2  jira_key
#   $3  note_id
#   $4  origin
#   $5  sync_state
#   $6  text
#
# Returns 0 on success (pushed + marked synced), 1 on skip or failure.
# ---------------------------------------------------------------------------
_sync_push_single_comment() {
    local ticket_file="$1" jira_key="$2"
    local note_id="$3" origin="$4" sync_state="$5" text="$6"

    # Skip: not agent origin (anti-echo for jira-origin, skip unknown/legacy)
    [[ "$origin" == "agent" ]] || return 1

    # Skip: already synced or legacy
    [[ "$sync_state" == "unsynced" ]] || return 1

    # Build comment body with attribution
    local comment_body
    comment_body="[Posted by tk sync from agent session]
${text}"

    # Push to Jira via acli
    local acli_exit=0
    acli jira workitem comment create \
        --key "$jira_key" \
        --body "$comment_body" \
        2>/dev/null || acli_exit=$?

    if [[ "$acli_exit" -ne 0 ]]; then
        echo "Warning: failed to push note $note_id to $jira_key (acli exit $acli_exit)" >&2
        return 1
    fi

    # Mark as synced — target specific note by note-id
    # Use awk to find the note-id line, then update only the next sync line
    local tmp_file="${ticket_file}.tmp.$$"
    awk -v target="$note_id" '
        /^<!-- note-id: / {
            if ($0 ~ "note-id: " target " -->") {
                found = 1
            }
        }
        found && /^<!-- sync: unsynced -->/ {
            sub(/sync: unsynced/, "sync: synced")
            found = 0
        }
        { print }
    ' "$ticket_file" > "$tmp_file" && mv "$tmp_file" "$ticket_file"

    return 0
}

# List installed plugins with descriptions
# Scripts: # tk-plugin: description (comment in first 10 lines)
# Binaries: --tk-describe flag outputs description
_list_plugins() {
    local seen="" plugin cmd desc path out

    for prefix in tk ticket; do
        while IFS= read -r plugin; do
            [[ -z "$plugin" ]] && continue
            cmd="${plugin#${prefix}-}"

            # Skip if already seen (tk- takes precedence over ticket-)
            case " $seen " in *" $cmd "*) continue ;; esac
            seen="$seen $cmd"

            path=$(command -v "$plugin" 2>/dev/null) || continue
            [[ -f "$path" ]] || continue

            desc=""
            # Try comment first (fast, no execution)
            desc=$(head -10 "$path" 2>/dev/null | grep -m1 '^# tk-plugin:' | sed 's/^# tk-plugin: *//')

            # Fall back to --tk-describe for binaries (requires timeout command)
            if [[ -z "$desc" ]] && command -v timeout &>/dev/null; then
                if out=$(timeout 1 "$path" --tk-describe 2>/dev/null); then
                    out=$(printf '%s' "$out" | head -1)
                    [[ "$out" == "tk-plugin:"* ]] && desc="${out#tk-plugin: }"
                fi
            fi

            printf "  %-22s %s\n" "$cmd" "${desc:-(no description)}"
        done < <(compgen -c "${prefix}-" 2>/dev/null | sort -u)
    done
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_content_hash
#
# Computes an MD5 hash of a ticket's canonical fields for change detection.
# Portable: uses md5sum (Linux) or md5 -q (macOS).
#
# Args:
#   $1  title
#   $2  status
#   $3  type
#   $4  priority
#   $5  deps (sorted, comma-separated)
#   $6  links (sorted, comma-separated)
#   $7  body
#
# Outputs the hex MD5 digest to stdout.
# ---------------------------------------------------------------------------
_sync_content_hash() {
    local title="$1" status="$2" type="$3" priority="$4"
    local deps="$5" links="$6" body="$7"

    # Exclude ## Notes section from body before hashing
    # Notes sync separately as Jira comments; their content/state changes
    # must not alter the ticket's content hash.
    body=$(printf '%s' "$body" | awk '/^## Notes/{exit} {print}')

    # Sort deps and links for canonical ordering
    local sorted_deps sorted_links
    if [[ -n "$deps" ]]; then
        sorted_deps=$(printf '%s\n' "${deps//,/$'\n'}" | sort | paste -sd ',' -)
    else
        sorted_deps=""
    fi
    if [[ -n "$links" ]]; then
        sorted_links=$(printf '%s\n' "${links//,/$'\n'}" | sort | paste -sd ',' -)
    else
        sorted_links=""
    fi

    # Build canonical hash input string
    local input
    input="${title}
${status}
${type}
${priority}
${sorted_deps}
${sorted_links}
${body}"

    # Portable md5: md5sum on Linux, md5 -q on macOS
    if command -v md5sum &>/dev/null; then
        printf '%s' "$input" | md5sum | awk '{print $1}'
    elif command -v md5 &>/dev/null; then
        printf '%s' "$input" | md5 -q
    else
        echo "Error: no md5sum or md5 command found" >&2
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_ledger_read
#
# Reads a single field value from .sync-state.json for a given tk-id.
# Returns empty string if the file is missing, the key is absent, or the
# field is absent.
#
# Args:
#   $1  ledger_file  (path to .sync-state.json)
#   $2  tk_id        (ticket ID, e.g. "w21-abc1")
#   $3  field        (one of: jira_key, local_hash, jira_hash, last_synced)
#
# Outputs the field value to stdout (empty string if not found).
# ---------------------------------------------------------------------------
_sync_ledger_read() {
    local ledger_file="$1" tk_id="$2" field="$3"

    [[ -f "$ledger_file" ]] || { echo ""; return 0; }

    python3 -c "
import json, sys
try:
    with open('$ledger_file') as f:
        d = json.load(f)
    entry = d.get('$tk_id', {})
    print(entry.get('$field', ''))
except Exception:
    print('')
" 2>/dev/null || echo ""
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_ledger_write
#
# Upserts a single entry in .sync-state.json.  Creates the file if
# it does not exist.  Uses a temp-file-then-mv pattern for atomicity so that
# a crash mid-write never leaves a partial/corrupt ledger.
#
# Args:
#   $1  ledger_file  (path to .sync-state.json)
#   $2  tk_id        (ticket ID, e.g. "w21-abc1")
#   $3  jira_key     (Jira issue key, e.g. "TEST-42")
#   $4  local_hash   (hash of local ticket fields)
#   $5  jira_hash    (hash of Jira issue fields)
#   $6  last_synced  (ISO-8601 timestamp)
# ---------------------------------------------------------------------------
_sync_ledger_write() {
    local ledger_file="$1" tk_id="$2" jira_key="$3"
    local local_hash="$4" jira_hash="$5" last_synced="$6"

    local ledger_dir
    ledger_dir=$(dirname "$ledger_file")
    mkdir -p "$ledger_dir"

    # Write to a temp file in the same directory, then mv for atomicity
    local tmp_file
    tmp_file=$(mktemp "${ledger_file}.tmp.XXXXXX")

    python3 -c "
import json, sys, os

ledger_file = '$ledger_file'
tk_id       = '$tk_id'
jira_key    = '$jira_key'
local_hash  = '$local_hash'
jira_hash   = '$jira_hash'
last_synced = '$last_synced'
tmp_file    = '$tmp_file'

# Load existing ledger or start fresh
if os.path.isfile(ledger_file):
    with open(ledger_file) as f:
        data = json.load(f)
else:
    data = {}

# Upsert the entry
data[tk_id] = {
    'jira_key':    jira_key,
    'local_hash':  local_hash,
    'jira_hash':   jira_hash,
    'last_synced': last_synced,
}

# Write to temp file
with open(tmp_file, 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
" 2>&1

    # Atomic rename: replaces ledger_file in one syscall
    mv "$tmp_file" "$ledger_file"
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_state_read
#
# Reads a single top-level field from a JSON state file (e.g. .sync-state.json).
# Returns empty string if the file is missing, corrupt, or the field is absent.
#
# Args:
#   $1  state_file  (path to JSON file)
#   $2  field       (top-level key, e.g. "last_sync_commit")
#
# Outputs the field value to stdout (empty string if not found).
# ---------------------------------------------------------------------------
_sync_state_read() {
    local state_file="$1" field="$2"

    [[ -f "$state_file" ]] || { echo ""; return 0; }

    python3 -c "
import json
try:
    with open('$state_file') as f:
        d = json.load(f)
    print(d.get('$field', ''))
except Exception:
    print('')
" 2>/dev/null || echo ""
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_state_write
#
# Atomically updates a single top-level field in a JSON state file.
# Creates the file if it does not exist.  Preserves other fields.
# Uses a temp-file-then-mv pattern for atomicity so that a crash mid-write
# never leaves a partial/corrupt file.
#
# Args:
#   $1  state_file  (path to JSON file)
#   $2  field       (top-level key, e.g. "last_sync_commit")
#   $3  value       (value to set)
# ---------------------------------------------------------------------------
_sync_state_write() {
    local state_file="$1" field="$2" value="$3"

    local state_dir
    state_dir=$(dirname "$state_file")
    mkdir -p "$state_dir"

    # Write to a temp file in the same directory, then mv for atomicity
    local tmp_file
    tmp_file=$(mktemp "${state_file}.tmp.XXXXXX")

    python3 -c "
import json, os

state_file = '$state_file'
field      = '$field'
value      = '$value'
tmp_file   = '$tmp_file'

# Load existing state or start fresh
if os.path.isfile(state_file):
    try:
        with open(state_file) as f:
            data = json.load(f)
    except Exception:
        data = {}
else:
    data = {}

# Set the field
data[field] = value

# Write to temp file
with open(tmp_file, 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
" 2>&1

    # Check python3 exit code — if it failed, remove the tmp file and abort
    if [[ $? -ne 0 ]]; then
        rm -f "$tmp_file"
        return 1
    fi

    # Atomic rename: replaces state_file in one syscall
    mv "$tmp_file" "$state_file"
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_detect_conflict
#
# Detects a both-sides-changed conflict for a ticket.
#
# A conflict exists when both the local ticket AND the remote Jira issue have
# changed since the last sync.  Specifically:
#   - The ledger entry for tk_id exists (ticket has been synced at least once)
#   - current_local_hash  != ledger_local_hash  (local side changed)
#   - current_jira_hash   != ledger_jira_hash   (remote side changed)
#
# Returns 0 if a conflict is detected, 1 if no conflict.
# Returns 1 (no conflict) if no ledger entry exists (new ticket).
#
# Args:
#   $1  tk_id               (ticket ID, e.g. "w21-abc1")
#   $2  ledger_file         (path to .sync-state.json)
#   $3  current_local_hash  (hash of the current local ticket)
#   $4  current_jira_hash   (hash of the current Jira issue)
# ---------------------------------------------------------------------------
_sync_detect_conflict() {
    local tk_id="$1" ledger_file="$2"
    local current_local_hash="$3" current_jira_hash="$4"

    # No ledger file → new ticket, no conflict
    [[ -f "$ledger_file" ]] || return 1

    local ledger_local_hash ledger_jira_hash
    ledger_local_hash=$(_sync_ledger_read "$ledger_file" "$tk_id" "local_hash")
    ledger_jira_hash=$(_sync_ledger_read  "$ledger_file" "$tk_id" "jira_hash")

    # No ledger entry → new ticket, no conflict
    [[ -n "$ledger_local_hash" ]] || return 1

    # Conflict requires BOTH sides to have changed since last sync
    if [[ "$current_local_hash" != "$ledger_local_hash" ]] && \
       [[ "$current_jira_hash"  != "$ledger_jira_hash"  ]]; then
        return 0  # conflict detected
    fi

    return 1  # no mutual conflict
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_drift_check
#
# Performs drift detection by comparing local ticket state against live Jira
# state.  Iterates all .tickets/*.md files, fetches the corresponding Jira
# issue, and compares content hashes.
#
# Args:
#   $1  tickets_dir   (path to .tickets/ directory)
#   $2  ledger_file   (path to .sync-state.json — unused but accepted for API
#                      consistency with other _sync_* helpers)
#
# Environment:
#   JIRA_STATUS_MAP    Override status mapping (Jira->tk direction)
#   JIRA_PRIORITY_MAP  Override priority mapping (Jira->tk direction)
#   JIRA_TYPE_MAP      Override type mapping (Jira->tk direction)
#
# Output:
#   One line per drifted ticket:
#     DRIFT: <tk_id> (<jira_key>) -- local_hash=<hash> jira_hash=<hash>
#   Summary line: "Checked N tickets"
#   Warnings to stderr for skipped tickets.
#
# Returns 0 if no drift detected, 1 if any drift found.
# ---------------------------------------------------------------------------
_sync_drift_check() {
    local tickets_dir="$1" ledger_file="$2"
    local drift_count=0
    local checked_count=0
    local skipped_count=0

    for ticket_file in "$tickets_dir"/*.md; do
        [[ -f "$ticket_file" ]] || continue

        # ── Parse frontmatter fields ─────────────────────────────────────
        local tk_id title status type priority deps links body jira_key

        tk_id=$(awk '/^---$/{n++; next} n==1 && /^id:/{print; exit}' "$ticket_file" \
            | sed 's/^id:[[:space:]]*//')
        jira_key=$(awk '/^---$/{n++; next} n==1 && /^jira_key:/{print; exit}' "$ticket_file" \
            | sed 's/^jira_key:[[:space:]]*//' | tr -d "\"'")

        # Skip tickets without jira_key
        if [[ -z "$jira_key" ]]; then
            echo "warning: $tk_id has no jira_key — skipping drift check" >&2
            (( skipped_count++ )) || true
            continue
        fi

        title=$(awk '/^---$/{n++; next} n==2 && /^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        if [[ -z "$title" ]]; then
            title=$(awk '/^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        fi
        status=$(awk '/^---$/{n++; next} n==1 && /^status:/{print; exit}' "$ticket_file" \
            | sed 's/^status:[[:space:]]*//')
        type=$(awk '/^---$/{n++; next} n==1 && /^type:/{print; exit}' "$ticket_file" \
            | sed 's/^type:[[:space:]]*//')
        priority=$(awk '/^---$/{n++; next} n==1 && /^priority:/{print; exit}' "$ticket_file" \
            | sed 's/^priority:[[:space:]]*//')
        deps=$(awk '/^---$/{n++; next} n==1 && /^deps:/{print; exit}' "$ticket_file" \
            | sed 's/^deps:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
        links=$(awk '/^---$/{n++; next} n==1 && /^links:/{print; exit}' "$ticket_file" \
            | sed 's/^links:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
        body=$(awk 'found{print} /^# /{found=1}' "$ticket_file" | sed '/^$/d' | head -50)

        # ── Compute local content hash ───────────────────────────────────
        local local_hash
        # Exclude deps/links — Jira doesn't store them, so including them
        # causes false-positive drift (local hash would never match Jira hash).
        local_hash=$(_sync_content_hash "$title" "$status" "$type" "$priority" "" "" "$body")

        # ── Fetch Jira issue ─────────────────────────────────────────────
        local jira_view_output="" jira_view_exit=0
        jira_view_output=$(acli jira workitem view "$jira_key" --json 2>/dev/null) || jira_view_exit=$?

        if [[ $jira_view_exit -ne 0 || -z "$jira_view_output" ]]; then
            echo "warning: failed to fetch Jira issue $jira_key for $tk_id — skipping" >&2
            (( skipped_count++ )) || true
            continue
        fi

        # ── Parse Jira fields ────────────────────────────────────────────
        local summary jira_status_name jira_type_name jira_priority_name description
        local parse_result
        parse_result=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    fields = d.get('fields', {})
    print(fields.get('summary', '') or '')
    desc = fields.get('description', '') or ''
    if isinstance(desc, dict):
        def _adf_text(node):
            if isinstance(node, str): return node
            if isinstance(node, dict):
                if node.get('type') == 'text': return node.get('text', '')
                return ''.join(_adf_text(c) for c in node.get('content', []))
            if isinstance(node, list): return ''.join(_adf_text(c) for c in node)
            return ''
        desc = _adf_text(desc)
    print(str(desc) if desc else '')
    status = fields.get('status', {}) or {}
    print((status.get('name', '') or '').strip())
    issuetype = fields.get('issuetype', {}) or {}
    print((issuetype.get('name', '') or '').strip())
    priority = fields.get('priority', {}) or {}
    print((priority.get('name', '') or '').strip())
except Exception as e:
    sys.stderr.write('Error parsing Jira JSON: ' + str(e) + '\n')
    sys.exit(1)
" <<< "$jira_view_output" 2>/dev/null) || {
            echo "warning: failed to parse Jira JSON for $jira_key ($tk_id) — skipping" >&2
            (( skipped_count++ )) || true
            continue
        }

        summary=$(sed -n '1p' <<< "$parse_result")
        description=$(sed -n '2p' <<< "$parse_result")
        jira_status_name=$(sed -n '3p' <<< "$parse_result")
        jira_type_name=$(sed -n '4p' <<< "$parse_result")
        jira_priority_name=$(sed -n '5p' <<< "$parse_result")

        # ── Reverse field mapping (Jira -> tk) ───────────────────────────
        local tk_status
        if [[ -n "${JIRA_STATUS_MAP:-}" ]]; then
            tk_status=$(echo "$JIRA_STATUS_MAP" | tr ',' '\n' \
                | awk -F: -v s="$jira_status_name" '$1==s{print $2; exit}')
        fi
        if [[ -z "${tk_status:-}" ]]; then
            case "$jira_status_name" in
                "To Do")       tk_status="open" ;;
                "In Progress") tk_status="in_progress" ;;
                "Done")        tk_status="closed" ;;
                *)             tk_status="open" ;;
            esac
        fi

        local tk_type=""
        if [[ -n "${JIRA_TYPE_MAP:-}" ]]; then
            tk_type=$(echo "$JIRA_TYPE_MAP" | tr ',' '\n' \
                | awk -F: -v t="$jira_type_name" '$2==t{print $1; exit}')
        fi
        if [[ -z "$tk_type" ]]; then
            case "$jira_type_name" in
                "Epic")    tk_type="epic" ;;
                "Bug")     tk_type="bug" ;;
                "Task")    tk_type="task" ;;
                "Feature") tk_type="feature" ;;
                *)         tk_type="feature" ;;
            esac
        fi

        local tk_priority
        if [[ -n "${JIRA_PRIORITY_MAP:-}" ]]; then
            tk_priority=$(echo "$JIRA_PRIORITY_MAP" | tr ',' '\n' \
                | awk -F: -v p="$jira_priority_name" '$1==p{print $2; exit}')
        fi
        if [[ -z "${tk_priority:-}" ]]; then
            case "$jira_priority_name" in
                "Highest") tk_priority="0" ;;
                "High")    tk_priority="1" ;;
                "Medium")  tk_priority="2" ;;
                "Low")     tk_priority="3" ;;
                "Lowest")  tk_priority="4" ;;
                *)         tk_priority="2" ;;
            esac
        fi

        # ── Compute Jira-side hash using mapped tk fields ────────────────
        local jira_hash
        jira_hash=$(_sync_content_hash "$summary" "$tk_status" "$tk_type" "$tk_priority" "" "" "$description")

        # ── Compare hashes ───────────────────────────────────────────────
        (( checked_count++ )) || true
        if [[ "$local_hash" != "$jira_hash" ]]; then
            echo "DRIFT: $tk_id ($jira_key) -- local_hash=$local_hash jira_hash=$jira_hash"
            (( drift_count++ )) || true
        fi
    done

    echo "Checked $checked_count tickets"

    if [[ $drift_count -gt 0 ]]; then
        return 1
    fi
    return 0
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_diff_fields
#
# Prints a human-readable side-by-side diff of changed fields to stdout.
# Intended to show the user which fields conflict and what each side contains.
#
# Args:
#   $1  side_a_label  label for the first side (e.g. 'local')
#   $2  side_b_label  label for the second side (e.g. 'remote')
#   $3+ field:a_value:b_value triples (one per changed field)
#       The field name is separated from values by ':'.
#       Example: "title:Old title:New title"
#       Note: values may not contain ':' — the first ':' separates field name
#             from a_value, and the second ':' separates a_value from b_value.
#
# Output format (one block per field triple):
#   CONFLICT: <field>
#     <side_a_label>:  "<a_value>"
#     <side_b_label>: "<b_value>"
# ---------------------------------------------------------------------------
_sync_diff_fields() {
    local side_a_label="$1" side_b_label="$2"
    shift 2

    local triple field a_value b_value
    for triple in "$@"; do
        # Split on the first two ':' characters
        field="${triple%%:*}"
        local remainder="${triple#*:}"
        a_value="${remainder%%:*}"
        b_value="${remainder#*:}"

        echo "CONFLICT: $field"
        echo "  ${side_a_label}:  \"${a_value}\""
        echo "  ${side_b_label}: \"${b_value}\""
    done
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_push_ticket
#
# Pushes a single ticket file to Jira. Performs create-or-update logic:
#   - New ticket (not in ledger): create Jira issue, stamp jira_key in
#     frontmatter, write ledger entry.
#   - Modified ticket (hash differs from ledger): update Jira issue, update
#     ledger.
#   - Unchanged ticket (hash matches ledger): skip (no-op).
#
# Args:
#   $1  ticket_file  (path to the ticket .md file)
#   $2  ledger_file  (path to .sync-state.json)
#
# Environment:
#   JIRA_PROJECT     Jira project key (required)
#   JIRA_STATUS_MAP  Override status mapping: "open:In Progress,closed:Done"
#   JIRA_PRIORITY_MAP Override priority mapping: "0:Highest,1:High,..."
#
# Returns 0 on success/skip, 1 on acli failure.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# _sync_title_dedup_check TITLE JIRA_PROJECT
#
# Targeted JQL query to check if a Jira issue with the exact given title
# already exists. Returns the first matching Jira key on stdout, or empty
# string if no exact match found.
#
# - Uses JQL `summary ~ "title"` (fuzzy), then filters for exact match
# - Escapes special JQL characters (quotes, backslashes)
# - Returns empty string on acli failure (graceful degradation)
# - Exit code is always 0 (dedup guard failure must not block push)
# ---------------------------------------------------------------------------
_sync_title_dedup_check() {
    local title="$1"
    local project="$2"

    # Escape special characters for JQL: backslashes first, then double quotes
    local escaped_title
    escaped_title="${title//\\/\\\\}"
    escaped_title="${escaped_title//\"/\\\"}"

    # Run targeted JQL query
    local search_output=""
    local search_exit=0
    search_output=$(acli jira workitem search \
        --jql "project=$project AND summary ~ \"$escaped_title\"" \
        --json --limit 5 2>/dev/null) || search_exit=$?

    if [[ $search_exit -ne 0 || -z "$search_output" ]]; then
        echo "warning: title dedup JQL query failed (exit=$search_exit) — skipping dedup guard" >&2
        echo ""
        return 0
    fi

    # Parse results and find exact title match
    local matched_key
    matched_key=$(TITLE="$title" python3 -c "
import json, sys, os
title = os.environ['TITLE']
for issue in json.load(sys.stdin):
    summary = issue.get('fields', {}).get('summary', '')
    if summary == title:
        print(issue.get('key', ''))
        sys.exit(0)
" <<< "$search_output" 2>/dev/null) || true

    echo "$matched_key"
    return 0
}

_sync_push_ticket() {
    local ticket_file="$1" ledger_file="$2"
    local _SYNC_FORCE_RESOLVED=0

    # ── Parse frontmatter fields ─────────────────────────────────────────────
    local tk_id title status type priority deps links body

    tk_id=$(awk '/^---$/{n++; next} n==1 && /^id:/{print; exit}' "$ticket_file" \
        | sed 's/^id:[[:space:]]*//')
    title=$(awk '/^---$/{n++; next} n==2 && /^# /{sub(/^# /,""); print; exit}' "$ticket_file")
    if [[ -z "$title" ]]; then
        # Fallback: first # heading anywhere in file
        title=$(awk '/^# /{sub(/^# /,""); print; exit}' "$ticket_file")
    fi
    status=$(awk '/^---$/{n++; next} n==1 && /^status:/{print; exit}' "$ticket_file" \
        | sed 's/^status:[[:space:]]*//')
    type=$(awk '/^---$/{n++; next} n==1 && /^type:/{print; exit}' "$ticket_file" \
        | sed 's/^type:[[:space:]]*//')
    priority=$(awk '/^---$/{n++; next} n==1 && /^priority:/{print; exit}' "$ticket_file" \
        | sed 's/^priority:[[:space:]]*//')
    deps=$(awk '/^---$/{n++; next} n==1 && /^deps:/{print; exit}' "$ticket_file" \
        | sed 's/^deps:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
    links=$(awk '/^---$/{n++; next} n==1 && /^links:/{print; exit}' "$ticket_file" \
        | sed 's/^links:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
    local parent
    parent=$(awk '/^---$/{n++; next} n==1 && /^parent:/{print; exit}' "$ticket_file" \
        | sed 's/^parent:[[:space:]]*//')

    # Extract body: everything after the first # heading
    body=$(awk 'found{print} /^# /{found=1}' "$ticket_file" | sed '/^$/d' | head -50)

    # ── Compute content hash ─────────────────────────────────────────────────
    local local_hash
    local_hash=$(_sync_content_hash "$title" "$status" "$type" "$priority" "$deps" "$links" "$body")

    # ── Look up in ledger ────────────────────────────────────────────────────
    local ledger_jira_key ledger_local_hash ledger_jira_hash
    ledger_jira_key=$(_sync_ledger_read "$ledger_file" "$tk_id" "jira_key")
    ledger_local_hash=$(_sync_ledger_read "$ledger_file" "$tk_id" "local_hash")
    ledger_jira_hash=$(_sync_ledger_read "$ledger_file" "$tk_id" "jira_hash")

    # ── Field mapping ────────────────────────────────────────────────────────

    # Priority map: 0->Highest, 1->High, 2->Medium, 3->Low, 4->Lowest
    local jira_priority
    if [[ -n "${JIRA_PRIORITY_MAP:-}" ]]; then
        # Parse override map: "0:Highest,1:High,..."
        jira_priority=$(echo "$JIRA_PRIORITY_MAP" | tr ',' '\n' \
            | awk -F: -v p="$priority" '$1==p{print $2; exit}')
    fi
    if [[ -z "${jira_priority:-}" ]]; then
        case "$priority" in
            0) jira_priority="Highest" ;;
            1) jira_priority="High" ;;
            2) jira_priority="Medium" ;;
            3) jira_priority="Low" ;;
            4) jira_priority="Lowest" ;;
            *) jira_priority="Medium" ;;
        esac
    fi

    # Status map: open->To Do, closed->Done
    local jira_status
    if [[ -n "${JIRA_STATUS_MAP:-}" ]]; then
        jira_status=$(echo "$JIRA_STATUS_MAP" | tr ',' '\n' \
            | awk -F: -v s="$status" '$1==s{print $2; exit}')
    fi
    if [[ -z "${jira_status:-}" ]]; then
        case "$status" in
            open)        jira_status="To Do" ;;
            in_progress) jira_status="In Progress" ;;
            closed)      jira_status="Done" ;;
            *)           jira_status="To Do" ;;
        esac
    fi

    # Type map: tk type -> Jira issue type (override via JIRA_TYPE_MAP)
    local jira_type=""
    if [[ -n "${JIRA_TYPE_MAP:-}" ]]; then
        jira_type=$(echo "$JIRA_TYPE_MAP" | tr ',' '\n' \
            | awk -F: -v t="$type" '$1==t{print $2; exit}')
    fi
    if [[ -z "$jira_type" ]]; then
        case "$type" in
            epic)    jira_type="Epic" ;;
            feature) jira_type="Feature" ;;
            task)    jira_type="Task" ;;
            bug)     jira_type="Bug" ;;
            *)       jira_type="Feature" ;;
        esac
    fi

    # ── Create or update ─────────────────────────────────────────────────────
    local now local_jira_key=""
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u +"%Y-%m-%dT%H:%M:%SZ")

    # ── Reconcile ledger vs frontmatter jira_key ──────────────────────────
    local frontmatter_jira_key
    frontmatter_jira_key=$(awk '/^---$/{n++; next} n==1 && /^jira_key:/{print; exit}' "$ticket_file" \
        | sed 's/^jira_key:[[:space:]]*//' | tr -d "\"'")

    # Frontmatter wins over stale/missing ledger entry
    if [[ -n "$frontmatter_jira_key" && -z "$ledger_jira_key" ]]; then
        # Case A: frontmatter has key, ledger is empty — repair ledger
        echo "warning: ledger missing entry for $tk_id but frontmatter has $frontmatter_jira_key — repairing ledger" >&2
        ledger_jira_key="$frontmatter_jira_key"
        _sync_ledger_write "$ledger_file" "$tk_id" "$frontmatter_jira_key" "$local_hash" "" "$now"
    elif [[ -n "$frontmatter_jira_key" && -n "$ledger_jira_key" && "$frontmatter_jira_key" != "$ledger_jira_key" ]]; then
        # Case B: both non-empty but disagree — frontmatter wins
        echo "warning: ledger has $ledger_jira_key but frontmatter has $frontmatter_jira_key for $tk_id — using frontmatter" >&2
        ledger_jira_key="$frontmatter_jira_key"
        _sync_ledger_write "$ledger_file" "$tk_id" "$frontmatter_jira_key" "$local_hash" "" "$now"
    fi

    # ── Dedup guard: targeted JQL title query ────────────────────────────
    if [[ -z "$ledger_jira_key" && -z "$frontmatter_jira_key" ]]; then
        local existing_key
        existing_key=$(_sync_title_dedup_check "$title" "$JIRA_PROJECT")
        if [[ -n "$existing_key" ]]; then
            echo "warning: found existing Jira issue $existing_key matching title for $tk_id — repairing ledger" >&2
            ledger_jira_key="$existing_key"
            _sync_ledger_write "$ledger_file" "$tk_id" "$existing_key" "$local_hash" "" "$now"
        fi
    fi

    if [[ -z "$ledger_jira_key" ]]; then
        # ── NEW ticket: create Jira issue ─────────────────────────────────
        local create_output create_exit=0
        # Resolve parent Jira key if parent exists AND parent is an Epic.
        # Jira only allows Epic -> child hierarchy; non-Epic parents cause
        # "Given parent work item does not belong to appropriate hierarchy."
        local parent_jira_key=""
        if [[ -n "$parent" ]]; then
            local parent_file
            parent_file=$(ticket_path "$parent" 2>/dev/null) || true
            local parent_type=""
            if [[ -n "$parent_file" && -f "$parent_file" ]]; then
                parent_type=$(awk '/^---$/{n++; next} n==1 && /^type:/{print $2; exit}' "$parent_file")
            fi
            if [[ "$parent_type" == "epic" ]]; then
                parent_jira_key=$(_sync_ledger_read "$ledger_file" "$parent" "jira_key")
            fi
        fi

        local create_args=(
            --project "$JIRA_PROJECT"
            --summary "$title"
            --description "$body"
            --type "$jira_type"
        )
        if [[ -n "$parent_jira_key" ]]; then
            create_args+=(--parent "$parent_jira_key")
        fi

        create_output=$(acli jira workitem create \
            "${create_args[@]}" \
            2>&1) || create_exit=$?

        if [[ $create_exit -ne 0 ]]; then
            echo "Error: failed to create Jira issue for $tk_id: $create_output" >&2
            return 1
        fi

        # Parse jira_key from acli output (format: "✓ Work item D2L-3 created: ...")
        local jira_key
        jira_key=$(echo "$create_output" \
            | grep -oE '[A-Z][A-Z0-9]+-[0-9]+' | head -1 || echo "")

        if [[ -z "$jira_key" ]]; then
            echo "Error: could not parse Jira key from acli output for $tk_id" >&2
            return 1
        fi

        # Stamp jira_key into ticket frontmatter
        # Use python3 for reliable cross-platform frontmatter insertion
        # (BSD sed a\ does not support 0,/range/ correctly on macOS)
        if _grep -q "^jira_key:" "$ticket_file"; then
            _sed_i "$ticket_file" "s/^jira_key:.*/jira_key: ${jira_key}/"
        else
            local stamp_exit=0
            TICKET_FILE="$ticket_file" JIRA_KEY="$jira_key" python3 -c "
import os
ticket_file = os.environ['TICKET_FILE']
jira_key = os.environ['JIRA_KEY']
lines = open(ticket_file).readlines()
# Find the closing --- of frontmatter (second occurrence of a line that is just ---)
result = []
fm_count = 0
inserted = False
for line in lines:
    stripped = line.rstrip('\n').rstrip('\r')
    if stripped == '---':
        fm_count += 1
        if fm_count == 2 and not inserted:
            result.append('jira_key: ' + jira_key + '\n')
            inserted = True
    result.append(line)
open(ticket_file, 'w').writelines(result)
" || stamp_exit=$?
            if [[ $stamp_exit -ne 0 ]]; then
                echo "warning: failed to stamp jira_key into $ticket_file (exit=$stamp_exit)" >&2
                ((sync_failures++))
            elif ! _grep -q "^jira_key:" "$ticket_file"; then
                echo "warning: jira_key not found in $ticket_file after stamping" >&2
                ((sync_failures++))
            fi
        fi
        # Propagate jira_key stamp to worktree peers via cross-worktree sync
        ( _sync_ticket_file "$ticket_file" || true )

        # Write ledger entry — compute jira_hash from the fields we just pushed
        # so the pull phase sees no change and skips this ticket (prevents
        # spurious pull rewrites that could race with the push-phase sync).
        local pushed_jira_hash
        pushed_jira_hash=$(_sync_content_hash "$title" "$status" "$type" "$priority" "$deps" "$links" "$body")
        _sync_ledger_write "$ledger_file" "$tk_id" "$jira_key" "$local_hash" "$pushed_jira_hash" "$now"

        local_jira_key="$jira_key"
        echo "pushed: $tk_id -> $jira_key (created) type=$jira_type priority=$jira_priority status=$jira_status" >&2

    elif [[ "$local_hash" != "$ledger_local_hash" ]]; then
        # ── MODIFIED ticket: check for conflict before updating Jira ─────

        # Only attempt conflict detection when the ledger has a stored jira_hash.
        # An empty jira_hash means this ticket was created via push only (never pulled),
        # so there is no baseline to compare against — skip conflict detection.
        local current_jira_hash=""
        local jira_view_output jira_view_exit=0
        if [[ -n "$ledger_jira_hash" ]]; then
            # Fetch current Jira issue to compute its hash for conflict detection
            jira_view_output=$(acli jira workitem view "$ledger_jira_key" --json 2>/dev/null) || jira_view_exit=$?
        fi

        if [[ -n "$ledger_jira_hash" && $jira_view_exit -eq 0 && -n "$jira_view_output" ]]; then
            # Parse Jira fields from the fetched issue JSON
            local _jf_summary _jf_status_name _jf_type_name _jf_priority_name _jf_description
            local _jf_parse
            _jf_parse=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    fields = d.get('fields', {})
    print(fields.get('summary', '') or '')
    status = fields.get('status', {}) or {}
    print((status.get('name', '') or '').strip())
    issuetype = fields.get('issuetype', {}) or {}
    print((issuetype.get('name', '') or '').strip())
    priority = fields.get('priority', {}) or {}
    print((priority.get('name', '') or '').strip())
    desc_raw = fields.get('description', '') or ''
    if isinstance(desc_raw, dict):
        def _adf_text(node):
            if isinstance(node, str): return node
            if isinstance(node, dict):
                if node.get('type') == 'text': return node.get('text', '')
                return ''.join(_adf_text(c) for c in node.get('content', []))
            if isinstance(node, list): return ''.join(_adf_text(c) for c in node)
            return ''
        desc = _adf_text(desc_raw)
    else:
        desc = str(desc_raw) if desc_raw else ''
    print(desc[:200])
except Exception:
    pass
" <<< "$jira_view_output" 2>/dev/null) || true

            if [[ -n "$_jf_parse" ]]; then
                _jf_summary=$(sed -n '1p' <<< "$_jf_parse")
                _jf_status_name=$(sed -n '2p' <<< "$_jf_parse")
                _jf_type_name=$(sed -n '3p' <<< "$_jf_parse")
                _jf_priority_name=$(sed -n '4p' <<< "$_jf_parse")
                _jf_description=$(sed -n '5p' <<< "$_jf_parse")

                # Apply Jira→tk field mappings (same as _sync_pull_ticket) so the
                # computed hash is comparable to jira_hash stored in the ledger
                local _jf_tk_status _jf_tk_type _jf_tk_priority
                if [[ -n "${JIRA_STATUS_MAP:-}" ]]; then
                    _jf_tk_status=$(echo "$JIRA_STATUS_MAP" | tr ',' '\n' \
                        | awk -F: -v s="$_jf_status_name" '$1==s{print $2; exit}')
                fi
                if [[ -z "${_jf_tk_status:-}" ]]; then
                    case "$_jf_status_name" in
                        "To Do")       _jf_tk_status="open" ;;
                        "In Progress") _jf_tk_status="in_progress" ;;
                        "Done")        _jf_tk_status="closed" ;;
                        *)             _jf_tk_status="open" ;;
                    esac
                fi
                _jf_tk_type=""
                if [[ -n "${JIRA_TYPE_MAP:-}" ]]; then
                    _jf_tk_type=$(echo "$JIRA_TYPE_MAP" | tr ',' '\n' \
                        | awk -F: -v t="$_jf_type_name" '$2==t{print $1; exit}')
                fi
                if [[ -z "$_jf_tk_type" ]]; then
                    case "$_jf_type_name" in
                        "Epic")    _jf_tk_type="epic" ;;
                        "Bug")    _jf_tk_type="bug" ;;
                        "Task")   _jf_tk_type="task" ;;
                        "Feature") _jf_tk_type="feature" ;;
                        *)        _jf_tk_type="feature" ;;
                    esac
                fi
                if [[ -n "${JIRA_PRIORITY_MAP:-}" ]]; then
                    _jf_tk_priority=$(echo "$JIRA_PRIORITY_MAP" | tr ',' '\n' \
                        | awk -F: -v p="$_jf_priority_name" '$1==p{print $2; exit}')
                fi
                if [[ -z "${_jf_tk_priority:-}" ]]; then
                    case "$_jf_priority_name" in
                        "Highest") _jf_tk_priority="0" ;;
                        "High")    _jf_tk_priority="1" ;;
                        "Medium")  _jf_tk_priority="2" ;;
                        "Low")     _jf_tk_priority="3" ;;
                        "Lowest")  _jf_tk_priority="4" ;;
                        *)         _jf_tk_priority="2" ;;
                    esac
                fi

                current_jira_hash=$(_sync_content_hash \
                    "$_jf_summary" "$_jf_tk_status" "$_jf_tk_type" "$_jf_tk_priority" \
                    "" "" "$_jf_description")
            fi
        fi

        # Conflict detection: both local and Jira changed since last sync
        if [[ -n "$current_jira_hash" ]] && \
           _sync_detect_conflict "$tk_id" "$ledger_file" "$local_hash" "$current_jira_hash"; then
            # Conflict: both sides changed since last sync
            if [ -t 0 ]; then
                # ── TTY mode: show diff and prompt user ───────────────────
                _sync_diff_fields "local" "remote" \
                    "title:$title:$_jf_summary" \
                    "status:$status:$_jf_tk_status"
                local _resolve_choice
                printf 'Choose version [local/remote]: '
                read -r _resolve_choice
                if [[ "$_resolve_choice" == "remote" ]]; then
                    # Apply remote version: skip local push, update ledger with remote hash
                    _sync_ledger_write "$ledger_file" "$tk_id" "$ledger_jira_key" \
                        "$local_hash" "$current_jira_hash" "$now"
                    echo "resolved: $tk_id (chose remote)" >&2
                    return 0
                else
                    # Apply local version: proceed with push below (fall through)
                    echo "resolved: $tk_id (chose local)" >&2
                fi
            else
                # ── Non-TTY mode ──────────────────────────────────────────
                if [[ "${TK_SYNC_FORCE_LOCAL:-}" == "1" ]]; then
                    # --force-local: auto-resolve by pushing local version (fall through)
                    echo "conflict: $tk_id ($ledger_jira_key) — forcing local version" >&2
                    _SYNC_FORCE_RESOLVED=1
                else
                    echo "conflict: $tk_id ($ledger_jira_key) — both sides changed, skipping (use TTY to resolve)"
                    return 3
                fi
            fi
        fi

        # ── Update Jira issue ─────────────────────────────────────────────
        local edit_exit=0
        acli jira workitem edit \
            --key "$ledger_jira_key" \
            --summary "$title" \
            --description "$body" \
            >/dev/null 2>&1 || edit_exit=$?

        # Transition status separately (edit does not support --status)
        if [[ $edit_exit -eq 0 && -n "$jira_status" ]]; then
            acli jira workitem transition \
                --key "$ledger_jira_key" \
                --status "$jira_status" \
                >/dev/null 2>&1 || \
                echo "warning: failed to transition $ledger_jira_key to $jira_status" >&2
        fi

        if [[ $edit_exit -ne 0 ]]; then
            echo "Error: failed to update Jira issue $ledger_jira_key for $tk_id" >&2
            return 1
        fi

        # Update ledger
        _sync_ledger_write "$ledger_file" "$tk_id" "$ledger_jira_key" "$local_hash" "" "$now"

        local_jira_key="$ledger_jira_key"
        echo "pushed: $tk_id -> $ledger_jira_key (updated) type=$jira_type priority=$jira_priority status=$jira_status" >&2

    else
        # ── UNCHANGED: skip ───────────────────────────────────────────────
        echo "skipped: $tk_id (unchanged)" >&2
    fi

    # ── Push dep relationships to Jira ───────────────────────────────────────
    # For each dep tk-id, look up its Jira key in the ledger and call
    # acli workitem link to create a Blocks relationship.
    # Link errors are advisory (warnings only) — they do not fail the ticket sync.
    if [[ -n "$local_jira_key" && -n "$deps" ]]; then
        local dep_id dep_jira_key
        # deps is comma-separated (may have empty entries if ticket has no deps)
        IFS=',' read -ra _dep_ids <<< "$deps"
        for dep_id in "${_dep_ids[@]}"; do
            dep_id="${dep_id// /}"  # strip whitespace
            [[ -z "$dep_id" ]] && continue
            dep_jira_key=$(_sync_ledger_read "$ledger_file" "$dep_id" "jira_key")
            if [[ -z "$dep_jira_key" ]]; then
                echo "warning: dep $dep_id not in ledger — skipping link push for $tk_id" >&2
                continue
            fi
            # Call acli to create "Blocks" link: local ticket blocks the dep
            acli jira workitem link create \
                --out "$dep_jira_key" \
                --in "$local_jira_key" \
                --type 'Blocks' \
                >/dev/null 2>&1 || \
                echo "warning: failed to create Jira link ($dep_jira_key Blocks $local_jira_key) — skipping" >&2
        done
    fi

    # ── Push remote links to Jira ─────────────────────────────────────────────
    # For each URL in the ticket's links field, call acli workitem link with
    # link-type 'Remote' so the URL appears as a remote link on the Jira issue.
    # Link errors are advisory (warnings only) — they do not fail the ticket sync.
    if [[ -n "$local_jira_key" && -n "$links" ]]; then
        local _url
        # links is comma-separated list of URLs
        IFS=',' read -ra _link_urls <<< "$links"
        for _url in "${_link_urls[@]}"; do
            _url="${_url// /}"  # strip whitespace
            [[ -z "$_url" ]] && continue
            # acli does not support remote links — use Jira REST API directly
            curl -sf --connect-timeout 10 -m 30 -u "$JIRA_USER:$JIRA_API_TOKEN" \
                -X POST "$JIRA_URL/rest/api/3/issue/$local_jira_key/remotelink" \
                -H "Content-Type: application/json" \
                -d "{\"object\":{\"url\":\"$_url\",\"title\":\"Remote link\"}}" \
                >/dev/null 2>&1 || \
                echo "warning: remote link push failed for $tk_id url=$_url" >&2
        done
    fi

    # ── Push comments to Jira (non-fatal) ────────────────────────────────────
    # Resolve effective Jira key: set during create/update, or from ledger for
    # unchanged tickets.
    local _effective_jira_key="${local_jira_key:-$ledger_jira_key}"
    if [[ -n "$_effective_jira_key" ]]; then
        local _comment_count
        _comment_count=$(_sync_push_comments "$ticket_file" "$_effective_jira_key") || _comment_count=0
        if [[ "$_comment_count" -gt 0 ]]; then
            echo "tk sync: pushed $_comment_count comment(s) for $tk_id" >&2
        fi
    fi

    # Exit code 4 signals "force-resolved conflict" to the caller for counting
    if [[ "$_SYNC_FORCE_RESOLVED" -eq 1 ]]; then
        return 4
    fi
    return 0
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_pull_deps
#
# Parses Jira issuelinks from issue JSON, finds outward "Blocks" links,
# reverse-looks up tk IDs from the ledger, and writes the resolved tk IDs
# to the ticket file's deps frontmatter field.
#
# Args:
#   $1  jira_issue_json   Full Jira issue JSON string (may contain issuelinks)
#   $2  ledger_file       Path to .sync-state.json
#   $3  ticket_file       Path to the local ticket .md file to update
#   $4  jira_key          Jira key of the issue (used in warning messages)
#
# Behavior:
#   - Extracts fields.issuelinks[] where type.name == "Blocks" and outwardIssue is set
#   - For each outward Blocks link, scans ledger for the linked Jira key
#   - If found: accumulates the tk ID
#   - If not found: prints warning to stderr, skips (does NOT fail)
#   - Writes deps: [id1, id2, ...] (or deps: []) to frontmatter — always replaces
#
# Returns 0 always (never fails; warnings for missing ledger entries).
# ---------------------------------------------------------------------------
_sync_pull_deps() {
    local jira_issue_json="$1" ledger_file="$2" ticket_file="$3" jira_key="$4"

    # Parse outward Blocks link keys from issuelinks array
    local outward_jira_keys
    outward_jira_keys=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    links = d.get('fields', {}).get('issuelinks', []) or []
    keys = []
    for link in links:
        lt = link.get('type', {}) or {}
        if lt.get('name', '') == 'Blocks' and 'outwardIssue' in link:
            k = (link.get('outwardIssue') or {}).get('key', '')
            if k:
                keys.append(k)
    print('\n'.join(keys))
except Exception as e:
    sys.stderr.write('warning: failed to parse issuelinks: ' + str(e) + '\n')
" <<< "$jira_issue_json" 2>/dev/null || echo "")

    # For each outward key, reverse-lookup tk ID from ledger
    local resolved_tk_ids=()
    if [[ -n "$outward_jira_keys" ]]; then
        while IFS= read -r linked_key; do
            [[ -z "$linked_key" ]] && continue
            local mapped_tk_id=""
            if [[ -f "$ledger_file" ]]; then
                mapped_tk_id=$(LEDGER="$ledger_file" LINKED_KEY="$linked_key" python3 -c "
import json, os
try:
    d = json.load(open(os.environ['LEDGER']))
    lk = os.environ['LINKED_KEY']
    for tk_id, entry in d.items():
        if entry.get('jira_key') == lk:
            print(tk_id)
            break
except Exception:
    pass
" 2>/dev/null || echo "")
            fi
            if [[ -z "$mapped_tk_id" ]]; then
                echo "warning: Jira link $linked_key not in ledger — skipping dep pull for $jira_key" >&2
            else
                resolved_tk_ids+=("$mapped_tk_id")
            fi
        done <<< "$outward_jira_keys"
    fi

    # Build deps YAML value: [] or [id1, id2, ...]
    local deps_value="[]"
    if [[ "${#resolved_tk_ids[@]}" -gt 0 ]]; then
        deps_value="[$(IFS=', '; echo "${resolved_tk_ids[*]}")]"
    fi

    # Write deps to ticket frontmatter (replace existing deps: line)
    TICKET_FILE="$ticket_file" DEPS_VALUE="$deps_value" python3 -c "
import os
tf = os.environ['TICKET_FILE']
dv = os.environ['DEPS_VALUE']
lines = open(tf).readlines()
result = []
fm = 0
deps_written = False
for line in lines:
    s = line.rstrip('\n').rstrip('\r')
    if s == '---':
        fm += 1
        if fm == 2 and not deps_written:
            # Closing ---, ensure deps was written
            result.append('deps: ' + dv + '\n')
            deps_written = True
        result.append(line)
        continue
    if fm == 1 and s.startswith('deps:'):
        result.append('deps: ' + dv + '\n')
        deps_written = True
        continue
    result.append(line)
open(tf, 'w').writelines(result)
" 2>/dev/null
    # Propagate deps change to worktree peers via cross-worktree sync
    ( _sync_ticket_file "$ticket_file" || true )

    return 0
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_pull_remote_links
#
# REVIEW-DEFENSE: jira_hash intentionally excludes deps and remoteLinks.
# Including them would require a separate `workitem view` API call per issue
# (search results don't include issuelinks/remoteLinks). Deps and links are
# currently pulled only when core fields change (hash mismatch), so link-only
# Jira changes won't be detected until a core field also changes. This is a
# known design limitation — same applies to _sync_pull_deps. Fixing requires
# either (a) always fetching full issue details (expensive) or (b) a periodic
# full-refresh mode. Tracked as a future enhancement.
#
# Parses Jira remote links from issue JSON and writes all URLs to the
# ticket file's links frontmatter field.
#
# Remote links are NOT included in Jira search results — they must be fetched
# via a separate view call or embedded in the issue JSON under the top-level
# "remoteLinks" key (array of {"object":{"url":"https://..."}}).
# This helper reads the top-level remoteLinks field if present in the supplied
# issue JSON.  If the field is absent or empty, it writes links: [] to clear
# any stale links from a prior sync state.
#
# Args:
#   $1  jira_issue_json   Full Jira issue JSON string (top-level remoteLinks key)
#   $2  ticket_file       Path to the local ticket .md file to update
#   $3  jira_key          Jira key of the issue (used in warning messages)
#
# Behavior:
#   - Extracts top-level remoteLinks[].object.url values from the JSON
#   - Writes links: [url1, url2, ...] (or links: []) to frontmatter — always replaces
#
# Returns 0 always (never fails; warnings for parse errors).
# ---------------------------------------------------------------------------
_sync_pull_remote_links() {
    local jira_issue_json="$1" ticket_file="$2" jira_key="$3"

    # Parse remote link URLs from top-level remoteLinks array
    # Each entry has the form: {"object": {"url": "https://..."}, ...}
    local remote_urls
    remote_urls=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    rlinks = d.get('remoteLinks', []) or []
    urls = []
    for rl in rlinks:
        url = (rl.get('object') or {}).get('url', '')
        if url:
            urls.append(url)
    print('\n'.join(urls))
except Exception as e:
    sys.stderr.write('warning: failed to parse remoteLinks for $jira_key: ' + str(e) + '\n')
" <<< "$jira_issue_json" 2>/dev/null || echo "")

    # Build links YAML value: [] or [url1, url2, ...]
    local links_value="[]"
    if [[ -n "$remote_urls" ]]; then
        local url_list=()
        while IFS= read -r url; do
            [[ -z "$url" ]] && continue
            url_list+=("$url")
        done <<< "$remote_urls"
        if [[ "${#url_list[@]}" -gt 0 ]]; then
            links_value="[$(IFS=', '; echo "${url_list[*]}")]"
        fi
    fi

    # Write links to ticket frontmatter (replace existing links: line)
    TICKET_FILE="$ticket_file" LINKS_VALUE="$links_value" python3 -c "
import os
tf = os.environ['TICKET_FILE']
lv = os.environ['LINKS_VALUE']
lines = open(tf).readlines()
result = []
fm = 0
links_written = False
for line in lines:
    s = line.rstrip('\n').rstrip('\r')
    if s == '---':
        fm += 1
        if fm == 2 and not links_written:
            # Closing ---, ensure links was written before it
            result.append('links: ' + lv + '\n')
            links_written = True
        result.append(line)
        continue
    if fm == 1 and s.startswith('links:'):
        result.append('links: ' + lv + '\n')
        links_written = True
        continue
    result.append(line)
open(tf, 'w').writelines(result)
" 2>/dev/null
    # Propagate links change to worktree peers via cross-worktree sync
    ( _sync_ticket_file "$ticket_file" || true )

    return 0
}

# ---------------------------------------------------------------------------
# Sync helper: _sync_pull_ticket
#
# Pulls a single Jira issue JSON object and creates or updates the
# corresponding local .tickets/ file.  Reverse of _sync_push_ticket.
#
#   - New issue (jira_key not in ledger): create local ticket via TK_SCRIPT,
#     stamp jira_key in frontmatter, write body, write ledger entry.
#   - Modified issue (jira_hash differs from ledger): update local ticket
#     file (title, body, frontmatter), update ledger.
#   - Unchanged issue (jira_hash matches ledger): skip.
#
# Args:
#   $1  jira_issue_json  (single Jira issue object as a JSON string)
#   $2  ledger_file      (path to .sync-state.json)
#   $3  tickets_dir      (path to .tickets/ directory)
#
# Environment:
#   JIRA_STATUS_MAP    Override status mapping: "To Do:open,Done:closed,..."
#   JIRA_PRIORITY_MAP  Override priority mapping: "Highest:0,High:1,..."
#   TK_SCRIPT          Path to this script (set by load_tk_pull_helpers in tests,
#                      or resolved via BASH_SOURCE[0] at runtime)
#
# Outputs diagnostic messages to stderr.
# Returns 0 on success/skip, 1 on failure.
# ---------------------------------------------------------------------------
_sync_pull_ticket() {
    local jira_issue_json="$1" ledger_file="$2" tickets_dir="$3"

    # Resolve path to this script so we can call "tk create" as a subprocess
    local tk_script
    if [[ -n "${TK_SCRIPT:-}" ]]; then
        tk_script="$TK_SCRIPT"
    else
        tk_script="$(realpath "${BASH_SOURCE[0]}")"
    fi

    # ── Parse Jira fields from JSON ──────────────────────────────────────────
    local jira_key summary description jira_status_name jira_type_name jira_priority_name
    local parse_result
    parse_result=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    print(d.get('key', ''))
    fields = d.get('fields', {})
    print(fields.get('summary', '') or '')
    desc_raw = fields.get('description', '') or ''
    # Jira API v3 returns description as ADF (dict); extract plain text
    if isinstance(desc_raw, dict):
        def _adf_text(node):
            if isinstance(node, str): return node
            if isinstance(node, dict):
                if node.get('type') == 'text': return node.get('text', '')
                return ''.join(_adf_text(c) for c in node.get('content', []))
            if isinstance(node, list): return ''.join(_adf_text(c) for c in node)
            return ''
        desc = _adf_text(desc_raw)
    else:
        desc = str(desc_raw) if desc_raw else ''
    # Collapse to single line for passing via variable; newlines handled later
    print(desc.replace('\n', '\\\\n'))
    status = fields.get('status', {}) or {}
    print((status.get('name', '') or '').strip())
    issuetype = fields.get('issuetype', {}) or {}
    print((issuetype.get('name', '') or '').strip())
    priority = fields.get('priority', {}) or {}
    print((priority.get('name', '') or '').strip())
except Exception as e:
    sys.stderr.write('Error parsing Jira JSON: ' + str(e) + '\n')
    sys.exit(1)
" <<< "$jira_issue_json" 2>/dev/null) || {
        echo "Error: failed to parse Jira issue JSON" >&2
        return 1
    }

    # Read the 6 lines of output
    jira_key=$(sed -n '1p' <<< "$parse_result")
    summary=$(sed -n '2p' <<< "$parse_result")
    local desc_escaped
    desc_escaped=$(sed -n '3p' <<< "$parse_result")
    jira_status_name=$(sed -n '4p' <<< "$parse_result")
    jira_type_name=$(sed -n '5p' <<< "$parse_result")
    jira_priority_name=$(sed -n '6p' <<< "$parse_result")

    # Skip lock issues (agent-batch-lifecycle markers)
    if [[ "$summary" == \[LOCK\]* ]]; then
        return 0
    fi

    # Restore newlines in description
    description=$(printf '%b' "${desc_escaped//\\\\n/$'\n'}")

    if [[ -z "$jira_key" ]]; then
        echo "Error: Jira issue JSON missing 'key' field" >&2
        return 1
    fi

    # ── Reverse field mapping ────────────────────────────────────────────────

    # Status: Jira -> tk
    local tk_status
    if [[ -n "${JIRA_STATUS_MAP:-}" ]]; then
        tk_status=$(echo "$JIRA_STATUS_MAP" | tr ',' '\n' \
            | awk -F: -v s="$jira_status_name" '$1==s{print $2; exit}')
    fi
    if [[ -z "${tk_status:-}" ]]; then
        case "$jira_status_name" in
            "To Do")       tk_status="open" ;;
            "In Progress") tk_status="in_progress" ;;
            "Done")        tk_status="closed" ;;
            *)             tk_status="open" ;;
        esac
    fi

    # Type: Jira -> tk (override via JIRA_TYPE_MAP — reverse lookup)
    local tk_type=""
    if [[ -n "${JIRA_TYPE_MAP:-}" ]]; then
        tk_type=$(echo "$JIRA_TYPE_MAP" | tr ',' '\n' \
            | awk -F: -v t="$jira_type_name" '$2==t{print $1; exit}')
    fi
    if [[ -z "$tk_type" ]]; then
        case "$jira_type_name" in
            "Epic")    tk_type="epic" ;;
            "Bug")    tk_type="bug" ;;
            "Task")   tk_type="task" ;;
            "Feature") tk_type="feature" ;;
            *)        tk_type="feature" ;;
        esac
    fi

    # Priority: Jira -> tk
    local tk_priority
    if [[ -n "${JIRA_PRIORITY_MAP:-}" ]]; then
        tk_priority=$(echo "$JIRA_PRIORITY_MAP" | tr ',' '\n' \
            | awk -F: -v p="$jira_priority_name" '$1==p{print $2; exit}')
    fi
    if [[ -z "${tk_priority:-}" ]]; then
        case "$jira_priority_name" in
            "Highest") tk_priority="0" ;;
            "High")    tk_priority="1" ;;
            "Medium")  tk_priority="2" ;;
            "Low")     tk_priority="3" ;;
            "Lowest")  tk_priority="4" ;;
            *)         tk_priority="2" ;;
        esac
    fi

    # ── Compute jira_hash for this issue ─────────────────────────────────────
    local jira_hash
    jira_hash=$(_sync_content_hash "$summary" "$tk_status" "$tk_type" "$tk_priority" "" "" "$description")

    # ── Look up jira_key in ledger (reverse lookup: scan for jira_key value) ─
    local existing_tk_id=""
    if [[ -f "$ledger_file" ]]; then
        existing_tk_id=$(python3 -c "
import json, sys
try:
    d = json.load(open('$ledger_file'))
    for tk_id, entry in d.items():
        if entry.get('jira_key') == '$jira_key':
            print(tk_id)
            break
except Exception:
    pass
" 2>/dev/null || echo "")
    fi

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u +"%Y-%m-%dT%H:%M:%SZ")

    if [[ -z "$existing_tk_id" ]]; then
        # ── Skip archived/tombstoned Jira issues (w20-oviu) ─────────────────
        # If the Jira key is in .tombstones, it was explicitly deleted/archived.
        local tombstone_file="$tickets_dir/.tombstones"
        if [[ -f "$tombstone_file" ]] && grep -qxF "$jira_key" "$tombstone_file"; then
            return 0  # skip — already archived
        fi
        # If the Jira status maps to "closed" and no local ticket exists,
        # don't recreate it — it was likely closed and cleaned up intentionally.
        # Note: depends on JIRA_STATUS_MAP mapping Done/Archived → "closed".
        # Custom maps that map terminal states to non-"closed" will bypass this.
        if [[ "$tk_status" == "closed" ]]; then
            return 0  # skip Done/closed Jira issues with no local counterpart
        fi

        # ── NEW issue: create local ticket ───────────────────────────────────
        local new_tk_id
        new_tk_id=$(TICKETS_DIR="$tickets_dir" "$tk_script" create \
            "$summary" \
            --type "$tk_type" \
            --priority "$tk_priority" \
            2>/dev/null) || {
            echo "Error: tk create failed for Jira issue $jira_key" >&2
            return 1
        }

        new_tk_id=$(echo "$new_tk_id" | tr -d '[:space:]')
        if [[ -z "$new_tk_id" ]]; then
            echo "Error: tk create returned empty ID for Jira issue $jira_key" >&2
            return 1
        fi

        local ticket_file="$tickets_dir/${new_tk_id}.md"
        if [[ ! -f "$ticket_file" ]]; then
            echo "Error: ticket file not found after create: $ticket_file" >&2
            return 1
        fi

        # Update status in frontmatter (tk create always sets status: open)
        if [[ "$tk_status" != "open" ]]; then
            TICKET_FILE="$ticket_file" TK_STATUS="$tk_status" python3 -c "
import os
tf = os.environ['TICKET_FILE']
st = os.environ['TK_STATUS']
lines = open(tf).readlines()
result = []
fm = 0
for line in lines:
    s = line.rstrip('\n').rstrip('\r')
    if s == '---':
        fm += 1
    if fm == 1 and s.startswith('status:'):
        result.append('status: ' + st + '\n')
    else:
        result.append(line)
open(tf, 'w').writelines(result)
" 2>/dev/null
        fi

        # Stamp jira_key into frontmatter (before closing ---)
        local stamp_exit=0
        TICKET_FILE="$ticket_file" JIRA_KEY="$jira_key" python3 -c "
import os
ticket_file = os.environ['TICKET_FILE']
jira_key = os.environ['JIRA_KEY']
lines = open(ticket_file).readlines()
result = []
fm_count = 0
inserted = False
for line in lines:
    stripped = line.rstrip('\n').rstrip('\r')
    if stripped == '---':
        fm_count += 1
        if fm_count == 2 and not inserted:
            result.append('jira_key: ' + jira_key + '\n')
            inserted = True
    result.append(line)
open(ticket_file, 'w').writelines(result)
" || stamp_exit=$?
        if [[ $stamp_exit -ne 0 ]]; then
            echo "warning: failed to stamp jira_key into $ticket_file (exit=$stamp_exit)" >&2
        elif ! _grep -q "^jira_key:" "$ticket_file"; then
            echo "warning: jira_key not found in $ticket_file after stamping" >&2
        fi

        # Write body (description) into ticket file below the title heading
        if [[ -n "$description" ]]; then
            TICKET_FILE="$ticket_file" python3 -c "
import os
ticket_file = os.environ['TICKET_FILE']
lines = open(ticket_file).readlines()
result = []
inserted = False
for i, line in enumerate(lines):
    result.append(line)
    # Insert description after the first # heading line
    if not inserted and line.startswith('# '):
        result.append('\n')
        for desc_line in os.environ.get('DESCRIPTION', '').split('\n'):
            result.append(desc_line + '\n')
        inserted = True
open(ticket_file, 'w').writelines(result)
" DESCRIPTION="$description" 2>/dev/null
        fi

        # Populate deps from Jira issuelinks (outward Blocks links → tk IDs)
        _sync_pull_deps "$jira_issue_json" "$ledger_file" "$ticket_file" "$jira_key"

        # Populate links from Jira remoteLinks (URLs → links: frontmatter field)
        _sync_pull_remote_links "$jira_issue_json" "$ticket_file" "$jira_key"

        # Pull comments from Jira (non-fatal — failure logged but continues)
        local _pulled_count=0
        _pulled_count=$(_sync_fetch_and_pull_comments "$jira_issue_json" "$ticket_file" "$jira_key" "new ticket $new_tk_id")
        : "${_sync_session_comments:=0}" "${_sync_session_comment_tickets:=0}"
        (( _sync_session_comments += _pulled_count )) 2>/dev/null || true
        if [[ $_pulled_count -gt 0 ]]; then
            (( _sync_session_comment_tickets++ )) 2>/dev/null || true
        fi

        # Propagate all writes (status, jira_key, body, deps, links) to worktree peers
        ( _sync_ticket_file "$ticket_file" || true )

        # Compute local_hash from the actual file content (not from Jira fields directly)
        # so that conflict detection is consistent regardless of body-write success.
        local local_hash new_local_title new_local_status new_local_type new_local_priority
        local new_local_deps new_local_links new_local_body
        new_local_title=$(awk '/^---$/{n++; next} n==2 && /^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        if [[ -z "$new_local_title" ]]; then
            new_local_title=$(awk '/^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        fi
        new_local_status=$(awk '/^---$/{n++; next} n==1 && /^status:/{print; exit}' "$ticket_file" \
            | sed 's/^status:[[:space:]]*//')
        new_local_type=$(awk '/^---$/{n++; next} n==1 && /^type:/{print; exit}' "$ticket_file" \
            | sed 's/^type:[[:space:]]*//')
        new_local_priority=$(awk '/^---$/{n++; next} n==1 && /^priority:/{print; exit}' "$ticket_file" \
            | sed 's/^priority:[[:space:]]*//')
        new_local_deps=$(awk '/^---$/{n++; next} n==1 && /^deps:/{print; exit}' "$ticket_file" \
            | sed 's/^deps:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
        new_local_links=$(awk '/^---$/{n++; next} n==1 && /^links:/{print; exit}' "$ticket_file" \
            | sed 's/^links:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
        new_local_body=$(awk 'found{print} /^# /{found=1}' "$ticket_file" | sed '/^$/d' | head -50)
        local_hash=$(_sync_content_hash \
            "$new_local_title" "$new_local_status" "$new_local_type" "$new_local_priority" \
            "$new_local_deps" "$new_local_links" "$new_local_body")

        # Write ledger entry
        _sync_ledger_write "$ledger_file" "$new_tk_id" "$jira_key" "$local_hash" "$jira_hash" "$now"

        echo "pulled: $jira_key -> $new_tk_id (created)" >&2

    else
        # ── EXISTING issue: check if changed ─────────────────────────────────
        local ledger_jira_hash
        ledger_jira_hash=$(_sync_ledger_read "$ledger_file" "$existing_tk_id" "jira_hash")

        if [[ "$jira_hash" == "$ledger_jira_hash" ]]; then
            # Unchanged: skip
            echo "skipped: $jira_key (unchanged)" >&2
            return 0
        fi

        # Conflict guard: check if local ticket has also changed since last sync
        local ticket_file="$tickets_dir/${existing_tk_id}.md"
        if [[ ! -f "$ticket_file" ]]; then
            echo "Error: expected ticket file not found: $ticket_file" >&2
            return 1
        fi

        # Compute current local hash by reading the existing local ticket file
        local local_title local_status local_type local_priority local_deps local_links local_body
        local_title=$(awk '/^---$/{n++; next} n==2 && /^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        if [[ -z "$local_title" ]]; then
            local_title=$(awk '/^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        fi
        local_status=$(awk '/^---$/{n++; next} n==1 && /^status:/{print; exit}' "$ticket_file" \
            | sed 's/^status:[[:space:]]*//')
        local_type=$(awk '/^---$/{n++; next} n==1 && /^type:/{print; exit}' "$ticket_file" \
            | sed 's/^type:[[:space:]]*//')
        local_priority=$(awk '/^---$/{n++; next} n==1 && /^priority:/{print; exit}' "$ticket_file" \
            | sed 's/^priority:[[:space:]]*//')
        local_deps=$(awk '/^---$/{n++; next} n==1 && /^deps:/{print; exit}' "$ticket_file" \
            | sed 's/^deps:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
        local_links=$(awk '/^---$/{n++; next} n==1 && /^links:/{print; exit}' "$ticket_file" \
            | sed 's/^links:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
        local_body=$(awk 'found{print} /^# /{found=1}' "$ticket_file" | sed '/^$/d' | head -50)

        local current_local_hash
        current_local_hash=$(_sync_content_hash \
            "$local_title" "$local_status" "$local_type" "$local_priority" \
            "$local_deps" "$local_links" "$local_body")

        # Detect conflict: both local and jira changed since last sync
        if _sync_detect_conflict "$existing_tk_id" "$ledger_file" "$current_local_hash" "$jira_hash"; then
            # Conflict detected
            if [ -t 0 ]; then
                # TTY mode: show diff and prompt user
                local ledger_local_hash
                ledger_local_hash=$(_sync_ledger_read "$ledger_file" "$existing_tk_id" "local_hash")
                _sync_diff_fields "local" "remote" \
                    "title:${local_title}:${summary}" \
                    "status:${local_status}:${tk_status}"
                printf 'Choose version [local/remote]: '
                local user_choice
                read -r user_choice
                if [[ "$user_choice" == "remote" ]]; then
                    # Fall through to update below (no return; execution continues)
                    true
                else
                    # Keep local: update ledger to mark both sides as in sync with
                    # the local state. Record local_hash for both hashes so next pull
                    # sees Jira as "unchanged" relative to what the user chose to keep.
                    _sync_ledger_write "$ledger_file" "$existing_tk_id" "$jira_key" \
                        "$current_local_hash" "$current_local_hash" "$now"
                    echo "conflict resolved: kept local for $jira_key ($existing_tk_id)" >&2
                    return 0
                fi
            else
                # Non-TTY mode
                if [[ "${TK_SYNC_FORCE_LOCAL:-}" == "1" ]]; then
                    # --force-local: keep local, update ledger to mark in sync
                    _sync_ledger_write "$ledger_file" "$existing_tk_id" "$jira_key" \
                        "$current_local_hash" "$current_local_hash" "$now"
                    echo "conflict: $existing_tk_id ($jira_key) — forcing local version" >&2
                    return 4
                else
                    echo "conflict: $existing_tk_id ($jira_key) — both sides changed, skipping (use TTY to resolve)"
                    return 3
                fi
            fi
        fi

        # Modified: update local ticket file

        # Hard gate: reject update if Jira summary exceeds Jira's 255-char limit.
        # (Jira itself enforces this on writes, but guard locally in case of data
        # inconsistency or testing with synthetic data.)
        local _update_title_len=${#summary}
        if (( _update_title_len > 255 )); then
            echo "Error: Jira summary for $jira_key is ${_update_title_len} characters (max 255)." >&2
            echo "Jira's summary field has a 255-character limit. Skipping update to avoid corrupting local ticket." >&2
            return 1
        fi

        # Update frontmatter fields and title using python3
        TICKET_FILE="$ticket_file" \
        NEW_TITLE="$summary" \
        NEW_STATUS="$tk_status" \
        NEW_TYPE="$tk_type" \
        NEW_PRIORITY="$tk_priority" \
        NEW_BODY="$description" \
        python3 -c "
import os

ticket_file  = os.environ['TICKET_FILE']
new_title    = os.environ['NEW_TITLE']
new_status   = os.environ['NEW_STATUS']
new_type     = os.environ['NEW_TYPE']
new_priority = os.environ['NEW_PRIORITY']
new_body     = os.environ['NEW_BODY']

lines = open(ticket_file).readlines()
result = []
fm_count = 0
in_body = False
body_inserted = False

for line in lines:
    stripped = line.rstrip('\n').rstrip('\r')
    if stripped == '---':
        fm_count += 1
        result.append(line)
        if fm_count == 2:
            in_body = True
        continue
    if fm_count == 1:
        # Inside frontmatter: update known fields
        if stripped.startswith('status:'):
            result.append('status: ' + new_status + '\n')
        elif stripped.startswith('type:'):
            result.append('type: ' + new_type + '\n')
        elif stripped.startswith('priority:'):
            result.append('priority: ' + new_priority + '\n')
        else:
            result.append(line)
        continue
    if in_body:
        # Replace title heading
        if stripped.startswith('# ') and not body_inserted:
            result.append('# ' + new_title + '\n')
            if new_body:
                result.append('\n')
                for bl in new_body.split('\n'):
                    result.append(bl + '\n')
            body_inserted = True
            # Skip rest of old body by not appending other lines
            break
        else:
            result.append(line)
    else:
        result.append(line)

open(ticket_file, 'w').writelines(result)
" 2>/dev/null

        # Populate deps from Jira issuelinks (outward Blocks links → tk IDs)
        _sync_pull_deps "$jira_issue_json" "$ledger_file" "$ticket_file" "$jira_key"

        # Populate links from Jira remoteLinks (URLs → links: frontmatter field)
        _sync_pull_remote_links "$jira_issue_json" "$ticket_file" "$jira_key"

        # Pull comments from Jira (non-fatal — failure logged but continues)
        local _pulled_count=0
        _pulled_count=$(_sync_fetch_and_pull_comments "$jira_issue_json" "$ticket_file" "$jira_key" "$existing_tk_id")
        : "${_sync_session_comments:=0}" "${_sync_session_comment_tickets:=0}"
        (( _sync_session_comments += _pulled_count )) 2>/dev/null || true
        if [[ $_pulled_count -gt 0 ]]; then
            (( _sync_session_comment_tickets++ )) 2>/dev/null || true
        fi

        # Propagate all writes (title, status, body, deps, links) to worktree peers
        ( _sync_ticket_file "$ticket_file" || true )

        # Update ledger: record local_hash = file content hash after the pull update.
        # After a successful pull, the local file reflects Jira content, so compute
        # the hash from the updated file to ensure the conflict guard has a consistent
        # baseline for future local-edit detection.
        local updated_local_title updated_local_status updated_local_type updated_local_priority
        local updated_local_deps updated_local_links updated_local_body updated_local_hash
        updated_local_title=$(awk '/^---$/{n++; next} n==2 && /^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        if [[ -z "$updated_local_title" ]]; then
            updated_local_title=$(awk '/^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        fi
        updated_local_status=$(awk '/^---$/{n++; next} n==1 && /^status:/{print; exit}' "$ticket_file" \
            | sed 's/^status:[[:space:]]*//')
        updated_local_type=$(awk '/^---$/{n++; next} n==1 && /^type:/{print; exit}' "$ticket_file" \
            | sed 's/^type:[[:space:]]*//')
        updated_local_priority=$(awk '/^---$/{n++; next} n==1 && /^priority:/{print; exit}' "$ticket_file" \
            | sed 's/^priority:[[:space:]]*//')
        updated_local_deps=$(awk '/^---$/{n++; next} n==1 && /^deps:/{print; exit}' "$ticket_file" \
            | sed 's/^deps:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
        updated_local_links=$(awk '/^---$/{n++; next} n==1 && /^links:/{print; exit}' "$ticket_file" \
            | sed 's/^links:[[:space:]]*//' | tr -d '[]' | tr ',' '\n' | tr -d ' ' | sort | paste -sd ',' - 2>/dev/null || echo "")
        updated_local_body=$(awk 'found{print} /^# /{found=1}' "$ticket_file" | sed '/^$/d' | head -50)
        updated_local_hash=$(_sync_content_hash \
            "$updated_local_title" "$updated_local_status" "$updated_local_type" "$updated_local_priority" \
            "$updated_local_deps" "$updated_local_links" "$updated_local_body")

        _sync_ledger_write "$ledger_file" "$existing_tk_id" "$jira_key" "$updated_local_hash" "$jira_hash" "$now"

        echo "pulled: $jira_key -> $existing_tk_id (updated)" >&2
    fi

    return 0
}

# ---------------------------------------------------------------------------
# _sync_pull_comments
#
# Pulls comments from a Jira issue JSON object and appends them as structured
# notes to a local ticket file.  Deduplicates by deriving a deterministic
# note-id from each Jira comment ID (jira-<first 8 chars>).  Skips comments
# whose body contains the TK_SYNC_ATTRIBUTION marker (anti-echo).
#
# Args:
#   $1  jira_issue_json  (single Jira issue object as a JSON string)
#   $2  ticket_file      (path to the local .tickets/<id>.md file)
#
# Returns 0 on success or partial success; logs warnings to stderr on
# individual comment failures.
# ---------------------------------------------------------------------------
_sync_pull_comments() {
    local jira_issue_json="$1" ticket_file="$2"

    [[ -f "$ticket_file" ]] || { echo "Error: ticket file not found: $ticket_file" >&2; return 1; }

    # Parse comments from Jira JSON using python3 (matches existing patterns)
    local parsed_comments
    parsed_comments=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    fields = d.get('fields', {})
    comment_block = fields.get('comment', {}) or {}
    comments = comment_block.get('comments', []) or []
    for c in comments:
        cid = str(c.get('id', ''))
        body = str(c.get('body', '') or '')
        created = str(c.get('created', '') or '')
        author = c.get('author', {}) or {}
        display_name = str(author.get('displayName', '') or 'Unknown')
        # Output as tab-separated: id, created, author, body (body newlines escaped)
        safe_body = body.replace('\\\\', '\\\\\\\\').replace('\\n', '\\\\n').replace('\\t', '    ')
        print(cid + '\\t' + created + '\\t' + display_name + '\\t' + safe_body)
except Exception as e:
    sys.stderr.write('Error parsing Jira comments: ' + str(e) + '\\n')
    sys.exit(1)
" <<< "$jira_issue_json" 2>/dev/null) || {
        echo "warning: failed to parse Jira comments JSON" >&2
        return 0  # non-fatal
    }

    # If no comments, nothing to do
    [[ -z "$parsed_comments" ]] && return 0

    # Get existing note IDs for dedup (portable: no grep -P on macOS)
    local existing_note_ids=""
    if [[ -f "$ticket_file" ]]; then
        existing_note_ids=$(sed -n 's/.*<!-- note-id: \([a-z0-9-]*\) -->.*/\1/p' "$ticket_file" 2>/dev/null || true)
    fi

    local attribution="${TK_SYNC_ATTRIBUTION:-Posted by tk sync}"
    local added=0

    while IFS=$'\t' read -r comment_id created author body_escaped; do
        [[ -z "$comment_id" ]] && continue

        # Derive deterministic note-id from Jira comment ID
        local note_id="jira-${comment_id:0:8}"

        # Dedup: skip if this note-id already exists
        if echo "$existing_note_ids" | grep -qxF "$note_id"; then
            continue
        fi

        # Restore newlines in body
        local body
        body=$(printf '%b' "${body_escaped//\\\\n/$'\n'}")

        # Anti-echo: skip comments that contain the attribution marker
        if [[ "$body" == *"$attribution"* ]]; then
            echo "skipped echo comment $comment_id (contains attribution marker)" >&2
            continue
        fi

        # Sanitize body: replace leading --- lines to prevent frontmatter confusion
        body=$(echo "$body" | sed 's/^---$/- - -/g')

        # Format note text with author attribution
        local note_text="[Jira: $author] $body"

        # Convert Jira timestamp to ISO 8601 (strip milliseconds and timezone offset)
        local timestamp
        timestamp=$(python3 -c "
import sys
ts = sys.argv[1]
# Handle Jira format: 2026-03-05T10:00:00.000+0000
# Strip to ISO 8601 UTC
if '.' in ts:
    ts = ts[:ts.index('.')]
ts = ts.rstrip('Z') + 'Z'
print(ts)
" "$created" 2>/dev/null || echo "$created")

        # Add Notes section if missing
        if ! grep -q '^## Notes' "$ticket_file"; then
            printf '\n## Notes\n' >> "$ticket_file"
        fi

        # Append structured note block
        printf '\n<!-- note-id: %s -->\n' "$note_id" >> "$ticket_file"
        printf '<!-- timestamp: %s -->\n' "$timestamp" >> "$ticket_file"
        printf '<!-- origin: jira -->\n' >> "$ticket_file"
        printf '<!-- sync: synced -->\n\n' >> "$ticket_file"
        printf '%s\n' "$note_text" >> "$ticket_file"

        # Update existing_note_ids for subsequent dedup within this call
        existing_note_ids="${existing_note_ids}
${note_id}"

        ((added++))
    done <<< "$parsed_comments"

    if [[ $added -gt 0 ]]; then
        echo "pulled $added comment(s) as notes" >&2
    fi

    # Output count to stdout so callers can capture it
    echo "$added"
    return 0
}

# ---------------------------------------------------------------------------
# _sync_fetch_and_pull_comments <jira_issue_json> <ticket_file> <jira_key> <context_label>
#
# Checks whether jira_issue_json contains a comments field; if not, falls back
# to fetching via `acli jira workitem view`. Then delegates to _sync_pull_comments.
# Prints the number of comments pulled to stdout.
# ---------------------------------------------------------------------------
_sync_fetch_and_pull_comments() {
    local jira_issue_json="$1" ticket_file="$2" jira_key="$3" context_label="$4"

    local _comment_json="$jira_issue_json"
    # If search data lacks comments field, fetch via view
    local _has_comments
    _has_comments=$(echo "$jira_issue_json" | python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
c = d.get('fields', {}).get('comment')
print('yes' if c is not None else 'no')
" 2>/dev/null || echo "no")
    if [[ "$_has_comments" == "no" ]]; then
        local _view_json=""
        _view_json=$(acli jira workitem view "$jira_key" --json 2>/dev/null) || _view_json=""
        if [[ -n "$_view_json" ]]; then
            _comment_json="$_view_json"
        fi
    fi
    local _pulled=0
    _pulled=$(_sync_pull_comments "$_comment_json" "$ticket_file") || {
        echo "warning: comment pull failed for $jira_key ($context_label)" >&2
        echo "0"
        return 0
    }
    echo "$_pulled"
}

# ---------------------------------------------------------------------------
# _resolve_main_repo_root
#
# Returns the absolute path to the main repo root, even when called from a
# worktree.  Errors on non-git directory (never falls back to ".").
# ---------------------------------------------------------------------------
_resolve_main_repo_root() {
    local repo_root git_common_dir main_root=""
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
        echo "Error: not inside a git repository" >&2
        return 1
    }
    git_common_dir=$(git -C "$repo_root" rev-parse --git-common-dir 2>/dev/null) || { echo "$repo_root"; return; }
    if [[ -n "$git_common_dir" ]]; then
        case "$git_common_dir" in
            /*) main_root=$(dirname "$git_common_dir") ;;
            *)  main_root=$(dirname "$repo_root/$git_common_dir") ;;
        esac
    fi
    main_root="${main_root:-$repo_root}"
    # Canonicalize to remove /../ segments for readable output
    (cd "$main_root" 2>/dev/null && pwd) || echo "$main_root"
}

# ---------------------------------------------------------------------------
# _jira_key_num
#
# Extract the numeric suffix from a Jira key (e.g., "LLD2L-42" -> "42").
# ---------------------------------------------------------------------------
_jira_key_num() { echo "$1" | grep -oE '[0-9]+$'; }

# ---------------------------------------------------------------------------
# _sync_diff_changed_tickets
#
# Returns newline-separated list of changed .tickets/*.md file paths since
# the given base SHA.  Uses git diff-tree for tree-object comparison (NOT
# ancestry-based git diff) so it correctly handles cross-worktree detached-
# index commits that are NOT ancestors of HEAD.
#
# Args:
#   $1 - base_sha: the commit SHA to diff against
#   $2 - tickets_dir: absolute path to the .tickets/ directory
#
# Output: full paths (one per line) of changed .md files, or ALL .md files
#         on fallback (invalid SHA / missing tree).
# ---------------------------------------------------------------------------
_sync_diff_changed_tickets() {
    local base_sha="$1"
    local tickets_dir="$2"

    # Resolve tree objects for .tickets/ subtree at each point
    local base_tree head_tree
    base_tree=$(git rev-parse --verify "$base_sha:.tickets" 2>/dev/null) || true
    head_tree=$(git rev-parse --verify "HEAD:.tickets" 2>/dev/null) || true

    if [[ -z "$base_tree" || -z "$head_tree" ]]; then
        # Fallback: return ALL .tickets/*.md files
        for f in "$tickets_dir"/*.md; do
            [[ -f "$f" ]] && echo "$f"
        done
        return 0
    fi

    # Compare tree objects directly — works regardless of commit ancestry
    git diff-tree -r --name-only --diff-filter=ACMRD "$base_tree" "$head_tree" \
        | grep '\.md$' \
        | while IFS= read -r name; do
            echo "$tickets_dir/$name"
        done

    return 0
}

# ---------------------------------------------------------------------------
# _sync_body
#
# Core push/pull sync logic.  Reads $include_closed, $force_local,
# $tickets_dir, and $ledger_file from cmd_sync()'s dynamic scope.
# ---------------------------------------------------------------------------
_sync_body() {
    # ── Hook coordination: prevent ticket-sync-push.sh from creating ──────
    # ── intermediate commits that corrupt the diff base ───────────────────
    export TK_SYNC_SKIP_WORKTREE_PUSH=1

    # ── Diff-scoped incremental push: read prior state ────────────────────
    local _last_sync_sha=""
    _last_sync_sha=$(_sync_state_read "$ledger_file" last_sync_commit)

    local _incremental_mode=0
    local _changed_files_tmp=""
    local _total_ticket_count=0

    if [[ "${_sync_full_mode:-0}" -eq 1 ]]; then
        echo "tk sync: --full requested — performing full sync (bypassing incremental logic)" >&2
    elif [[ -n "$_last_sync_sha" ]] && git rev-parse --verify "${_last_sync_sha}^{commit}" &>/dev/null; then
        _changed_files_tmp=$(mktemp "${TMPDIR:-/tmp}/tk-sync-changed.XXXXXX")
        _sync_diff_changed_tickets "$_last_sync_sha" "$tickets_dir" > "$_changed_files_tmp"
        _incremental_mode=1
    else
        if [[ -n "$_last_sync_sha" ]]; then
            echo "tk sync: invalid prior state SHA — performing full push (auto-fallback)" >&2
        else
            echo "tk sync: no prior state — performing full push" >&2
        fi
    fi

    # ── Windowed pull: fetch only Jira issues updated since last pull ────
    local _last_pull_timestamp=""
    if [[ "${_sync_full_mode:-0}" -ne 1 ]]; then
        _last_pull_timestamp=$(_sync_state_read "$ledger_file" "last_pull_timestamp")
    fi

    local _pull_jql=""
    if [[ -n "$_last_pull_timestamp" ]]; then
        # Apply 15-minute overlap buffer to account for clock skew
        local _buffered_ts
        _buffered_ts=$(LAST_PULL_TS="$_last_pull_timestamp" python3 -c "import os; from datetime import datetime, timedelta; t=datetime.fromisoformat(os.environ['LAST_PULL_TS']); print((t - timedelta(minutes=15)).strftime('%Y-%m-%d %H:%M'))" 2>/dev/null) || _buffered_ts=""
        if [[ -n "$_buffered_ts" ]]; then
            _pull_jql="project=$JIRA_PROJECT AND updated >= \"$_buffered_ts\" ORDER BY created ASC"
        else
            echo "warning: failed to compute buffered timestamp — falling back to full pull" >&2
            _pull_jql="project=$JIRA_PROJECT ORDER BY created ASC"
        fi
    else
        # First run or no state — full pull (identical to previous behavior)
        _pull_jql="project=$JIRA_PROJECT ORDER BY created ASC"
    fi

    local _windowed_jira_issues=""
    local _pull_fetch_exit=0
    _windowed_jira_issues=$(acli jira workitem search \
        --jql "$_pull_jql" \
        --paginate --json 2>/dev/null) || _pull_fetch_exit=$?
    if [[ $_pull_fetch_exit -ne 0 || -z "$_windowed_jira_issues" ]]; then
        echo "warning: failed to fetch Jira issues (exit=$_pull_fetch_exit) — pull phase will be skipped" >&2
        _windowed_jira_issues=""
    fi

    # ── Session-level comment pull counters (accumulated by _sync_pull_ticket) ──
    _sync_session_comments=0
    _sync_session_comment_tickets=0

    # ── Push all tickets ─────────────────────────────────────────────────────
    local sync_failures=0
    local sync_conflicts=0
    local sync_forced=0

    # Two-pass push: parents first, then children.
    local _push_parents=() _push_children=()
    for ticket_file in "$tickets_dir"/*.md; do
        [[ -f "$ticket_file" ]] || continue

        # Skip lock issues (agent-batch-lifecycle markers)
        local t_title
        t_title=$(awk '/^# /{sub(/^# /,""); print; exit}' "$ticket_file")
        if [[ "$t_title" == \[LOCK\]* ]]; then
            continue
        fi

        local t_status
        t_status=$(awk '/^---$/{n++; next} n==1 && /^status:/{print; exit}' "$ticket_file" \
            | sed 's/^status:[[:space:]]*//')

        if [[ "$t_status" == "closed" && $include_closed -eq 0 ]]; then
            continue
        fi

        local t_parent
        t_parent=$(awk '/^---$/{n++; next} n==1 && /^parent:/{print; exit}' "$ticket_file" \
            | sed 's/^parent:[[:space:]]*//')
        if [[ -n "$t_parent" ]]; then
            _push_children+=("$ticket_file")
        else
            _push_parents+=("$ticket_file")
        fi
    done

    # ── Incremental filter: narrow push lists to changed files only ──────
    _total_ticket_count=$(( ${#_push_parents[@]} + ${#_push_children[@]} ))
    if [[ $_incremental_mode -eq 1 ]]; then
        local _filtered_parents=() _filtered_children=()
        for ticket_file in "${_push_parents[@]+"${_push_parents[@]}"}"; do
            if grep -qxF "$ticket_file" "$_changed_files_tmp"; then
                _filtered_parents+=("$ticket_file")
            fi
        done
        for ticket_file in "${_push_children[@]+"${_push_children[@]}"}"; do
            if grep -qxF "$ticket_file" "$_changed_files_tmp"; then
                _filtered_children+=("$ticket_file")
            fi
        done
        _push_parents=("${_filtered_parents[@]+"${_filtered_parents[@]}"}")
        _push_children=("${_filtered_children[@]+"${_filtered_children[@]}"}")
        local _changed_count=$(( ${#_push_parents[@]} + ${#_push_children[@]} ))
        echo "tk sync: pushing $_changed_count changed tickets (of $_total_ticket_count total)" >&2
        rm -f "$_changed_files_tmp"
    fi

    # Pass 1: push parent tickets
    for ticket_file in "${_push_parents[@]+"${_push_parents[@]}"}"; do
        local _push_exit=0
        _sync_push_ticket "$ticket_file" "$ledger_file" || _push_exit=$?
        touch "${SYNC_HEARTBEAT_FILE:-}" 2>/dev/null || true
        if [[ $_push_exit -eq 3 ]]; then
            ((sync_conflicts++))
        elif [[ $_push_exit -eq 4 ]]; then
            ((sync_forced++))
        elif [[ $_push_exit -ne 0 ]]; then
            ((sync_failures++))
        fi
    done

    # Pass 2: push child tickets
    for ticket_file in "${_push_children[@]+"${_push_children[@]}"}"; do
        local _push_exit=0
        _sync_push_ticket "$ticket_file" "$ledger_file" || _push_exit=$?
        touch "${SYNC_HEARTBEAT_FILE:-}" 2>/dev/null || true
        if [[ $_push_exit -eq 3 ]]; then
            ((sync_conflicts++))
        elif [[ $_push_exit -eq 4 ]]; then
            ((sync_forced++))
        elif [[ $_push_exit -ne 0 ]]; then
            ((sync_failures++))
        fi
    done

    if [[ $sync_failures -gt 0 ]]; then
        echo "tk sync: $sync_failures ticket(s) failed to sync" >&2
    fi
    if [[ $sync_forced -gt 0 ]]; then
        echo "tk sync: $sync_forced conflict(s) resolved (forced local)" >&2
    fi
    if [[ $sync_conflicts -gt 0 ]]; then
        echo "tk sync: $sync_conflicts conflict(s) skipped (use TTY or --force-local to resolve)" >&2
    fi

    # ── Pull Jira issues (windowed or full depending on state) ─────────────
    local pull_failures=0

    if [[ -n "$_windowed_jira_issues" ]]; then
        local issue_count
        issue_count=$(echo "$_windowed_jira_issues" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))" 2>/dev/null || echo 0)
        if [[ "$issue_count" -gt 0 ]]; then
            while IFS= read -r issue_json; do
                local _pull_exit=0
                _sync_pull_ticket "$issue_json" "$ledger_file" "$tickets_dir" || _pull_exit=$?
                touch "${SYNC_HEARTBEAT_FILE:-}" 2>/dev/null || true
                if [[ $_pull_exit -eq 3 ]]; then
                    ((sync_conflicts++))
                elif [[ $_pull_exit -eq 4 ]]; then
                    ((sync_forced++))
                elif [[ $_pull_exit -ne 0 ]]; then
                    ((pull_failures++))
                fi
            done < <(echo "$_windowed_jira_issues" | python3 -c "import json,sys; [print(json.dumps(i)) for i in json.load(sys.stdin)]")
        fi
    fi

    if [[ $pull_failures -gt 0 ]]; then
        echo "tk sync: $pull_failures pull failure(s)" >&2
    fi

    # ── Post-sync observability ───────────────────────────────────────────
    # Report comments pulled during this session (not cumulative)
    if [[ $_sync_session_comments -gt 0 ]]; then
        echo "tk sync: $_sync_session_comments comments pulled across $_sync_session_comment_tickets tickets" >&2
    fi

    local ledger_count jira_count
    ledger_count=$(LEDGER_FILE="$ledger_file" python3 -c "
import json, os
print(len(json.load(open(os.environ['LEDGER_FILE']))))
" 2>/dev/null || echo "?")
    jira_count=$(echo "$_windowed_jira_issues" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "?")
    if [[ -n "$_last_pull_timestamp" ]]; then
        echo "tk sync: ledger=$ledger_count entries, jira=$jira_count issues (windowed since $_last_pull_timestamp)" >&2
        # Orphan detection is not meaningful in windowed mode — windowed count is a subset
    else
        echo "tk sync: ledger=$ledger_count entries, jira=$jira_count issues (full pull)" >&2
        if [[ "$ledger_count" != "?" && "$jira_count" != "?" ]] && (( jira_count > ledger_count )); then
            echo "warning: Jira has more issues ($jira_count) than ledger ($ledger_count) — investigate for orphans or duplicates" >&2
        fi
    fi

    # Clean up temp files
    rm -f "${_changed_files_tmp:-}"

    # ── Write state after successful sync ─────────────────────────────────
    if [[ $sync_failures -eq 0 && $pull_failures -eq 0 ]]; then
        _sync_state_write "$ledger_file" last_sync_commit "$(git rev-parse HEAD)"
        _sync_state_write "$ledger_file" last_pull_timestamp "$(date -u +%FT%TZ)"
    fi

    # ── Unset hook coordination flag ──────────────────────────────────────
    unset TK_SYNC_SKIP_WORKTREE_PUSH

    if [[ $sync_failures -gt 0 ]] || [[ $pull_failures -gt 0 ]]; then
        return 1
    fi

    if [[ ${sync_conflicts:-0} -gt 0 ]]; then
        return 2
    fi

    return 0
}

# ---------------------------------------------------------------------------
# Local sync lock via mkdir
# ---------------------------------------------------------------------------
# Uses mkdir for atomic lock creation and mv for atomic stale recovery.
# State file: PID + epoch. Stale if kill -0 PID fails or epoch > threshold.
# POSIX-portable (no flock).

LOCAL_LOCK_STALE_SECONDS=300   # 5 minutes
LOCAL_LOCK_DIR=""              # Set by _local_lock_acquire; read by _local_lock_release
LOCAL_LOCK_NAME="tk-sync.lock" # Lock path: mkdir $git_common_dir/tk-sync.lock

# _local_lock_is_stale <lock_dir>
# Returns 0 (stale) if state file missing, PID dead, or epoch too old.
# Returns 1 (not stale) if process alive AND epoch recent.
_local_lock_is_stale() {
    local lock_dir="$1"
    local state_file="$lock_dir/state"

    # Missing or empty state file → stale
    if [[ ! -s "$state_file" ]]; then
        return 0
    fi

    local lock_pid="" lock_epoch=""
    lock_pid=$(grep '^PID=' "$state_file" 2>/dev/null | cut -d= -f2)
    lock_epoch=$(grep '^EPOCH=' "$state_file" 2>/dev/null | cut -d= -f2)

    # Missing fields → stale
    if [[ -z "$lock_pid" ]] || [[ -z "$lock_epoch" ]]; then
        return 0
    fi

    # Dead PID → stale
    if ! kill -0 "$lock_pid" 2>/dev/null; then
        return 0
    fi

    # Old epoch → stale
    local now_epoch age
    now_epoch=$(date +%s)
    age=$(( now_epoch - lock_epoch ))
    if (( age > LOCAL_LOCK_STALE_SECONDS )); then
        return 0
    fi

    # Process alive and epoch recent → not stale
    return 1
}

# _write_local_lock_state <lock_dir>
# Writes PID and epoch to <lock_dir>/state.
_write_local_lock_state() {
    local lock_dir="$1"
    printf 'PID=%s\nEPOCH=%s\n' "$$" "$(date +%s)" > "$lock_dir/state"
}

# _local_lock_release [lock_dir]
# Removes lock directory. Idempotent (no error if absent).
# If lock_dir omitted, uses LOCAL_LOCK_DIR global.
_local_lock_release() {
    local lock_dir="${1:-$LOCAL_LOCK_DIR}"
    if [[ -n "$lock_dir" ]]; then
        rm -rf "$lock_dir"
    fi
    # Clear EXIT trap installed by _local_lock_acquire
    trap - EXIT
    return 0
}

# _local_lock_acquire [lock_dir]
# Acquires local lock via mkdir (atomic on POSIX).
# Returns 0 on success, 1 on failure (lock held by live process).
_local_lock_acquire() {
    local lock_dir="${1:-}"

    # Default: use git-common-dir
    if [[ -z "$lock_dir" ]]; then
        local git_common_dir
        git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || {
            echo "error: _local_lock_acquire: git rev-parse --git-common-dir failed" >&2
            return 1
        }
        lock_dir="$git_common_dir/$LOCAL_LOCK_NAME"
    fi

    LOCAL_LOCK_DIR="$lock_dir"
    local max_retries=2
    local attempt=0

    while (( attempt <= max_retries )); do
        # Try atomic mkdir
        if mkdir "$lock_dir" 2>/dev/null; then
            _write_local_lock_state "$lock_dir"
            # Install EXIT trap for cleanup on abnormal exit
            trap '_local_lock_release' EXIT
            return 0
        fi

        # mkdir failed — lock dir exists
        if ! _local_lock_is_stale "$lock_dir"; then
            # Lock held by live process
            return 1
        fi

        # Stale lock — attempt atomic recovery via mv
        local stale_dir="${lock_dir}.stale.$$"
        # Clean up any pre-existing .stale dir from a previous attempt
        rm -rf "$stale_dir" 2>/dev/null

        if mv "$lock_dir" "$stale_dir" 2>/dev/null; then
            # Successfully moved stale lock aside
            rm -rf "$stale_dir" 2>/dev/null
        else
            # mv failed — concurrent recovery race; sleep and retry
            sleep 1
        fi

        (( attempt++ ))
    done

    # Exhausted retries
    return 1
}

# ---------------------------------------------------------------------------
# Distributed sync lock constants and globals
# ---------------------------------------------------------------------------

TK_SYNC_ATTRIBUTION="Posted by tk sync"   # Anti-echo marker for comment pull/push coordination
SYNC_TIMEOUT_SECONDS=1800       # 30-minute overall timeout
_SYNC_WATCHDOG_PID=""   # Global — watchdog PID for cleanup in traps

# ---------------------------------------------------------------------------
# --- CAS lock primitives (refs/tk/sync-lock) ---
# Uses a git ref (not a file in the tree) as a distributed lock.
# All mutations use --force-with-lease with explicit expected value.
# INVARIANT: never bare-force, never unguarded-delete on the lock ref.
# Exit codes: 0 = success, 1 = CAS rejection (contention, safe to retry),
#             2 = network/git error (caller must fail immediately).
# ---------------------------------------------------------------------------

SYNC_LOCK_CAS_REF="refs/tk/sync-lock"
SYNC_LOCK_STALE_THRESHOLD=1800      # 30 minutes
SYNC_LOCK_ACQUIRE_TIMEOUT=300       # 5 minutes total
SYNC_LOCK_INITIAL_BACKOFF_V2=1      # seconds
SYNC_LOCK_MAX_BACKOFF_V2=30         # seconds max backoff
_HELD_LOCK_SHA=""                    # Global — set by acquire_v2, read by release_v2

# _git_ref_lock_write_metadata
# Creates a git blob containing lock metadata and returns its SHA.
# Args: repo_root
# Outputs: blob SHA on stdout
_git_ref_lock_write_metadata() {
    local repo_root="$1"
    local _hostname _pid _session_id _timestamp metadata
    _hostname=$(hostname 2>/dev/null || echo unknown)
    _pid=$$
    _session_id="${CLAUDE_SESSION_ID:-$(uuidgen 2>/dev/null || echo unknown)}"
    _timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    metadata=$(printf 'hostname=%s\npid=%s\nsession_id=%s\ntimestamp=%s\n' \
        "$_hostname" "$_pid" "$_session_id" "$_timestamp")
    echo "$metadata" | git -C "$repo_root" hash-object -w --stdin 2>/dev/null || return 2
}

# _git_ref_cas_create <repo_root>
# Creates refs/tk/sync-lock on origin when the ref does not exist.
# Uses --force-with-lease with empty expected value (ref must not exist).
# Outputs: the new commit SHA on stdout.
# Exit: 0 = created, 1 = CAS rejection (ref already exists), 2 = git/network error.
_git_ref_cas_create() {
    local repo_root="$1"

    # Create metadata blob
    local blob_sha
    blob_sha=$(_git_ref_lock_write_metadata "$repo_root") || return 2

    # Create tree containing the blob
    local tree_sha
    tree_sha=$(printf '100644 blob %s\tsync-lock\n' "$blob_sha" | git -C "$repo_root" mktree 2>/dev/null) || return 2

    # Create commit (no parent — this is a standalone ref)
    local commit_sha
    commit_sha=$(git -C "$repo_root" commit-tree "$tree_sha" -m "chore: acquire sync lock [skip ci]" 2>/dev/null) || return 2

    # Push with --force-with-lease expecting empty (ref must not exist)
    local push_output push_exit=0
    push_output=$(git -C "$repo_root" push origin \
        "$commit_sha:$SYNC_LOCK_CAS_REF" \
        --force-with-lease="$SYNC_LOCK_CAS_REF:" \
        2>&1) || push_exit=$?

    if [[ "$push_exit" -eq 0 ]]; then
        echo "$commit_sha"
        return 0
    fi

    # Distinguish CAS rejection from network/git error
    if echo "$push_output" | grep -qiE 'stale info|failed to push|rejected|fetch first|lock|lease'; then
        return 1  # CAS rejection — safe to retry
    fi

    # Network or other git error
    return 2
}

# _git_ref_cas_replace <repo_root> <expected_sha>
# Atomically replaces refs/tk/sync-lock using --force-with-lease with explicit expected value.
# Used for stale lock recovery: the caller provides the SHA they read, and this
# replaces it with a new lock blob only if the ref still points to that SHA.
# Outputs: the new commit SHA on stdout.
# Exit: 0 = replaced, 1 = CAS rejection (ref changed), 2 = git/network error.
_git_ref_cas_replace() {
    local repo_root="$1" expected_sha="$2"

    # Create new metadata blob
    local blob_sha
    blob_sha=$(_git_ref_lock_write_metadata "$repo_root") || return 2

    # Create tree
    local tree_sha
    tree_sha=$(printf '100644 blob %s\tsync-lock\n' "$blob_sha" | git -C "$repo_root" mktree 2>/dev/null) || return 2

    # Create commit (no parent — standalone ref)
    local commit_sha
    commit_sha=$(git -C "$repo_root" commit-tree "$tree_sha" -m "chore: replace stale sync lock [skip ci]" 2>/dev/null) || return 2

    # Push with --force-with-lease expecting the old SHA
    local push_output push_exit=0
    push_output=$(git -C "$repo_root" push origin \
        "$commit_sha:$SYNC_LOCK_CAS_REF" \
        --force-with-lease="$SYNC_LOCK_CAS_REF:$expected_sha" \
        2>&1) || push_exit=$?

    if [[ "$push_exit" -eq 0 ]]; then
        echo "$commit_sha"
        return 0
    fi

    # Distinguish CAS rejection from network/git error
    if echo "$push_output" | grep -qiE 'stale info|failed to push|rejected|fetch first|lock|lease'; then
        return 1  # CAS rejection
    fi

    return 2
}

# _git_ref_cas_release <repo_root> <held_sha>
# Deletes refs/tk/sync-lock using --force-with-lease with the held SHA.
# Idempotent: returns 0 when ref is already absent.
# Exit: 0 = deleted or already absent, 1 = CAS rejection, 2 = git/network error.
_git_ref_cas_release() {
    local repo_root="$1" held_sha="$2"

    # Check if ref exists on origin first
    local remote_sha
    remote_sha=$(git -C "$repo_root" ls-remote origin "$SYNC_LOCK_CAS_REF" 2>/dev/null | awk '{print $1}') || {
        # ls-remote failed — network/git error; return 2 per documented contract
        return 2
    }

    # Ref not found — already absent, idempotent success
    if [[ -z "$remote_sha" ]]; then
        return 0
    fi

    # Delete with --force-with-lease (CAS delete) — both flags on same push
    local push_output push_exit=0
    push_output=$(git -C "$repo_root" push origin --force-with-lease="$SYNC_LOCK_CAS_REF:$held_sha" --delete "$SYNC_LOCK_CAS_REF" 2>&1) || push_exit=$?

    if [[ "$push_exit" -eq 0 ]]; then
        return 0
    fi

    # Distinguish CAS rejection from network/git error
    if echo "$push_output" | grep -qiE 'stale info|failed to push|rejected|fetch first|lock|lease'; then
        return 1
    fi

    return 2
}

# _git_ref_read_lock <repo_root>
# Fetches refs/tk/sync-lock state from origin.
# Distinguishes: (a) ref not found = exit 0, empty stdout,
#                (b) ref exists = exit 0, metadata on stdout,
#                (c) network error = exit 1.
_git_ref_read_lock() {
    local repo_root="$1"

    # Use ls-remote to check if ref exists (network operation)
    local ls_output ls_exit=0
    ls_output=$(git -C "$repo_root" ls-remote origin "$SYNC_LOCK_CAS_REF" 2>/dev/null) || ls_exit=$?

    if [[ "$ls_exit" -ne 0 ]]; then
        # ls-remote failed — network error or git error
        echo "error: could not read ref $SYNC_LOCK_CAS_REF from origin (ls-remote failed)" >&2
        return 1
    fi

    local ref_sha
    ref_sha=$(echo "$ls_output" | awk '{print $1}')

    # Ref not found — exit 0 with empty output
    if [[ -z "$ref_sha" ]]; then
        return 0
    fi

    # Fetch the specific commit so we can read its tree (no --force needed;
    # we fetch into FETCH_HEAD to avoid updating any local ref).
    git -C "$repo_root" fetch origin "$ref_sha" 2>/dev/null || {
        echo "error: could not fetch commit $ref_sha for $SYNC_LOCK_CAS_REF" >&2
        return 1
    }

    # Read the blob from the commit tree
    local tree_sha
    tree_sha=$(git -C "$repo_root" rev-parse "${ref_sha}^{tree}" 2>/dev/null) || {
        echo "error: not a valid commit at $SYNC_LOCK_CAS_REF" >&2
        return 1
    }

    # Get the sync-lock blob from the tree
    local blob_sha
    blob_sha=$(git -C "$repo_root" ls-tree "$tree_sha" sync-lock 2>/dev/null | awk '{print $3}')

    if [[ -z "$blob_sha" ]]; then
        echo "error: could not read sync-lock blob from tree" >&2
        return 1
    fi

    git -C "$repo_root" cat-file -p "$blob_sha" 2>/dev/null || {
        echo "error: could not read blob content" >&2
        return 1
    }

    return 0
}

# _sync_lock_acquire_v2 <repo_root>
# High-level acquire: read -> create if absent, replace if stale.
# Exponential backoff 1s -> 30s, 5min total timeout.
# Fails immediately on network error (exit 2 from primitives).
# Outputs: held lock SHA on stdout.
# Sets _HELD_LOCK_SHA global.
# Exit: 0 = acquired, 1 = timeout/contention, 2 = network/git error.
_sync_lock_acquire_v2() {
    local repo_root="$1"
    local start_epoch
    start_epoch=$(date +%s)
    local backoff="$SYNC_LOCK_INITIAL_BACKOFF_V2"

    while true; do
        local elapsed=$(( $(date +%s) - start_epoch ))
        if (( elapsed >= SYNC_LOCK_ACQUIRE_TIMEOUT )); then
            echo "error: could not acquire sync lock after ${SYNC_LOCK_ACQUIRE_TIMEOUT}s" >&2
            return 1
        fi

        # Try to create (ref absent case)
        local create_sha="" create_exit=0
        create_sha=$(_git_ref_cas_create "$repo_root" 2>/dev/null) || create_exit=$?

        if [[ "$create_exit" -eq 0 ]]; then
            _HELD_LOCK_SHA="$create_sha"
            echo "$create_sha"
            return 0
        elif [[ "$create_exit" -eq 2 ]]; then
            echo "error: network/git error during lock create" >&2
            return 2
        fi

        # CAS rejection (exit 1) — ref exists. Read it to check staleness.
        local lock_metadata="" read_exit=0
        lock_metadata=$(_git_ref_read_lock "$repo_root" 2>/dev/null) || read_exit=$?

        if [[ "$read_exit" -ne 0 ]]; then
            echo "error: network error reading lock state" >&2
            return 2
        fi

        if [[ -z "$lock_metadata" ]]; then
            # Ref disappeared between create and read — retry immediately
            continue
        fi

        # Check if stale
        local lock_ts
        lock_ts=$(echo "$lock_metadata" | grep '^timestamp=' | cut -d= -f2-)

        if [[ -n "$lock_ts" ]]; then
            local lock_epoch now_epoch age
            lock_epoch=$(date -juf "%Y-%m-%dT%H:%M:%SZ" "$lock_ts" +%s 2>/dev/null || \
                         date -d "$lock_ts" +%s 2>/dev/null || echo 0)
            now_epoch=$(date +%s)
            age=$(( now_epoch - lock_epoch ))

            if (( age > SYNC_LOCK_STALE_THRESHOLD )); then
                # Stale — try CAS replace
                local current_sha
                current_sha=$(git -C "$repo_root" ls-remote origin "$SYNC_LOCK_CAS_REF" 2>/dev/null | awk '{print $1}')
                if [[ -n "$current_sha" ]]; then
                    local replace_sha="" replace_exit=0
                    replace_sha=$(_git_ref_cas_replace "$repo_root" "$current_sha" 2>/dev/null) || replace_exit=$?

                    if [[ "$replace_exit" -eq 0 ]]; then
                        echo "info: recovered stale sync lock (age=${age}s)" >&2
                        _HELD_LOCK_SHA="$replace_sha"
                        echo "$replace_sha"
                        return 0
                    elif [[ "$replace_exit" -eq 2 ]]; then
                        echo "error: network/git error during stale lock recovery" >&2
                        return 2
                    fi
                    # CAS rejection on replace — someone else beat us, retry
                fi
            fi
        fi

        # Non-stale lock or CAS rejection on replace — backoff and retry
        local lock_holder
        lock_holder=$(echo "$lock_metadata" | grep '^hostname=' | cut -d= -f2-)
        echo "warning: sync lock held by ${lock_holder:-unknown} — retrying in ${backoff}s" >&2
        sleep "$backoff"

        # Exponential backoff with cap
        backoff=$(( backoff * 2 ))
        (( backoff > SYNC_LOCK_MAX_BACKOFF_V2 )) && backoff="$SYNC_LOCK_MAX_BACKOFF_V2"
    done
}

# _sync_lock_release_v2 <repo_root> <held_sha>
# High-level release: CAS delete with held SHA.
# Clears _HELD_LOCK_SHA global.
# Exit: 0 = released, non-zero = failed (lock will expire via stale threshold).
_sync_lock_release_v2() {
    local repo_root="$1" held_sha="$2"
    _HELD_LOCK_SHA=""  # Clear first to prevent double-release
    _git_ref_cas_release "$repo_root" "$held_sha"
}

# --- End CAS lock primitives ---

# _sync_lock_break [repo_root]
# Interactively break a stuck CAS sync lock (refs/tk/sync-lock).
# Fetches lock metadata, displays it, prompts for confirmation via /dev/tty,
# then performs a CAS delete using the specific SHA read at fetch time.
# Exit: 0 = lock broken or no lock, 1 = aborted/failed/non-interactive.
_sync_lock_break() {
    local repo_root="${1:-}"
    if [[ -z "$repo_root" ]]; then
        repo_root=$(_resolve_main_repo_root) || {
            echo "error: could not resolve main repo root" >&2
            return 1
        }
    fi

    # Read current lock state from origin
    local lock_metadata="" read_exit=0
    lock_metadata=$(_git_ref_read_lock "$repo_root") || read_exit=$?

    if [[ "$read_exit" -ne 0 ]]; then
        echo "error: could not read lock state from origin" >&2
        return 1
    fi

    if [[ -z "$lock_metadata" ]]; then
        echo "No sync lock found." >&2
        return 0
    fi

    # Parse metadata fields
    local lock_hostname lock_pid lock_session lock_ts
    lock_hostname=$(echo "$lock_metadata" | grep '^hostname=' | cut -d= -f2-)
    lock_pid=$(echo "$lock_metadata" | grep '^pid=' | cut -d= -f2-)
    lock_session=$(echo "$lock_metadata" | grep '^session_id=' | cut -d= -f2-)
    lock_ts=$(echo "$lock_metadata" | grep '^timestamp=' | cut -d= -f2-)

    # Compute age
    local age_str="unknown"
    if [[ -n "$lock_ts" ]]; then
        local lock_epoch now_epoch age_secs
        lock_epoch=$(date -juf "%Y-%m-%dT%H:%M:%SZ" "$lock_ts" +%s 2>/dev/null || \
                     date -d "$lock_ts" +%s 2>/dev/null || echo 0)
        now_epoch=$(date +%s)
        age_secs=$(( now_epoch - lock_epoch ))
        local hours=$(( age_secs / 3600 ))
        local mins=$(( (age_secs % 3600) / 60 ))
        if (( hours > 0 )); then
            age_str="${hours} hour(s) ${mins} minute(s) ago"
        elif (( mins > 0 )); then
            age_str="${mins} minute(s) ago"
        else
            age_str="${age_secs} second(s) ago"
        fi
    fi

    local stale_label=""
    if [[ -n "$lock_ts" ]]; then
        local lock_epoch_chk now_epoch_chk age_chk
        lock_epoch_chk=$(date -juf "%Y-%m-%dT%H:%M:%SZ" "$lock_ts" +%s 2>/dev/null || \
                         date -d "$lock_ts" +%s 2>/dev/null || echo 0)
        now_epoch_chk=$(date +%s)
        age_chk=$(( now_epoch_chk - lock_epoch_chk ))
        if (( age_chk > SYNC_LOCK_STALE_THRESHOLD )); then
            stale_label=" (STALE)"
        fi
    fi

    # Display metadata
    echo "" >&2
    echo "=== Sync Lock Found${stale_label} ===" >&2
    echo "  Hostname:   ${lock_hostname:-unknown}" >&2
    echo "  PID:        ${lock_pid:-unknown}" >&2
    echo "  Session:    ${lock_session:-unknown}" >&2
    echo "  Timestamp:  ${lock_ts:-unknown}" >&2
    echo "  Age:        ${age_str}" >&2
    echo "" >&2

    # Get the current lock ref SHA for CAS delete
    local current_sha
    current_sha=$(git -C "$repo_root" ls-remote origin "$SYNC_LOCK_CAS_REF" 2>/dev/null | awk '{print $1}')
    if [[ -z "$current_sha" ]]; then
        echo "Lock disappeared before confirmation — nothing to break." >&2
        return 0
    fi

    # Interactive confirmation via /dev/tty (or stdin fallback)
    local confirm=""
    if [[ "${_SYNC_LOCK_BREAK_NON_INTERACTIVE:-}" == "1" ]]; then
        echo "error: cannot confirm lock break in non-interactive context (no /dev/tty)" >&2
        return 1
    fi

    printf "Break this lock? [y/N] " >&2
    if [[ -t 0 ]]; then
        # stdin is a terminal — read directly from it
        read -r confirm
    else
        # stdin is not a terminal. Try /dev/tty first (interactive piped context),
        # fall back to stdin (test context with <<< or pipe).
        if [[ -r /dev/tty ]] && read -r confirm < /dev/tty 2>/dev/null; then
            : # read from /dev/tty succeeded
        elif read -r confirm 2>/dev/null; then
            : # read from stdin succeeded (pipe/heredoc)
        else
            echo "error: cannot confirm lock break in non-interactive context (no /dev/tty)" >&2
            return 1
        fi
    fi

    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "Aborted — lock not broken." >&2
        return 1
    fi

    # CAS delete using the SHA we read earlier
    local release_exit=0
    _git_ref_cas_release "$repo_root" "$current_sha" || release_exit=$?

    if [[ "$release_exit" -eq 0 ]]; then
        echo "Sync lock broken successfully." >&2
        return 0
    elif [[ "$release_exit" -eq 1 ]]; then
        echo "error: could not break lock — it was modified concurrently (CAS failed). Retry --break-lock." >&2
        return 1
    else
        echo "error: could not break lock — network/git error" >&2
        return 1
    fi
}

_sync_with_lock() {
    local repo_root
    repo_root=$(_resolve_main_repo_root) || {
        echo "error: could not resolve main repo root" >&2
        return 1
    }

    # --- Layer 1: Local lock (prevents concurrent tk sync on this machine) ---
    _local_lock_acquire || {
        echo "error: another tk sync is running locally" >&2
        return 1
    }

    # Combined trap: releases both layers on abnormal exit.
    # Installed BEFORE distributed acquire so local lock is always cleaned up.
    # _sync_lock_release_v2 no-ops when _HELD_LOCK_SHA is empty, so this is
    # safe even if distributed acquire hasn't run yet.
    trap '_sync_lock_release_v2 "$repo_root" "$_HELD_LOCK_SHA" 2>/dev/null; _local_lock_release; rm -f "${SYNC_HEARTBEAT_FILE:-}"; kill $_SYNC_WATCHDOG_PID 2>/dev/null || true' EXIT
    trap '_sync_lock_release_v2 "$repo_root" "$_HELD_LOCK_SHA" 2>/dev/null; _local_lock_release; rm -f "${SYNC_HEARTBEAT_FILE:-}"; kill $_SYNC_WATCHDOG_PID 2>/dev/null || true; exit 130' INT
    trap '_sync_lock_release_v2 "$repo_root" "$_HELD_LOCK_SHA" 2>/dev/null; _local_lock_release; rm -f "${SYNC_HEARTBEAT_FILE:-}"; kill $_SYNC_WATCHDOG_PID 2>/dev/null || true; exit 143' TERM HUP

    # --- Layer 2: Distributed lock (prevents concurrent tk sync across machines) ---
    # Called directly (not in a subshell) so _HELD_LOCK_SHA global is set.
    _sync_lock_acquire_v2 "$repo_root" || {
        # Distributed acquire failed — explicitly release local lock and clear traps
        _local_lock_release
        trap - EXIT INT TERM HUP
        return 1
    }

    # Heartbeat-based watchdog: kills sync only if no per-ticket progress for
    # 120 seconds, allowing long-but-active syncs (200 tickets, 10+ minutes)
    # while still catching truly hung syncs promptly.
    SYNC_HEARTBEAT_FILE="/tmp/tk-sync-heartbeat-$$"
    touch "$SYNC_HEARTBEAT_FILE"
    (
        while true; do
            sleep 30
            if [[ ! -f "$SYNC_HEARTBEAT_FILE" ]]; then break; fi
            _hb_mtime=$(stat -f %m "$SYNC_HEARTBEAT_FILE" 2>/dev/null || echo 0)
            _hb_age=$(( $(date +%s) - _hb_mtime ))
            if [[ $_hb_age -gt 120 ]]; then
                echo "tk sync: heartbeat stale for ${_hb_age}s — killing hung sync" >&2
                kill -TERM $$ 2>/dev/null
                break
            fi
        done
    ) &
    _SYNC_WATCHDOG_PID=$!

    # Run sync body in foreground
    local sync_exit=0
    _sync_body "$@" || sync_exit=$?

    # Cancel watchdog and remove heartbeat file
    rm -f "$SYNC_HEARTBEAT_FILE"
    kill "$_SYNC_WATCHDOG_PID" 2>/dev/null || true
    wait "$_SYNC_WATCHDOG_PID" 2>/dev/null || true
    _SYNC_WATCHDOG_PID=""

    # Explicit release: distributed first, then local (reverse acquire order)
    _sync_lock_release_v2 "$repo_root" "$_HELD_LOCK_SHA"
    _local_lock_release
    trap - EXIT INT TERM HUP

    return $sync_exit
}

cmd_sync() {
    local check_only=0
    local include_closed=0
    local force_local=0
    local no_lock=0
    local _sync_full_mode=0
    local break_lock=0
    local arg

    # Parse flags
    for arg in "$@"; do
        case "$arg" in
            --check) check_only=1 ;;
            --include-closed) include_closed=1 ;;
            --force-local) force_local=1 ;;
            --no-lock) no_lock=1 ;;
            --full) _sync_full_mode=1 ;;
            --break-lock) break_lock=1 ;;
            --lock-timeout=*)
                local timeout_val="${arg#--lock-timeout=}"
                if ! [[ "$timeout_val" =~ ^[0-9]+$ ]] || [[ "$timeout_val" -le 0 ]]; then
                    echo "Error: --lock-timeout must be a positive integer (got '$timeout_val')" >&2
                    return 1
                fi
                SYNC_LOCK_ACQUIRE_TIMEOUT="$timeout_val"
                SYNC_TIMEOUT_SECONDS="$timeout_val"
                ;;
            *)
                echo "Error: unknown tk sync option: $arg" >&2
                echo "Usage: tk sync [--check] [--include-closed] [--force-local] [--no-lock] [--break-lock] [--lock-timeout=N] [--full]" >&2
                return 1
                ;;
        esac
    done

    # Mutual exclusion: --break-lock and --check cannot be combined
    if [[ $break_lock -eq 1 && $check_only -eq 1 ]]; then
        echo "Error: --break-lock and --check are mutually exclusive" >&2
        return 1
    fi

    # Export force-local flag so push/pull functions can read it without
    # changing their signatures (they're called per-ticket in loops).
    if [[ $force_local -eq 1 ]]; then
        export TK_SYNC_FORCE_LOCAL=1
    fi

    # ── --break-lock: call _sync_lock_break and exit (no sync body) ──────────
    if [[ $break_lock -eq 1 ]]; then
        _sync_lock_break
        return $?
    fi

    # ── Check 1: acli must be in PATH ────────────────────────────────────────
    if ! command -v acli &>/dev/null; then
        echo "Error: acli not found in PATH." >&2
        echo "Install acli (Atlassian CLI) and ensure it is in your PATH." >&2
        echo "See: https://acli.atlassian.com/" >&2
        return 1
    fi

    # ── Resolve JIRA_PROJECT: env var > workflow-config.yaml > error ─────────
    if [[ -z "${JIRA_PROJECT:-}" ]]; then
        local _cfg_project=""
        local _read_config="$(git rev-parse --show-toplevel 2>/dev/null)/lockpick-workflow/scripts/read-config.sh"
        if [[ -x "$_read_config" ]]; then
            _cfg_project=$("$_read_config" "jira.project" 2>/dev/null) || true
        fi
        if [[ -n "$_cfg_project" ]]; then
            JIRA_PROJECT="$_cfg_project"
        fi
    fi

    # ── Check 2: JIRA_PROJECT must be resolved ────────────────────────────────
    if [[ -z "${JIRA_PROJECT:-}" ]]; then
        echo "Error: JIRA_PROJECT is not set." >&2
        echo "Set it via env var or add jira.project to workflow-config.yaml:" >&2
        echo "  export JIRA_PROJECT=MYPROJECT" >&2
        echo "  # or in workflow-config.yaml:" >&2
        echo "  # jira:" >&2
        echo "  #   project: MYPROJECT" >&2
        return 1
    fi

    # ── Check 3: acli authenticated and project accessible ───────────────────
    local check_output
    local check_exit=0
    check_output=$(acli jira workitem search \
        --jql "project=$JIRA_PROJECT ORDER BY created DESC" \
        --limit 1 2>&1) || check_exit=$?

    if [[ $check_exit -ne 0 ]]; then
        # Detect auth vs project errors without leaking credentials
        if echo "$check_output" | grep -qiE "authenticat|login|credential|unauthorized|401"; then
            echo "Error: acli is not authenticated." >&2
            echo "Run 'acli jira login' to authenticate, then retry." >&2
        else
            echo "Error: Jira project '$JIRA_PROJECT' is not accessible." >&2
            echo "Verify JIRA_PROJECT is correct and you have access." >&2
        fi
        return 1
    fi

    # ── Resolve ledger path (before check_only so --check shows it) ─────────
    local main_root tickets_dir ledger_file
    main_root=$(_resolve_main_repo_root) || return 1
    ledger_file="${SYNC_STATE_FILE:-$main_root/.tickets/.sync-state.json}"

    # Pre-sync observability: show ledger source
    local ledger_entry_count
    ledger_entry_count=$(LEDGER_FILE="$ledger_file" python3 -c "
import json, os
try: print(len(json.load(open(os.environ['LEDGER_FILE']))))
except: print('?')
" 2>/dev/null || echo "?")
    echo "tk sync: using ledger $ledger_file ($ledger_entry_count entries)" >&2

    # ── Resolve tickets directory (before check_only so drift check can use it)
    if [[ -n "${TICKETS_DIR:-}" ]]; then
        tickets_dir="$TICKETS_DIR"
    else
        tickets_dir=$(find_tickets_dir 2>/dev/null) || tickets_dir=".tickets"
    fi

    if [[ $check_only -eq 1 ]]; then
        echo "OK: acli found, authenticated, and project '$JIRA_PROJECT' is accessible."
        # Run drift check after connectivity verification
        local drift_output="" drift_exit=0
        drift_output=$(_sync_drift_check "$tickets_dir" "$ledger_file" 2>&1) || drift_exit=$?
        if [[ $drift_exit -eq 0 ]]; then
            # Extract checked count from drift output
            local checked_n
            checked_n=$(echo "$drift_output" | grep -oE 'Checked [0-9]+ tickets' | grep -oE '[0-9]+') || checked_n="0"
            echo "Drift check: no drift detected ($checked_n tickets checked)"
            return 0
        else
            # Print drift report lines, then summary
            echo "$drift_output" | grep "^DRIFT:"
            local drift_n checked_total
            drift_n=$(echo "$drift_output" | grep -c "^DRIFT:") || drift_n="0"
            checked_total=$(echo "$drift_output" | grep -oE 'Checked [0-9]+ tickets' | grep -oE '[0-9]+') || checked_total="0"
            echo "Drift check: $drift_n of $checked_total tickets drifted"
            return 1
        fi
    fi

    # ── Route to sync body (with or without lock) ──────────────────────────
    if [[ ${no_lock:-0} -eq 1 || "${TK_SYNC_SKIP_LOCK:-}" == "1" ]]; then
        # Bypass BOTH lock layers: distributed CAS lock (refs/tk/sync-lock)
        # and local mkdir lock (when w21-fqzt/w21-4x2x land).
        export TK_SYNC_SKIP_LOCAL_LOCK=1
        echo "warning: running without sync lock — concurrent syncs may cause duplicates" >&2
        _sync_body "$@"
    else
        _sync_with_lock "$@"
    fi
}

# ---------------------------------------------------------------------------
# cmd_backfill_jira_keys
#
# One-time idempotent operation: stamps jira_key from the ledger into ticket
# frontmatter for any tickets that are missing it.
# ---------------------------------------------------------------------------
cmd_backfill_jira_keys() {
    local dry_run=1
    local arg
    for arg in "$@"; do
        case "$arg" in
            --dry-run) dry_run=1 ;;
            --execute) dry_run=0 ;;
            *)
                echo "Error: unknown option: $arg" >&2
                echo "Usage: tk backfill-jira-keys [--dry-run|--execute]" >&2
                return 1
                ;;
        esac
    done

    local main_root
    main_root=$(_resolve_main_repo_root) || return 1
    local ledger_file="${SYNC_STATE_FILE:-$main_root/.tickets/.sync-state.json}"
    local tickets_dir
    if [[ -n "${TICKETS_DIR:-}" ]]; then
        tickets_dir="$TICKETS_DIR"
    else
        tickets_dir=$(find_tickets_dir 2>/dev/null) || tickets_dir=".tickets"
    fi

    if [[ ! -f "$ledger_file" ]]; then
        echo "Error: ledger not found at $ledger_file" >&2
        return 1
    fi

    local stamped=0 skipped=0 missing=0

    # Read all ledger entries
    while IFS=$'\t' read -r tk_id jira_key; do
        [[ -z "$tk_id" || -z "$jira_key" ]] && continue
        local ticket_file="$tickets_dir/$tk_id.md"
        if [[ ! -f "$ticket_file" ]]; then
            ((missing++))
            continue
        fi

        # Check if frontmatter already has jira_key
        local existing_key
        existing_key=$(awk '/^---$/{n++; next} n==1 && /^jira_key:/{print; exit}' "$ticket_file" \
            | sed 's/^jira_key:[[:space:]]*//' | tr -d "\"'")

        if [[ -n "$existing_key" ]]; then
            ((skipped++))
            continue
        fi

        if [[ $dry_run -eq 1 ]]; then
            echo "would stamp: $tk_id <- $jira_key"
            ((stamped++))
        else
            # Stamp jira_key
            if _grep -q "^jira_key:" "$ticket_file"; then
                _sed_i "$ticket_file" "s/^jira_key:.*/jira_key: ${jira_key}/"
            else
                local stamp_exit=0
                TICKET_FILE="$ticket_file" JIRA_KEY="$jira_key" python3 -c "
import os
ticket_file = os.environ['TICKET_FILE']
jira_key = os.environ['JIRA_KEY']
lines = open(ticket_file).readlines()
result = []
fm_count = 0
inserted = False
for line in lines:
    stripped = line.rstrip('\n').rstrip('\r')
    if stripped == '---':
        fm_count += 1
        if fm_count == 2 and not inserted:
            result.append('jira_key: ' + jira_key + '\n')
            inserted = True
    result.append(line)
open(ticket_file, 'w').writelines(result)
" || stamp_exit=$?
                if [[ $stamp_exit -ne 0 ]]; then
                    echo "warning: failed to stamp $tk_id" >&2
                    continue
                fi
            fi
            # Verify
            if ! _grep -q "^jira_key:" "$ticket_file"; then
                echo "warning: stamp verification failed for $tk_id" >&2
                continue
            fi
            # Propagate to worktrees
            ( _sync_ticket_file "$ticket_file" || true )
            echo "stamped: $tk_id <- $jira_key"
            ((stamped++))
        fi
    done < <(LEDGER_FILE="$ledger_file" python3 -c "
import json, os
data = json.load(open(os.environ['LEDGER_FILE']))
for tk_id, entry in data.items():
    jk = entry.get('jira_key', '')
    if jk:
        print(tk_id + '\t' + jk)
")

    if [[ $dry_run -eq 1 ]]; then
        echo "Dry run: $stamped tickets to stamp, $skipped already stamped, $missing ticket files not found"
    else
        echo "Stamped $stamped tickets, skipped $skipped (already stamped), $missing ticket files not found"
    fi
}

# ---------------------------------------------------------------------------
# cmd_sync_to_main
#
# One-shot recovery tool: pushes all divergent local .tickets/ files to main.
#
# For each local .tickets/*.md file:
#   - If it differs from main (or doesn't exist on main): call _sync_ticket_file
#   - If it exists on main but not locally: call _sync_ticket_delete
#   - If it matches main exactly: skip (idempotent)
#
# Prints a summary: "N files pushed, M files deleted, K files unchanged"
#
# Works from any worktree or the main repo.
# ---------------------------------------------------------------------------
cmd_sync_to_main() {
    # Resolve repo root: prefer injected REPO_ROOT env var, fall back to git
    local _REPO_ROOT="${REPO_ROOT:-}"
    if [[ -z "$_REPO_ROOT" ]]; then
        _REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
            echo "Error: not inside a git repository" >&2
            return 1
        }
    fi

    # Load tk-sync-lib.sh for _sync_ticket_file and _sync_ticket_delete.
    # tk-sync-lib.sh is always at the scripts/ dir of the *main* repo (not
    # a worktree-local copy). Resolve via the git common dir so we find the
    # real scripts/ dir even when running from inside a worktree.
    local _GIT_COMMON_DIR
    _GIT_COMMON_DIR=$(git -C "$_REPO_ROOT" rev-parse --git-common-dir 2>/dev/null) || _GIT_COMMON_DIR=""
    local _MAIN_REPO_ROOT=""
    if [[ -n "$_GIT_COMMON_DIR" ]]; then
        # git-common-dir may be relative — make it absolute
        case "$_GIT_COMMON_DIR" in
            /*) _MAIN_REPO_ROOT=$(dirname "$_GIT_COMMON_DIR") ;;
            *)  _MAIN_REPO_ROOT=$(dirname "$_REPO_ROOT/$_GIT_COMMON_DIR") ;;
        esac
    fi
    # If we couldn't resolve main repo root, fall back to _REPO_ROOT itself
    [[ -z "$_MAIN_REPO_ROOT" ]] && _MAIN_REPO_ROOT="$_REPO_ROOT"

    local _LIB="$_MAIN_REPO_ROOT/scripts/tk-sync-lib.sh"
    if [[ ! -f "$_LIB" ]]; then
        # Fallback: lib in same scripts/ dir as the tk script itself
        _LIB="$(cd "$(dirname "$0")" && pwd)/tk-sync-lib.sh"
    fi
    if [[ ! -f "$_LIB" ]]; then
        echo "Error: tk-sync-lib.sh not found" >&2
        return 1
    fi
    # shellcheck source=scripts/tk-sync-lib.sh
    source "$_LIB"

    # Export REPO_ROOT so _sync_ticket_file and _sync_ticket_delete use the
    # correct repo root (the one we resolved above, not the caller's CWD).
    export REPO_ROOT="$_REPO_ROOT"

    # Resolve tickets directory
    local tickets_dir="${TICKETS_DIR:-}"
    if [[ -z "$tickets_dir" ]]; then
        tickets_dir=$(find_tickets_dir 2>/dev/null) || {
            echo "Error: no .tickets directory found" >&2
            return 1
        }
    fi

    local pushed=0
    local deleted=0
    local unchanged=0

    # ── Pass 1: push local files that differ from (or are absent on) main ────
    local ticket_file rel_path main_content local_content
    for ticket_file in "$tickets_dir"/*.md; do
        [[ -f "$ticket_file" ]] || continue
        rel_path="${ticket_file#"$_REPO_ROOT/"}"

        # Get content from main branch (empty string if absent)
        main_content=$(git -C "$_REPO_ROOT" show "refs/heads/main:${rel_path}" 2>/dev/null) || main_content=""
        local_content=$(cat "$ticket_file" 2>/dev/null) || local_content=""

        if [[ "$local_content" == "$main_content" ]]; then
            ((unchanged++)) || true
        else
            # Call in a subshell so that the RETURN trap set by _sync_ticket_file
            # (to clean up its temp index) does not propagate to cmd_sync_to_main.
            ( _sync_ticket_file "$ticket_file" )
            ((pushed++)) || true
        fi
    done

    # ── Pass 2: delete files present on main but not locally ─────────────────
    local main_files main_file local_abs
    # List .tickets/*.md files tracked on main.
    # Determine the directory to check for local files: use tickets_dir if it
    # is under _REPO_ROOT, otherwise fall back to _REPO_ROOT/.tickets.
    local _local_tickets_dir="$_REPO_ROOT/.tickets"
    if [[ "$tickets_dir" == "$_REPO_ROOT"* ]]; then
        _local_tickets_dir="$tickets_dir"
    fi
    while IFS= read -r main_file; do
        [[ -n "$main_file" ]] || continue
        # main_file is like "some-ticket.md"; build the local abs path
        local_abs="$_local_tickets_dir/$main_file"
        if [[ ! -f "$local_abs" ]]; then
            # Call in a subshell so the RETURN trap from _sync_ticket_delete
            # does not propagate to cmd_sync_to_main.
            ( _sync_ticket_delete "$_REPO_ROOT/.tickets/$main_file" )
            ((deleted++)) || true
        fi
    done < <(git -C "$_REPO_ROOT" ls-tree --name-only "refs/heads/main:.tickets" 2>/dev/null \
        | grep '\.md$')

    echo "${pushed} files pushed, ${deleted} files deleted, ${unchanged} files unchanged"
    return 0
}

cmd_help() {
    local cmd
    cmd=$(basename "$0")
    cat << EOF
$cmd - minimal ticket system with dependency tracking

Usage: $cmd <command> [args]

Commands:
  create [title] [options] Create ticket, prints ID
    -d, --description      Description text
    --design               Design notes
    --acceptance           Acceptance criteria
    -t, --type             Type (bug|feature|task|epic|chore) [default: task]
    -p, --priority         Priority 0-4, 0=highest [default: 2]
    -a, --assignee         Assignee
    --external-ref         External reference (e.g., gh-123, JIRA-456)
    --parent               Parent ticket ID
    --tags                 Comma-separated tags (e.g., --tags ui,backend,urgent)
  start <id>               Set status to in_progress
  close <id> [--reason=..] Set status to closed (optionally add close reason note)
  reopen <id>              Set status to open
  status <id> <status>     Update status (open|in_progress|closed)
  dep <id> <dep-id>        Add dependency (id depends on dep-id)
  dep tree [--full] <id>   Show dependency tree (--full disables dedup)
  dep cycle                Find dependency cycles in open tickets
  undep <id> <dep-id>      Remove dependency
  link <id> <id> [id...]   Link tickets together (symmetric)
  unlink <id> <target-id>  Remove link between tickets
  ready [-a X] [-T X]      List open/in-progress tickets with deps resolved
  blocked [-a X] [-T X]    List open/in-progress tickets with unresolved deps
  list [options]           List tickets (non-closed by default)
    --type <type>          Filter by type (bug|task|epic|feature|chore)
    --status <status>      Filter by status (open|in_progress|closed)
    --priority <N>         Filter by priority (0-4)
    -a <name>              Filter by assignee
    --all                  Include closed tickets
  children <id>            List child tickets of a parent
  assign <id> <name>       Set assignee
  priority <id> <0-4>      Set priority
  parent <id> <parent-id>  Set parent ticket
  tag <id> <tag>           Add tag to ticket
  delete <id>              Delete ticket
  count [options]          Count tickets (same filters as list)
  search <pattern>         Search ticket content
  closed [--limit=N] [-a X] [-T X] List recently closed tickets (default 20, by mtime)
  show <id>                Display ticket
  add-note <id> [text]     Append timestamped note (or pipe via stdin)
  sync [options]           Sync tickets with Jira (push local→Jira, pull Jira→local)
    --check                Verify acli is installed, authenticated, and JIRA_PROJECT is accessible
                           JIRA_PROJECT: env var > jira.project in workflow-config.yaml
    --include-closed       Also push closed tickets (pull always fetches open issues)
    --force-local          Auto-resolve conflicts by keeping local version (no TTY needed)
    --no-lock              Skip both distributed and local sync locks (use with caution)
    --break-lock           Interactively break a stuck sync lock (CAS-guarded)
    --lock-timeout=N       Override lock acquire/sync timeout to N seconds
    --full                 Bypass incremental logic; perform full push+pull reconciliation
  sync-to-main             Push all divergent local .tickets/ changes to main branch
                           Files changed locally are pushed; files on main but not locally are deleted.
                           Idempotent: files already matching main are skipped.
                           Prints: "N files pushed, M files deleted, K files unchanged"
  super <cmd> [args]       Bypass plugins, run built-in command directly

Aliases:
  comment                  Alias for add-note
  open                     Alias for reopen
  ls                       Alias for list
  move                     Alias for status
EOF

    # List installed plugins
    local plugins
    plugins=$(_list_plugins 2>/dev/null)
    if [[ -n "$plugins" ]]; then
        cat << EOF

Plugins (tk-<cmd> or ticket-<cmd> in PATH):
$plugins
EOF
    fi

    cat << EOF

Use 'super' to bypass plugins. Plugins receive TICKETS_DIR and TK_SCRIPT
env vars; use '\$TK_SCRIPT super <cmd>' to call built-ins.

Plugin descriptions: comment '# tk-plugin: text' or --tk-describe flag

Tickets stored as markdown files in .tickets/
Supports partial ID matching (e.g., '$cmd show 5c4' matches 'nw-5c46')
EOF
}

# ---------------------------------------------------------------------------
# _sync_from_main
#
# Called before every read subcommand.  Compares git rev-parse main:.tickets
# against the hash stored in .tickets/.last-sync-hash.  If they
# differ (or the hash file is absent), runs:
#   git checkout main -- .tickets/
#   git reset HEAD .tickets/
# and rewrites .tickets/.last-sync-hash.
#
# Skips silently when:
#   • Not inside a git repository
#   • main:.tickets ref doesn't exist yet (fresh repo / no main branch)
#   • .git is a directory (running in the main repo, not a worktree)
#     — This avoids polluting the main repo's working tree.
#
# Zero network calls; at most two git rev-parse calls on the unchanged path.
# ---------------------------------------------------------------------------
_sync_from_main() {
    # No sync: _sync_ticket_file is intentionally NOT called here.
    # This function pulls .tickets/ FROM main into the worktree — calling
    # _sync_ticket_file would push those files back to main, creating a
    # circular write loop. The source of truth for this pull is main itself.

    # Determine the worktree root (directory containing .git file/dir)
    local git_root
    git_root=$(git rev-parse --show-toplevel 2>/dev/null) || return 0

    # Resolve the .git path
    local git_path="$git_root/.git"

    # If .git is a directory we are in the main repo — skip
    if [[ -d "$git_path" ]]; then
        return 0
    fi

    # Must be a file (worktree gitfile) to proceed
    if [[ ! -f "$git_path" ]]; then
        return 0
    fi

    # Resolve the canonical main repo root from the worktree gitfile
    local common_dir
    common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || return 0
    # --git-common-dir may return a relative path; make it absolute
    case "$common_dir" in
        /*) ;;
        *) common_dir="$git_root/$common_dir" ;;
    esac

    # Get the tree hash of main:.tickets from the main repo
    # Use the common_dir so we query the main repo's object store
    local main_hash
    main_hash=$(GIT_DIR="$common_dir" git rev-parse main:.tickets 2>/dev/null) || return 0

    # Compare with cached hash
    local hash_file="$git_root/.tickets/.last-sync-hash"
    local cached_hash=""
    [[ -f "$hash_file" ]] && cached_hash=$(cat "$hash_file" 2>/dev/null || true)

    if [[ "$main_hash" == "$cached_hash" ]]; then
        # Nothing changed — fast path (zero additional git calls)
        return 0
    fi

    # Hashes differ: pull .tickets/ from main, preserving local-only changes.
    (
        cd "$git_root" || exit 0

        # Detect local-only changes: files that differ from the last-synced
        # tree.  These are edits whose _sync_ticket_file push may have failed;
        # overwriting them would silently lose work (GAP-5).
        #
        # Strategy: for each .tickets/*.md file in the worktree, compare its
        # content against the same path in the cached tree hash (which is a
        # git tree object for .tickets/).  If the file has been modified
        # locally since the last sync, it won't match the tree entry.
        local _local_only_files=()
        # Use cached_hash if available; fall back to main_hash when
        # the hash file is missing (e.g., deleted or first sync).
        local _compare_hash="${cached_hash:-$main_hash}"
        if [[ -n "$_compare_hash" ]]; then
            # Batch 1: ONE git ls-tree call for all blob hashes (replaces N per-file calls).
            # Build parallel arrays: _tree_names[i] / _tree_hashes[i].
            # ls-tree output format: "mode type hash<TAB>filename"
            local _tree_names=() _tree_hashes=()
            while IFS=$' \t' read -r _tm _tt _t_hash _t_name; do
                _tree_names+=("$_t_name")
                _tree_hashes+=("$_t_hash")
            done < <(git ls-tree "$_compare_hash" 2>/dev/null)

            # Collect all ticket files (bash parameter expansion avoids basename subprocess)
            local _ticket_files=()
            for _wt_file in .tickets/*.md; do
                [[ -f "$_wt_file" ]] || continue
                _ticket_files+=("$_wt_file")
            done

            if [[ ${#_ticket_files[@]} -gt 0 ]]; then
                # Batch 2: ONE git hash-object call for all working-tree files.
                # --stdin-paths reads filenames from stdin, outputs one hash per line
                # in the same order — maps 1:1 with _ticket_files[].
                local _wt_hashes=()
                while IFS= read -r _wt_h; do
                    _wt_hashes+=("$_wt_h")
                done < <(printf '%s\n' "${_ticket_files[@]}" | git hash-object --stdin-paths 2>/dev/null)

                # Compare using pure bash string ops — no subprocess per file.
                local _i _j _wt_basename _found_hash
                for _i in "${!_ticket_files[@]}"; do
                    _wt_file="${_ticket_files[$_i]}"
                    _wt_basename="${_wt_file##*/}"  # bash built-in: no subprocess
                    _found_hash=""
                    for _j in "${!_tree_names[@]}"; do
                        if [[ "${_tree_names[$_j]}" == "$_wt_basename" ]]; then
                            _found_hash="${_tree_hashes[$_j]}"
                            break
                        fi
                    done
                    # If file doesn't exist in cached tree, it's new — handled by
                    # checkout (new files from main get added; locally-created files
                    # without a cached counterpart are not at risk of overwrite).
                    if [[ -n "$_found_hash" && "${_wt_hashes[$_i]:-}" != "$_found_hash" ]]; then
                        _local_only_files+=("$_wt_file")
                    fi
                done
            fi
        fi

        # Clear any skip-worktree flags on .tickets/ files before overwriting.
        # If files were synced by _sync_ticket_file and marked skip-worktree,
        # git checkout would silently skip them (the skip-worktree flag tells
        # git "don't touch this file"). We clear the flags first so the pull
        # always overwrites with the authoritative main branch content.
        _clear_ticket_skip_worktree

        if [[ ${#_local_only_files[@]} -eq 0 ]]; then
            # No local-only changes — safe to overwrite everything
            git checkout main -- .tickets/ 2>/dev/null || true
        else
            # Back up local-only files, checkout from main, then restore them
            local _tmpdir
            _tmpdir=$(mktemp -d)
            for _f in "${_local_only_files[@]}"; do
                cp "$_f" "$_tmpdir/$(basename "$_f")" 2>/dev/null || true
            done

            git checkout main -- .tickets/ 2>/dev/null || true

            # Restore local-only files
            for _f in "${_local_only_files[@]}"; do
                local _basename
                _basename=$(basename "$_f")
                if [[ -f "$_tmpdir/$_basename" ]]; then
                    cp "$_tmpdir/$_basename" "$_f"
                    echo "tk: preserving local-only changes in $_basename" >&2
                fi
            done
            rm -rf "$_tmpdir"
        fi
        git reset HEAD .tickets/ >/dev/null 2>&1 || true

        # Remove .sync-lock if it was pulled from main — it is a transient
        # lock sentinel and should never persist in worktree working trees.
        rm -f .tickets/.sync-lock
    )

    # Update the cached hash
    echo "$main_hash" > "$hash_file"
}

# Main dispatch

# Handle 'super' to bypass plugins
_tk_super=0
if [[ "${1:-}" == "super" ]]; then
    _tk_super=1
    shift
fi

# Check for plugin commands first (unless super mode)
# Plugins are responsible for their own TICKETS_DIR handling
if [[ $_tk_super -eq 0 && -n "${1:-}" && "${1:-}" != "help" && "${1:-}" != "--help" && "${1:-}" != "-h" ]]; then
    for _prefix in tk ticket; do
        _plugin="${_prefix}-$1"
        if command -v "$_plugin" &>/dev/null; then
            # Export context for plugins
            export TICKETS_DIR="${TICKETS_DIR:-$(find_tickets_dir 2>/dev/null || echo "")}"
            export TK_SCRIPT="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
            shift
            exec "$_plugin" "$@"
        fi
    done
fi

# Source-only mode: define functions but skip dispatch (used by tests)
[[ "${_TK_SOURCE_ONLY:-}" == "1" ]] && return 0 2>/dev/null || true
[[ "${_TK_SOURCE_ONLY:-}" == "1" ]] && exit 0

# Initialize tickets dir for built-in commands (skip for help and sync)
case "${1:-help}" in
    help|--help|-h) ;;
    sync) ;;
    sync-to-main) ;;
    backfill-jira-keys) ;;
    *) init_tickets_dir "${1:-}" || exit 1 ;;
esac

# Auto-sync .tickets/ from main before READ subcommands only.
# Write commands (create, close, etc.) must NOT trigger sync — if a prior
# _sync_ticket_file push failed, _sync_from_main would overwrite the
# local-only change via `git checkout main -- .tickets/`.  See GAP-5.
case "${1:-help}" in
    list|ls|show|ready|blocked|search|count|children|closed) _sync_from_main ;;
esac

# Built-in commands
case "${1:-help}" in
    create) shift; cmd_create "$@" ;;
    start)  shift; cmd_start "$@" ;;
    close)  shift; cmd_close "$@" ;;
    reopen) shift; cmd_reopen "$@" ;;
    status) shift; cmd_status "$@" ;;
    dep)    shift; cmd_dep "$@" ;;
    undep)  shift; cmd_undep "$@" ;;
    link)   shift; cmd_link "$@" ;;
    unlink) shift; cmd_unlink "$@" ;;
    ready)  shift; cmd_ready "$@" ;;
    blocked) shift; cmd_blocked "$@" ;;
    closed) shift; cmd_closed "$@" ;;
    list)   shift; cmd_list "$@" ;;
    children) shift; cmd_children "$@" ;;
    assign) shift; cmd_assign "$@" ;;
    priority) shift; cmd_priority "$@" ;;
    parent) shift; cmd_set_parent "$@" ;;
    tag)    shift; cmd_tag "$@" ;;
    delete) shift; cmd_delete "$@" ;;
    count)  shift; cmd_count "$@" ;;
    search) shift; cmd_search "$@" ;;
    comment) shift; cmd_add_note "$@" ;;
    open)   shift; cmd_reopen "$@" ;;
    ls)     shift; cmd_list "$@" ;;
    move)   shift; cmd_status "$@" ;;
    show)   shift; cmd_show "$@" ;;
    add-note) shift; cmd_add_note "$@" ;;
    enumerate-notes) shift; cmd_enumerate_notes "$@" ;;
    sync)    shift; cmd_sync "$@" ;;
    sync-to-main) shift; cmd_sync_to_main "$@" ;;
    backfill-jira-keys) shift; cmd_backfill_jira_keys "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $1" >&2
        cmd_help >&2
        exit 1
        ;;
esac
