#!/usr/bin/env bash
# plugins/dso/scripts/ticket
# Dispatcher for the event-sourced ticket system.
# Routes subcommands to their implementation scripts.
#
# Usage: ticket <subcommand> [args...]
#   ticket init      — initialize ticket system (orphan branch + worktree)
#   ticket create    — create a new ticket
#   ticket show      — show ticket details
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_usage() {
    echo "Usage: ticket <subcommand> [args...]"
    echo ""
    echo "Subcommands:"
    echo "  init      Initialize the ticket system"
    echo "  create    Create a new ticket"
    echo "  show      Show ticket details"
    exit 1
}

_ensure_initialized() {
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
        echo "Error: not inside a git repository" >&2
        exit 1
    }
    if [[ ! -d "$repo_root/.tickets-tracker" ]]; then
        bash "$SCRIPT_DIR/ticket-init.sh" --silent 1>/dev/null || {
            echo "Error: ticket system initialization failed. Run 'ticket init' manually." >&2
            exit 1
        }
    fi
}

if [ $# -lt 1 ]; then
    _usage
fi

subcommand="$1"
shift

case "$subcommand" in
    init)
        exec bash "$SCRIPT_DIR/ticket-init.sh" "$@"
        ;;
    create)
        _ensure_initialized
        exec bash "$SCRIPT_DIR/ticket-create.sh" "$@"
        ;;
    show)
        _ensure_initialized
        exec bash "$SCRIPT_DIR/ticket-show.sh" "$@"
        ;;
    # REVIEW-DEFENSE: 'transition' subcommand routing is intentionally absent here.
    # ticket-transition.sh does not yet exist; wiring the dispatcher is tracked in dso-lcmz
    # and must be done alongside implementing ticket-transition.sh so the two land together.
    *)
        echo "Error: unknown subcommand '$subcommand'" >&2
        _usage
        ;;
esac
