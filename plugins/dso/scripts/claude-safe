#!/usr/bin/env bash
# scripts/claude-safe — Launch Claude Code with automatic worktree isolation
#
# Drop-in replacement for `claude` that always creates a fresh worktree
# so every session gets its own isolated working directory.
#
# Behavior:
#   1. If not in a git repo → launches claude normally
#   2. If already in a worktree → launches claude normally
#   3. If in main repo → creates a new worktree and launches claude there
#   4. On exit from auto-created worktree → offers to remove if branch is merged
#   5. When creating 4th+ worktree → suggests running worktree-cleanup.sh
#   6. When 10+ worktrees exist → auto-runs worktree-cleanup.sh
#
# Usage:
#   claude-safe                    # Launch claude in a new worktree
#   claude-safe --resume           # Pass flags through to claude
#   claude-safe --help-wrapper     # Show this script's help
#
# Source-only mode (for tests):
#   _CLAUDE_SAFE_SOURCE_ONLY=1 source scripts/claude-safe
#   _cleanup_docker_for_worktree "wt-name" "/path/to/wt"
#
# Config keys read from workflow-config.yaml via read-config.sh:
#   infrastructure.compose_files   — list of compose file paths (relative to repo root)
#   infrastructure.compose_project — prefix for COMPOSE_PROJECT_NAME (e.g. myproject-db-)
#   worktree.service_start_cmd   — command to start background services before Claude launches
#   database.port_cmd            — script path (relative to repo root) that resolves APP_PORT

set -euo pipefail

# ── Plugin scripts resolution ─────────────────────────────────────────────────
# PLUGIN_SCRIPTS can be injected by callers (e.g. tests); otherwise resolved
# relative to BASH_SOURCE so the script works from any CWD.
if [ -z "${PLUGIN_SCRIPTS:-}" ]; then
    PLUGIN_SCRIPTS="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

# ── Config helper ─────────────────────────────────────────────────────────────
# _read_cfg [--list] <key> — read a config value via read-config.sh.
# When WORKFLOW_CONFIG is set, it is passed as the config-file argument.
_read_cfg() {
    local list_flag=""
    if [ "${1:-}" = "--list" ]; then
        list_flag="--list"
        shift
    fi
    local key="$1"
    if [ -n "${WORKFLOW_CONFIG:-}" ]; then
        bash "$PLUGIN_SCRIPTS/read-config.sh" $list_flag "$key" "$WORKFLOW_CONFIG" 2>/dev/null || true
    else
        bash "$PLUGIN_SCRIPTS/read-config.sh" $list_flag "$key" 2>/dev/null || true
    fi
}

# ── Docker cleanup helper ─────────────────────────────────────────────────────
# Stops the worktree's containers and removes Docker networks.
# Called before worktree removal to prevent Docker network exhaustion.
#
# Reads infrastructure.compose_files from config (list of paths relative to repo root).
# For each file: COMPOSE_PROJECT_NAME="<compose_project><wt_name>" docker compose -f <wt_path>/<file> down
# When the key is absent, no Docker cleanup is attempted.
# When Docker is not on PATH, returns silently.
_cleanup_docker_for_worktree() {
    local wt_name="$1"
    local wt_path="$2"

    if ! command -v docker &>/dev/null; then
        return
    fi

    # Read compose file list from config; absent key → no cleanup
    local compose_files
    compose_files=$(_read_cfg --list infrastructure.compose_files 2>/dev/null) || true
    if [ -z "$compose_files" ]; then
        return
    fi

    # Read compose project prefix from config (e.g. myproject-db-)
    local compose_project
    compose_project=$(_read_cfg infrastructure.compose_project 2>/dev/null) || true

    # Iterate each compose file; failures are isolated (|| true after each call)
    while IFS= read -r compose_file; do
        [ -z "$compose_file" ] && continue
        local full_path="$wt_path/$compose_file"
        COMPOSE_PROJECT_NAME="${compose_project}${wt_name}" docker compose -f "$full_path" down 2>/dev/null || true
    done <<< "$compose_files"
}

# ── Worktree cleanup helper ───────────────────────────────────────────────────
_offer_worktree_cleanup() {
    local wt_name="$1"
    local wt_path="$2"

    # Check if stdin is a terminal (interactive session).
    # _CLAUDE_SAFE_TEST_INTERACTIVE=1 bypasses this guard in tests.
    if [ ! -t 0 ] && [ "${_CLAUDE_SAFE_TEST_INTERACTIVE:-0}" != "1" ]; then
        return
    fi

    # Find the main repo root (parent of this worktree)
    local main_root
    main_root=$(git -C "$wt_path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's|/\.git$||') || return

    # Check if the worktree's branch is merged to main
    local branch
    branch=$(git -C "$wt_path" branch --show-current 2>/dev/null) || return
    if [ -z "$branch" ]; then
        return
    fi

    local is_merged=0
    if git -C "$main_root" merge-base --is-ancestor "$branch" main 2>/dev/null; then
        is_merged=1
    elif git -C "$main_root" log main --oneline --grep="(merge $branch)" -1 2>/dev/null | grep -q .; then
        # Fallback: the branch tip may have been amended after the merge
        # (e.g., orchestrator recovery after merge-to-main.sh timeout).
        # The amend changes the SHA so is-ancestor fails, but main's merge
        # commit message still references this branch name.
        is_merged=1
    elif git -C "$main_root" log main --oneline --grep="Merge pull request.*$branch" -1 2>/dev/null | grep -q .; then
        # Fallback: GitHub PR merge commits use "Merge pull request #N from org/branch".
        # Anchored to "Merge pull request" to avoid false positives from unrelated
        # commits that mention the branch name in their body text.
        is_merged=1
    fi

    # Check for uncommitted changes — any dirty file blocks auto-removal.
    # .tickets-tracker/ files are treated like any other uncommitted change.  # tickets-boundary-ok: documents behavioral expectation, not direct access
    local is_clean=1
    if [ -n "$(git -C "$wt_path" status --porcelain 2>/dev/null)" ]; then
        is_clean=0
    fi

    local can_remove=0
    if [ "$is_merged" -eq 1 ] && [ "$is_clean" -eq 1 ]; then
        can_remove=1
    fi

    # Auto-remove if safe; show blocking details otherwise
    if [ "$can_remove" -eq 1 ]; then
        echo ""
        echo "Cleaning up worktree '$wt_name' (branch merged to main, working tree clean)..."

        # Stop Docker containers/networks for this worktree
        _cleanup_docker_for_worktree "$wt_name" "$wt_path"

        local removed=0
        if git -C "$main_root" worktree remove "$wt_path" --force 2>/dev/null; then
            removed=1
        fi

        if [ "$removed" -eq 1 ]; then
            echo "Worktree removed."
            # Delete local branch
            git -C "$main_root" branch -d "$branch" 2>/dev/null && echo "Local branch '$branch' deleted." || \
            git -C "$main_root" branch -D "$branch" 2>/dev/null && echo "Local branch '$branch' deleted." || true
            # Delete remote branch if it exists
            if git -C "$main_root" ls-remote --heads origin "$branch" 2>/dev/null | grep -q .; then
                git -C "$main_root" push origin --delete "$branch" 2>/dev/null && echo "Remote branch 'origin/$branch' deleted." || true
            fi
        else
            echo "Worktree removal failed. Run 'worktree-cleanup.sh' from the main repo."
        fi
    else
        echo ""
        echo "Worktree '$wt_name' cannot be auto-removed:"
        if [ "$is_merged" -eq 0 ]; then
            echo ""
            echo "  Branch '$branch' has unmerged commits:"
            git -C "$wt_path" log main..HEAD --oneline 2>/dev/null | sed 's/^/    /' || echo "    (unable to list commits)"
        fi
        if [ "$is_clean" -eq 0 ]; then
            echo ""
            echo "  Uncommitted changes:"
            git -C "$wt_path" status --short 2>/dev/null | sed 's/^/    /' || echo "    (unable to list changes)"
        fi
        echo ""
        echo "Run 'worktree-cleanup.sh' from the main repo to manage worktrees."
    fi
}

# ── Source-only guard ─────────────────────────────────────────────────────────
# When _CLAUDE_SAFE_SOURCE_ONLY=1, stop here so tests can source just the
# helper functions without running the main script body.
if [ "${_CLAUDE_SAFE_SOURCE_ONLY:-}" = "1" ]; then
    return 0 2>/dev/null || true
fi

# ── Help ──────────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--help-wrapper" ]]; then
    sed -n '2,/^$/s/^# //p' "$0"
    exit 0
fi

# ── Not in a git repo: launch normally ───────────────────────────────────────
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
if [ -z "$REPO_ROOT" ]; then
    exec claude "$@"
fi

# ── Already in a worktree: launch normally ────────────────────────────────────
if [ -f "$REPO_ROOT/.git" ]; then
    exec claude "$@"
fi

# ── In main repo: create a new worktree via worktree-create.sh ───────────────
CREATE_SCRIPT="$PLUGIN_SCRIPTS/worktree-create.sh"
if [ ! -x "$CREATE_SCRIPT" ]; then
    # Fall back to project scripts/ directory
    CREATE_SCRIPT="$REPO_ROOT/scripts/worktree-create.sh"
fi
if [ ! -x "$CREATE_SCRIPT" ]; then
    echo "ERROR: worktree-create.sh not found or not executable" >&2
    exit 1
fi

WORKTREE_PATH=$("$CREATE_SCRIPT")
if [ -z "$WORKTREE_PATH" ] || [ ! -d "$WORKTREE_PATH" ]; then
    echo "ERROR: Failed to create worktree" >&2
    echo "Create one manually: $CREATE_SCRIPT" >&2
    exit 1
fi

WORKTREE_NAME=$(basename "$WORKTREE_PATH")
# Read artifact prefix from config (session.artifact_prefix); fallback to repo-basename + -test-artifacts
_artifact_prefix=$(_read_cfg session.artifact_prefix 2>/dev/null) || true
if [ -z "$_artifact_prefix" ]; then
    _artifact_prefix="$(basename "$REPO_ROOT")-test-artifacts"
fi
VALIDATION_ARTIFACTS_DIR="/tmp/${_artifact_prefix}-${WORKTREE_NAME}"
mkdir -p "$VALIDATION_ARTIFACTS_DIR"
VALIDATION_STATE_FILE="$VALIDATION_ARTIFACTS_DIR/status"

# ── Service startup (background, config-driven) ───────────────────────────────
# Runs worktree.service_start_cmd from workflow-config.yaml (when set) in a
# background subshell. When absent, no service startup is attempted (zero-config no-op).
# Failure is non-blocking: stderr captured to SERVICE_LOG for post-hoc inspection.
#
# Security note: worktree.service_start_cmd executes an arbitrary command.
# This is the same trust boundary as the script itself — the config file lives
# in the repo and is controlled by repo owners.
# REVIEW-DEFENSE: eval is intentional here. The config value may use shell
# chaining (e.g. 'cd "$WORKTREE_PATH/app" && env VAR=val cmd'), which requires
# eval to handle properly. bash -c would suppress variable expansion that the
# caller relies on (WORKTREE_PATH, APP_PORT). The trust boundary is identical
# to the script itself; repo owners control workflow-config.yaml.
# Test coverage: scripts/tests/test-claude-safe.sh tests 13-18 cover this block.
SERVICE_LOG="$VALIDATION_ARTIFACTS_DIR/service-startup.log"
SERVICE_START_CMD=$(_read_cfg worktree.service_start_cmd 2>/dev/null || true)
if [ -n "$SERVICE_START_CMD" ]; then
    # Resolve APP_PORT via database.port_cmd config (exported for the command)
    PORT_CMD=$(_read_cfg database.port_cmd 2>/dev/null || true)
    APP_PORT=""
    if [ -n "$PORT_CMD" ]; then
        APP_PORT=$("$REPO_ROOT/$PORT_CMD" "$WORKTREE_NAME" app 2>/dev/null || true)
    fi
    echo "[service] Starting pre-launch services (background)..."
    echo "  Log: $SERVICE_LOG"
    (
        export WORKTREE_PATH="$WORKTREE_PATH"
        export APP_PORT="$APP_PORT"
        echo "[$(date +%H:%M:%S)] $SERVICE_START_CMD" >> "$SERVICE_LOG" 2>&1
        eval "$SERVICE_START_CMD" >> "$SERVICE_LOG" 2>&1; _svc_rc=$?
        [ "$_svc_rc" -eq 0 ] || echo "[$(date +%H:%M:%S)] service startup FAILED (exit $_svc_rc)" >> "$SERVICE_LOG" 2>&1
        echo "[$(date +%H:%M:%S)] service startup complete" >> "$SERVICE_LOG" 2>&1
    ) &
fi

# ── Validation skip ──────────────────────────────────────────────────────────
# Write "skipped" state so the validation-gate PreToolUse hook does not block.
echo "skipped" > "$VALIDATION_STATE_FILE"
echo "timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$VALIDATION_STATE_FILE"
echo "reason=no_code_changes" >> "$VALIDATION_STATE_FILE"

echo "Launching Claude in: $WORKTREE_PATH"
echo ""
(cd "$WORKTREE_PATH" && claude "$@") || true
# ── Post-exit: offer to clean up this auto-created worktree ──────────────────
# Note: we never cd'd out of REPO_ROOT, so our cwd is NOT inside the worktree.
# This is critical — git worktree remove fails if a process's cwd is inside the target.
_offer_worktree_cleanup "$WORKTREE_NAME" "$WORKTREE_PATH"
exit 0
