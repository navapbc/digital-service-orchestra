{
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    }
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "debugging-toolkit@claude-code-workflows": true,
    "unit-testing@claude-code-workflows": true,
    "error-debugging@claude-code-workflows": true,
    "backend-api-security@claude-code-workflows": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/inject-using-lockpick.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/session-safety-check.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/post-compact-review-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/tool-logging.sh pre"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/dispatchers/pre-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/validation-gate.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/worktree-edit-guard.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/cascade-circuit-breaker.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/title-length-validator.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/plan-review-gate.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/validation-gate.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/worktree-edit-guard.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/cascade-circuit-breaker.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/title-length-validator.sh"
          }
        ]
      },
      {
        "matcher": "TaskOutput",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/taskoutput-block-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/dispatchers/post-all.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/dispatchers/post-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/dispatchers/post-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/dispatchers/post-write.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/review-stop-check.sh"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/tool-logging-summary.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && hooks/run-hook.sh hooks/track-tool-errors.sh"
          }
        ]
      }
    ]
  }
}
