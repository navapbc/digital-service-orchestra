{
  "name": "dso",
  "version": "1.15.14",
  "description": "Workflow infrastructure plugin for Claude Code projects",
  "commands": "./commands/",
  "skills": "./skills/",
  "agents": [
    "./agents/approach-decision-maker.md",
    "./agents/bloat-blue-team.md",
    "./agents/bloat-resolver.md",
    "./agents/blue-team-filter.md",
    "./agents/bot-psychologist.md",
    "./agents/code-reviewer-deep-arch.md",
    "./agents/code-reviewer-deep-correctness.md",
    "./agents/code-reviewer-deep-hygiene.md",
    "./agents/code-reviewer-deep-verification.md",
    "./agents/code-reviewer-light.md",
    "./agents/code-reviewer-performance.md",
    "./agents/code-reviewer-security-blue-team.md",
    "./agents/code-reviewer-security-red-team.md",
    "./agents/code-reviewer-standard.md",
    "./agents/code-reviewer-test-quality.md",
    "./agents/completion-verifier.md",
    "./agents/complexity-evaluator.md",
    "./agents/conflict-analyzer.md",
    "./agents/cross-epic-interaction-classifier.md",
    "./agents/doc-writer.md",
    "./agents/feasibility-reviewer.md",
    "./agents/huge-diff-refactor-anomaly.md",
    "./agents/huge-diff-reviewer-light.md",
    "./agents/huge-diff-reviewer-standard.md",
    "./agents/intent-search.md",
    "./agents/plan-review.md",
    "./agents/red-team-reviewer.md",
    "./agents/red-test-evaluator.md",
    "./agents/red-test-writer.md",
    "./agents/scope-drift-reviewer.md",
    "./agents/ui-designer.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/pre-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/pre-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/pre-write.sh"
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/pre-enterplanmode.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/pre-exitplanmode.sh"
          }
        ]
      },
      {
        "matcher": "TaskOutput",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/pre-taskoutput.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/post-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/post-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/post-write.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/post-agent.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/stop.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh dispatchers/post-failure.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.sh fix-bug-skill-directive.sh"
          }
        ]
      }
    ]
  }
}
