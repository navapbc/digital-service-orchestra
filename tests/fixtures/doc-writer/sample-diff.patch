+    # Must have at least 6 fields
+    [ "$field_count" -ge 6 ] || return 1
+    # Both blocker IDs must appear in the 6th field (order not guaranteed)
+    [[ "$field6" == *"task-m1"* ]] || return 1
+    [[ "$field6" == *"task-m2"* ]] || return 1
