+# ── Test 34: Unblocked epic that blocks another has BLOCKING marker ──────────
+echo "Test 34: test_blocking_epic_has_marker — unblocked epic blocking another epic shows BLOCKING in 5th field"
+test_blocking_epic_has_marker() {
